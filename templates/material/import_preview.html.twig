{% extends 'layout/app.html.twig' %}

{% block title %}Vista Previa de Importación{% endblock %}

{% block page_title %}Vista Previa de Importación Excel{% endblock %}

{% block content %}
<div class="container-fluid py-4">
    <div class="card shadow mb-4">
        <div class="card-header py-3 bg-primary text-white">
            <h6 class="m-0 font-weight-bold">
                <i class="fas fa-file-excel mr-2"></i>
                Resumen de Importación
            </h6>
        </div>
        <div class="card-body">
            <div class="alert alert-info">
                <i class="fas fa-info-circle mr-2"></i>
                <strong>Se han detectado {{ preview.total_rows }} filas</strong> en el archivo Excel, que afectan a <strong>{{ preview.materials|length }} materiales</strong>.
            </div>

            <form method="post" action="{{ path('app_material_import_process') }}">
                <input type="hidden" name="temp_filename" value="{{ temp_filename }}">

            {% if preview.conflicts|length > 0 %}
            <div class="card border-warning mb-4">
                <div class="card-header bg-warning text-dark">
                    <h6 class="m-0 font-weight-bold">
                        <i class="fas fa-exclamation-triangle mr-2"></i>
                        Conflictos de Números de Serie Detectados
                    </h6>
                </div>
                <div class="card-body">
                    <p class="small text-muted">Se han detectado números de serie que ya existen en el sistema o están repetidos en el Excel. Por favor, elige qué versión de los datos deseas conservar para cada caso.</p>

                    <div class="table-responsive">
                        <table class="table table-sm table-bordered">
                            <thead class="bg-light">
                                <tr>
                                    <th>S/N</th>
                                    <th>Versión Actual / Existente</th>
                                    <th>Versión Nueva (Excel)</th>
                                    <th>Acción</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for sn, conflict in preview.conflicts %}
                                <tr>
                                    <td class="font-bold align-middle">{{ sn }}</td>
                                    <td class="small align-middle">
                                        <div class="text-slate-700"><strong>Material:</strong> {{ conflict.existing.materialName }}</div>
                                        <div class="text-slate-500"><strong>Alias:</strong> {{ conflict.existing.alias|default('-') }}</div>
                                        <div class="text-slate-500"><strong>Modelo:</strong> {{ conflict.existing.brandModel|default('-') }}</div>
                                    </td>
                                    <td class="small align-middle">
                                        <div class="text-primary font-bold"><strong>Material:</strong> {{ conflict.new.materialName }}</div>
                                        <div class="text-primary"><strong>Alias:</strong> {{ conflict.new.alias|default('-') }}</div>
                                        <div class="text-primary"><strong>Modelo:</strong> {{ conflict.new.brandModel|default('-') }}</div>
                                    </td>
                                    <td class="align-middle">
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="conflict_resolutions[{{ sn }}]" id="keep_{{ sn }}" value="keep" checked>
                                            <label class="form-check-label small" for="keep_{{ sn }}">
                                                Mantener existente
                                            </label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="conflict_resolutions[{{ sn }}]" id="update_{{ sn }}" value="update">
                                            <label class="form-check-label small" for="update_{{ sn }}">
                                                Actualizar con nuevo
                                            </label>
                                        </div>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            {% endif %}

            <div class="table-responsive">
                <table class="table table-hover table-bordered table-sm">
                    <thead class="bg-light">
                        <tr>
                            <th>Acción</th>
                            <th>Material</th>
                            <th>Info</th>
                            <th>Stock Actual</th>
                            <th>Cambio</th>
                            <th>Stock Final</th>
                            <th>Detalles</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in preview.materials %}
                        <tr class="{{ item.is_new ? 'table-primary' : '' }}">
                            <td class="text-center align-middle">
                                {% if item.is_new %}
                                    <span class="badge bg-primary px-3 py-2 text-white font-black" style="letter-spacing: 0.05em;">NUEVO</span>
                                {% else %}
                                    <span class="badge bg-success px-3 py-2 text-white font-black" style="letter-spacing: 0.05em;">ACTUALIZAR</span>
                                {% endif %}
                            </td>
                            <td class="align-middle">
                                <div class="font-black text-slate-900">{{ item.name }}</div>
                                <small class="text-slate-500 font-bold">{{ item.barcode|default('Sin EAN') }}</small>
                            </td>
                            <td class="align-middle">
                                <span class="badge bg-slate-200 text-slate-700 border border-slate-300">{{ item.category }}</span><br>
                                <span class="badge bg-blue-100 text-blue-700 border border-blue-200 mt-1">{{ item.nature }}</span>
                            </td>
                            <td class="text-center align-middle">{{ item.current_stock }}</td>
                            <td class="text-center align-middle text-success font-weight-bold">+{{ item.stock_to_add }}</td>
                            <td class="text-center align-middle font-weight-bold">{{ item.current_stock + item.stock_to_add }}</td>
                            <td class="align-middle">
                                {% if item.units_to_create > 0 %}
                                    <div class="small"><i class="fas fa-microchip mr-1"></i>{{ item.units_to_create }} unidades nuevas</div>
                                {% endif %}
                                {% if item.batches_to_create|length > 0 %}
                                    <div class="small text-truncate" style="max-width: 200px;" title="{{ item.batches_to_create|join(', ') }}">
                                        <i class="fas fa-layer-group mr-1"></i>Lotes: {{ item.batches_to_create|join(', ') }}
                                    </div>
                                {% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {% if preview.errors|length > 0 %}
            <div class="alert alert-danger">
                <h6><i class="fas fa-exclamation-triangle mr-2"></i>Errores Detectados:</h6>
                <ul>
                    {% for error in preview.errors %}
                    <li>{{ error }}</li>
                    {% endfor %}
                </ul>
            </div>
            {% endif %}

            <div class="mt-4 d-flex justify-content-between">
                <a href="{{ path('app_material_index') }}" class="btn btn-secondary">
                    <i class="fas fa-times mr-2"></i>Cancelar
                </a>
                <button type="submit" class="btn btn-success btn-lg px-5">
                    <i class="fas fa-check mr-2"></i>Confirmar Importación
                </button>
            </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
