{% extends 'layout/app.html.twig' %}

{% block title %}Vista Previa de Importación{% endblock %}

{% block page_title %}Vista Previa de Importación Excel{% endblock %}

{% block content %}
<div class="container-fluid py-4">
    <div class="card shadow mb-4">
        <div class="card-header py-3 bg-primary text-white">
            <h6 class="m-0 font-weight-bold">
                <i class="fas fa-file-excel mr-2"></i>
                Resumen de Importación
            </h6>
        </div>
        <div class="card-body">
            <div class="alert alert-info">
                <i class="fas fa-info-circle mr-2"></i>
                <strong>Se han detectado {{ preview.total_rows }} filas</strong> en el archivo Excel, que afectan a <strong>{{ preview.materials|length }} materiales</strong>.
            </div>

            <div class="table-responsive">
                <table class="table table-hover table-bordered table-sm">
                    <thead class="bg-light">
                        <tr>
                            <th>Acción</th>
                            <th>Material</th>
                            <th>Info</th>
                            <th>Stock Actual</th>
                            <th>Cambio</th>
                            <th>Stock Final</th>
                            <th>Detalles</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in preview.materials %}
                        <tr class="{{ item.is_new ? 'table-primary' : '' }}">
                            <td class="text-center align-middle">
                                {% if item.is_new %}
                                    <span class="badge bg-primary px-3 py-2 text-white font-black" style="letter-spacing: 0.05em;">NUEVO</span>
                                {% else %}
                                    <span class="badge bg-success px-3 py-2 text-white font-black" style="letter-spacing: 0.05em;">ACTUALIZAR</span>
                                {% endif %}
                            </td>
                            <td class="align-middle">
                                <div class="font-black text-slate-900">{{ item.name }}</div>
                                <small class="text-slate-500 font-bold">{{ item.barcode|default('Sin EAN') }}</small>
                            </td>
                            <td class="align-middle">
                                <span class="badge bg-slate-200 text-slate-700 border border-slate-300">{{ item.category }}</span><br>
                                <span class="badge bg-blue-100 text-blue-700 border border-blue-200 mt-1">{{ item.nature }}</span>
                            </td>
                            <td class="text-center align-middle">{{ item.current_stock }}</td>
                            <td class="text-center align-middle text-success font-weight-bold">+{{ item.stock_to_add }}</td>
                            <td class="text-center align-middle font-weight-bold">{{ item.current_stock + item.stock_to_add }}</td>
                            <td class="align-middle">
                                {% if item.units_to_create > 0 %}
                                    <div class="small"><i class="fas fa-microchip mr-1"></i>{{ item.units_to_create }} unidades nuevas</div>
                                {% endif %}
                                {% if item.batches_to_create|length > 0 %}
                                    <div class="small text-truncate" style="max-width: 200px;" title="{{ item.batches_to_create|join(', ') }}">
                                        <i class="fas fa-layer-group mr-1"></i>Lotes: {{ item.batches_to_create|join(', ') }}
                                    </div>
                                {% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {% if preview.errors|length > 0 %}
            <div class="alert alert-danger">
                <h6><i class="fas fa-exclamation-triangle mr-2"></i>Errores Detectados:</h6>
                <ul>
                    {% for error in preview.errors %}
                    <li>{{ error }}</li>
                    {% endfor %}
                </ul>
            </div>
            {% endif %}

            <div class="mt-4 d-flex justify-content-between">
                <a href="{{ path('app_material_index') }}" class="btn btn-secondary">
                    <i class="fas fa-times mr-2"></i>Cancelar
                </a>
                <form method="post" action="{{ path('app_material_import_process') }}">
                    <input type="hidden" name="temp_filename" value="{{ temp_filename }}">
                    <button type="submit" class="btn btn-success btn-lg px-5">
                        <i class="fas fa-check mr-2"></i>Confirmar Importación
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
