{% extends 'layout/app.html.twig' %}

{% block title %}Registrar Movimiento de Material{% endblock %}

{% block page_title %}Trazabilidad: {{ material.name }}{% endblock %}

{% block content %}
<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h6 class="fw-bold mb-0">Registrar Entrada, Traspaso o Consumo</h6>
                </div>
                <div class="card-body">
                    <div class="alert alert-info py-2 small mb-4">
                        <i data-lucide="info" class="w-4 h-4 me-2"></i>
                        <strong>Entrada:</strong> Origen vacío. <strong>Traspaso:</strong> Origen y Destino informados. <strong>Consumo/Baja:</strong> Destino vacío.
                    </div>

                    {% if not form.vars.valid %}
                        <div class="alert alert-danger py-2 small mb-4">
                            <h6 class="font-bold mb-1"><i data-lucide="alert-circle" class="w-4 h-4 inline mr-1"></i> Errores en el formulario:</h6>
                            <ul class="mb-0 ps-3">
                                {{ form_errors(form) }}
                                {% for child in form.children %}
                                    {% for error in child.vars.errors %}
                                        <li><strong>{{ child.vars.label }}:</strong> {{ error.message }}</li>
                                    {% endfor %}
                                {% endfor %}
                            </ul>
                        </div>
                    {% endif %}

                    {{ form_start(form, {'attr': {'id': 'transfer-form', 'class': 'needs-validation'}}) }}
                        <div class="row mb-4">
                            <div class="col-md-6">
                                {{ form_label(form.origin, null, {'label_attr': {'class': 'form-label font-bold text-gray-700'}}) }}
                                {{ form_widget(form.origin, {'attr': {'class': 'form-select select2-origin'}}) }}
                                <div class="form-text small text-muted mt-1">Dejar vacío si es una entrada de proveedor.</div>
                                <div id="origin-stock-info" class="mt-2 small font-bold text-indigo-600" style="display:none;">
                                    <i data-lucide="info" class="w-3 h-3 inline"></i> Stock disponible: <span id="available-qty">0</span> uds.
                                </div>
                                <div class="mt-3 form-check form-switch">
                                    {{ form_widget(form.isGlobal) }}
                                    {{ form_label(form.isGlobal, null, {'label_attr': {'class': 'form-check-label text-xs font-bold text-indigo-600 uppercase'}}) }}
                                </div>
                            </div>
                            <div class="col-md-6">
                                {{ form_label(form.destination, null, {'label_attr': {'class': 'form-label font-bold text-gray-700'}}) }}
                                {{ form_widget(form.destination, {'attr': {'class': 'form-select'}}) }}
                                <div class="form-text small text-muted mt-1">Dejar vacío si es una baja, pérdida o consumo.</div>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                {{ form_label(form.quantity, null, {'label_attr': {'class': 'form-label font-bold text-gray-700'}}) }}
                                <div class="input-group">
                                    {{ form_widget(form.quantity, {'attr': {'class': 'form-control', 'min': 1}}) }}
                                    <span class="input-group-text">uds.</span>
                                </div>
                                <div id="qty-error" class="text-danger small mt-1" style="display:none;">La cantidad no puede superar el stock disponible.</div>
                            </div>
                            {% if form.materialUnit is defined %}
                            <div class="col-md-6">
                                {{ form_label(form.materialUnit, null, {'label_attr': {'class': 'form-label font-bold text-gray-700'}}) }}
                                {{ form_widget(form.materialUnit, {'attr': {'class': 'form-select'}}) }}
                            </div>
                            {% endif %}
                            {% if form.batch is defined %}
                            <div class="col-md-6">
                                {{ form_label(form.batch, null, {'label_attr': {'class': 'form-label font-bold text-gray-700'}}) }}
                                {{ form_widget(form.batch, {'attr': {'class': 'form-select'}}) }}
                                <div class="form-text small text-muted mt-1">Obligatorio si se selecciona un lote específico.</div>
                            </div>
                            {% endif %}
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.responsible, null, {'label_attr': {'class': 'form-label font-bold text-gray-700'}}) }}
                            {{ form_widget(form.responsible, {'attr': {'class': 'form-select'}}) }}
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.reason, null, {'label_attr': {'class': 'form-label font-bold text-gray-700'}}) }}
                            {{ form_widget(form.reason, {'attr': {'placeholder': 'Ej: Reposición de ambulancia, Caducidad...'}}) }}
                        </div>

                        <div class="d-grid gap-3 pt-3">
                            <button type="submit" id="submit-btn" class="btn btn-indigo btn-lg py-3 font-bold uppercase tracking-wider shadow-sm">
                                <i data-lucide="check-circle" class="w-5 h-5 inline mr-2"></i> Procesar Movimiento
                            </button>
                            <a href="{{ path('app_material_show', {id: material.id}) }}" class="btn btn-outline-secondary py-2">
                                <i data-lucide="x" class="w-4 h-4 inline mr-1"></i> Cancelar
                            </a>
                        </div>
                    {{ form_end(form) }}

                    <script>
                        document.addEventListener('DOMContentLoaded', () => {
                            const originSelect = document.querySelector('.select2-origin');
                            const destinationSelect = document.querySelector('select[name*="[destination]"]');
                            const qtyInput = document.querySelector('input[name*="[quantity]"]');
                            const submitBtn = document.getElementById('submit-btn');
                            const stockInfo = document.getElementById('origin-stock-info');
                            const availableSpan = document.getElementById('available-qty');
                            const qtyError = document.getElementById('qty-error');

                            const isGlobalCheckbox = document.querySelector('input[name*="[isGlobal]"]');
                            const totalStock = {{ material.stock|default(0) }};

                            function updateValidation() {
                                const isGlobal = isGlobalCheckbox && isGlobalCheckbox.checked;
                                const qty = parseInt(qtyInput.value) || 0;
                                
                                // Ocultar el origen del combo de destino
                                if (destinationSelect && originSelect) {
                                    const originVal = originSelect.value;
                                    Array.from(destinationSelect.options).forEach(opt => {
                                        if (opt.value && opt.value === originVal) {
                                            opt.disabled = true;
                                            opt.style.display = 'none';
                                            // Resetear destino si estaba seleccionado y ahora es inválido
                                            if (destinationSelect.value === opt.value) {
                                                destinationSelect.value = '';
                                            }
                                        } else {
                                            opt.disabled = false;
                                            opt.style.display = '';
                                        }
                                    });
                                }

                                if (isGlobal) {
                                    stockInfo.style.display = 'block';
                                    availableSpan.textContent = totalStock;
                                    stockInfo.classList.replace('text-indigo-600', 'text-amber-600');
                                    
                                    if (qty > totalStock) {
                                        qtyInput.classList.add('is-invalid');
                                        qtyError.textContent = 'La cantidad no puede superar el STOCK TOTAL (' + totalStock + ').';
                                        qtyError.style.display = 'block';
                                        submitBtn.disabled = true;
                                    } else {
                                        qtyInput.classList.remove('is-invalid');
                                        qtyError.style.display = 'none';
                                        submitBtn.disabled = false;
                                    }
                                } else {
                                    stockInfo.classList.replace('text-amber-600', 'text-indigo-600');
                                    const option = originSelect.options[originSelect.selectedIndex];
                                    if (option) {
                                        const label = option.text;
                                        const match = label.match(/\[Disp: (\d+)\]/);
                                        
                                        if (match) {
                                            const available = parseInt(match[1]);
                                            stockInfo.style.display = 'block';
                                            availableSpan.textContent = available;
                                            
                                            if (qty > available) {
                                                qtyInput.classList.add('is-invalid');
                                                qtyError.textContent = 'La cantidad no puede superar el stock de esta ubicación.';
                                                qtyError.style.display = 'block';
                                                submitBtn.disabled = true;
                                            } else {
                                                qtyInput.classList.remove('is-invalid');
                                                qtyError.style.display = 'none';
                                                submitBtn.disabled = false;
                                            }
                                        } else {
                                            stockInfo.style.display = 'none';
                                            qtyInput.classList.remove('is-invalid');
                                            qtyError.style.display = 'none';
                                            submitBtn.disabled = false;
                                        }
                                    }
                                }
                            }

                            if (originSelect) originSelect.addEventListener('change', updateValidation);
                            if (qtyInput) qtyInput.addEventListener('input', updateValidation);
                            if (isGlobalCheckbox) isGlobalCheckbox.addEventListener('change', updateValidation);
                            
                            // Run once on load
                            updateValidation();
                        });
                    </script>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
