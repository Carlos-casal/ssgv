{% extends 'layout/app.html.twig' %}

{% block title %}Detalle de Material{% endblock %}

{% block page_title %}{% endblock %}

{% block content %}
<div class="px-6 py-2">
    {# Custom Header #}
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 leading-tight">{{ material.name }}</h1>
            <div class="flex flex-wrap gap-2 mt-2">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 border border-blue-200">
                    {{ material.category }}
                </span>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium {{ material.nature == 'CONSUMIBLE' ? 'bg-indigo-100 text-indigo-800 border border-indigo-200' : 'bg-slate-100 text-slate-800 border border-slate-200' }}">
                    {{ material.nature }}
                </span>
            </div>
        </div>
        <div class="flex flex-wrap gap-3">
            <a href="{{ path('app_material_index') }}" class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 transition-colors">
                <i data-lucide="arrow-left" class="w-4 h-4 mr-2"></i> Volver al Listado
            </a>
            <a href="{{ path('app_material_transfer', {id: material.id}) }}" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-bold rounded-lg shadow-sm text-white bg-blue-600 hover:bg-blue-700 transition-all">
                <i data-lucide="arrow-left-right" class="w-4 h-4 mr-2 text-white"></i> 
                <span class="text-white">Registrar Movimiento</span>
            </a>
        </div>
    </div>

    {# 4 Equal-Width Cards Ribbon #}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-2 mb-6">
        
        {# Card 1: Description & Barcode #}
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 flex flex-col justify-center min-h-[90px]">
            <div class="flex items-center mb-1">
                <div class="flex-shrink-0 p-1.5 rounded-lg bg-gray-50 text-gray-500 mr-2">
                    <i data-lucide="tag" class="w-4 h-4"></i>
                </div>
                <p class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider mb-0">Identificación</p>
            </div>
            <div class="ml-8">
                <h4 class="text-sm font-bold text-gray-900 m-0 leading-tight truncate" title="{{ material.description|default(material.name) }}">{{ material.description|default('Sin descripción') }}</h4>
                <div class="text-xs font-mono text-gray-500 mt-0.5 truncate" title="{{ material.barcode|default('') }}">{{ material.barcode|default('Sin código') }}</div>
            </div>
        </div>

        {# Card 2: Stock or Status #}
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 flex flex-col justify-center min-h-[90px]">
            <div class="flex items-center mb-1">
                <div class="flex-shrink-0 p-1.5 rounded-lg {{ material.nature == 'CONSUMIBLE' ? (material.isLowStock ? 'bg-red-50 text-red-600' : 'bg-green-50 text-green-600') : 'bg-blue-50 text-blue-600' }} mr-2">
                    <i data-lucide="{{ material.nature == 'CONSUMIBLE' ? 'boxes' : 'activity' }}" class="w-4 h-4"></i>
                </div>
                <p class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider mb-0">{{ material.nature == 'CONSUMIBLE' ? 'Stock Actual' : 'Estado Operativo' }}</p>
            </div>
            <div class="ml-8">
                <div class="flex items-baseline">
                    {% if material.nature == 'CONSUMIBLE' %}
                        <h4 class="text-lg font-bold text-gray-900 m-0 leading-tight">{{ material.getTotalPackages()|round(2) }}</h4>
                        <span class="ml-1 text-[10px] text-gray-500">envases</span>
                    {% else %}
                        <h4 class="text-sm font-bold m-0 leading-tight {{ material.operationalStatus == 'OPERATIVO' ? 'text-green-600' : 'text-amber-600' }}">{{ material.operationalStatus }}</h4>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Card 3: Total Valuation #}
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 flex flex-col justify-center min-h-[90px]">
            <div class="flex items-center mb-1">
                <div class="flex-shrink-0 p-1.5 rounded-lg bg-indigo-50 text-indigo-600 mr-2">
                    <i data-lucide="banknote" class="w-4 h-4"></i>
                </div>
                <p class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider mb-0">Valoración Total</p>
            </div>
            <div class="ml-8">
                <h4 class="text-lg font-bold text-gray-900 m-0 leading-tight">{{ material.getTotalValuation()|number_format(2, ',', '.') }}€</h4>
            </div>
        </div>

        {# Card 4: Status Alert / Extra info #}
        {% if material.nature == 'CONSUMIBLE' %}
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 flex flex-col justify-center min-h-[90px] {{ material.isLowStock ? 'border-red-200 bg-red-50/30' : '' }}">
            <div class="flex items-center mb-1">
                <div class="flex-shrink-0 p-1.5 rounded-lg {{ material.isLowStock ? 'bg-red-100 text-red-600 animate-pulse' : 'bg-slate-50 text-slate-400' }} mr-2">
                    <i data-lucide="{{ material.isLowStock ? 'alert-triangle' : 'info' }}" class="w-4 h-4"></i>
                </div>
                <p class="text-[10px] font-semibold {{ material.isLowStock ? 'text-red-600' : 'text-gray-500' }} uppercase tracking-wider mb-0">
                    {{ material.isLowStock ? 'Alerta' : 'Stock Total' }}
                </p>
            </div>
            <div class="ml-8">
                {% if material.isLowStock %}
                    <h4 class="text-sm font-semibold text-red-700 m-0 leading-tight">Reposición</h4>
                {% else %}
                    <h4 class="text-sm font-semibold text-gray-900 m-0 leading-tight">{{ material.stock }} <span class="text-[9px] text-gray-400 font-normal uppercase">unidades</span></h4>
                {% endif %}
            </div>
        </div>
        {% else %}
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 flex flex-col justify-center min-h-[90px]">
            <div class="flex items-center mb-1">
                <div class="flex-shrink-0 p-1.5 rounded-lg bg-amber-50 text-amber-600 mr-2">
                    <i data-lucide="shield-check" class="w-4 h-4"></i>
                </div>
                <p class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider mb-0">Garantía</p>
            </div>
            <div class="ml-8">
                <h4 class="text-sm font-semibold m-0 leading-tight {{ material.warrantyDate and material.warrantyDate < date() ? 'text-red-600' : 'text-gray-900' }}">
                    {{ material.warrantyDate ? material.warrantyDate|date('d/m/Y') : 'No registrada' }}
                </h4>
            </div>
        </div>
        {% endif %}
    </div>

    {# Detailed Tech Info (Only if it exists and needs space, else just tables below) #}
    {% if material.nature == 'EQUIPO_TECNICO' or material.category == 'Comunicaciones' or material.imagePath %}
    <div class="flex flex-col lg:flex-row gap-6 mb-6">
        {% if material.imagePath %}
        <div class="w-full lg:w-1/4 bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            <div class="aspect-square relative flex items-center justify-center p-4 bg-gray-50/50">
                <img src="{{ asset('uploads/material_images/' ~ material.imagePath) }}" alt="{{ material.name }}" class="max-h-full max-w-full object-contain">
            </div>
        </div>
        {% endif %}

        {% if material.nature == 'EQUIPO_TECNICO' or material.category == 'Comunicaciones' %}
        <div class="flex-1 bg-white rounded-xl shadow-sm border border-gray-200 p-5">
            <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-4 flex items-center">
                <i data-lucide="settings" class="w-3.5 h-3.5 mr-1.5"></i> Información Técnica Completa
            </h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4">
                <div class="flex flex-col text-sm">
                    <span class="text-gray-500 text-xs">S/N:</span>
                    <span class="font-medium text-gray-900 break-all">{{ material.serialNumber|default('N/A') }}</span>
                </div>
                {% if material.networkId %}
                <div class="flex flex-col text-sm">
                    <span class="text-gray-500 text-xs">ID Red:</span>
                    <span class="font-bold text-blue-700">{{ material.networkId }}</span>
                </div>
                {% endif %}
                {% if material.brandModel %}
                <div class="flex flex-col text-sm">
                    <span class="text-gray-500 text-xs">Modelo:</span>
                    <span class="font-medium text-gray-900">{{ material.brandModel }}</span>
                </div>
                {% endif %}
                {% if material.assignedVehicle %}
                <div class="flex flex-col text-sm">
                    <span class="text-gray-500 text-xs">Vehículo Asignado:</span>
                    <span class="font-bold text-indigo-900">{{ material.assignedVehicle.alias }}</span>
                </div>
                {% endif %}
            </div>
        </div>
        {% endif %}
    </div>
    {% endif %}

    {# Tables Section #}
    <div class="space-y-6">

            {# Traceability Table (Consumables only) #}
            {% if material.nature == 'CONSUMIBLE' and material.batches|length > 0 %}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
                    <h2 class="text-sm font-bold text-gray-900 flex items-center">
                        <i data-lucide="tags" class="w-4 h-4 mr-2 text-indigo-600"></i> Trazabilidad de Lotes y Costes
                    </h2>
                </div>
                <div class="w-full overflow-hidden">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th scope="col" class="px-4 py-3 text-left text-xxs font-bold text-gray-500 uppercase tracking-wider">Lote</th>
                                <th scope="col" class="px-4 py-3 text-left text-xxs font-bold text-gray-500 uppercase tracking-wider">Caducidad</th>
                                <th scope="col" class="px-4 py-3 text-left text-xxs font-bold text-gray-500 uppercase tracking-wider">Proveedor</th>
                                <th scope="col" class="px-4 py-3 text-center text-xxs font-bold text-gray-500 uppercase tracking-wider">Uds/Env</th>
                                <th scope="col" class="px-4 py-3 text-center text-xxs font-bold text-gray-500 uppercase tracking-wider">Envases</th>
                                <th scope="col" class="px-4 py-3 text-center text-xxs font-bold text-gray-500 uppercase tracking-wider">Stock</th>
                                <th scope="col" class="px-4 py-3 text-right text-xxs font-bold text-gray-500 uppercase tracking-wider">P. Compra</th>
                                <th scope="col" class="px-4 py-3 text-right text-xxs font-bold text-gray-500 uppercase tracking-wider">Val/Ud</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-100">
                            {% for batch in material.batches %}
                                {% set batchStock = 0 %}
                                {% for s in batch.stocks %}{% set batchStock = batchStock + s.quantity %}{% endfor %}
                                <tr class="{{ batchStock <= 0 ? 'opacity-40 bg-gray-50/50' : 'hover:bg-gray-50/80 transition-colors' }}">
                                    <td class="px-4 py-3 text-sm font-bold text-indigo-600 break-words">
                                        {{ batch.batchNumber }}
                                    </td>
                                    <td class="px-4 py-3 whitespace-nowrap">
                                        {% set isExpired = batch.expirationDate and batch.expirationDate < date() %}
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium {{ isExpired ? 'bg-red-100 text-red-800' : 'bg-green-100 text-green-800' }}">
                                            <i data-lucide="calendar" class="w-3 h-3 mr-1"></i>
                                            {{ batch.expirationDate ? batch.expirationDate|date('d/m/Y') : '-' }}
                                        </span>
                                    </td>
                                    <td class="px-5 py-3 whitespace-nowrap text-sm text-gray-600">
                                        {{ batch.supplier|default('-') }}
                                    </td>
                                    <td class="px-5 py-3 whitespace-nowrap text-center text-sm text-gray-600">
                                        {{ batch.unitsPerPackage }}
                                    </td>
                                    <td class="px-5 py-3 whitespace-nowrap text-center text-sm text-gray-600">
                                        {{ batch.numPackages }}
                                    </td>
                                    <td class="px-5 py-3 whitespace-nowrap text-center">
                                        <span class="text-sm font-bold {{ batchStock <= 0 ? 'text-gray-400' : 'text-gray-900' }}">
                                            {{ batchStock }}
                                        </span>
                                    </td>
                                    <td class="px-5 py-3 whitespace-nowrap text-right text-sm text-gray-600">
                                        {{ batch.totalPrice|number_format(2, ',', '.') }}€
                                        <div class="text-xxs text-gray-400">IVA {{ batch.iva }}%</div>
                                    </td>
                                    <td class="px-5 py-3 whitespace-nowrap text-right text-sm font-bold text-gray-900">
                                        {{ batch.getValuationPerUnit()|number_format(2, ',', '.') }}€
                                    </td>
                                </tr>
                            {% endfor %}

                            {# Check and display stock without batch #}
                            {% set noBatchStock = 0 %}
                            {% for s in material.stocks %}
                                {% if s.batch is null and s.quantity > 0 %}
                                    {% set noBatchStock = noBatchStock + s.quantity %}
                                {% endif %}
                            {% endfor %}
                            
                            {% if noBatchStock > 0 %}
                            <tr class="bg-orange-50/60 hover:bg-orange-50 transition-colors border-t border-orange-100">
                                <td class="px-4 py-3 text-sm font-bold text-orange-600">
                                    <div class="flex items-center">
                                        <i data-lucide="alert-triangle" class="w-4 h-4 mr-1"></i> Sin Lote (Huérfano)
                                    </div>
                                </td>
                                <td class="px-4 py-3 text-orange-500">-</td>
                                <td class="px-4 py-3 text-orange-500">-</td>
                                <td class="px-4 py-3 text-center text-orange-500">-</td>
                                <td class="px-4 py-3 text-center text-orange-500">-</td>
                                <td class="px-5 py-3 whitespace-nowrap text-center">
                                    <span class="text-sm font-bold text-orange-600">
                                        {{ noBatchStock }}
                                    </span>
                                </td>
                                <td class="px-4 py-3 text-right text-orange-500">-</td>
                                <td class="px-4 py-3 text-right text-orange-500">-</td>
                            </tr>
                            {% endif %}
                        </tbody>
                    </table>
                </div>
            </div>
            {% endif %}

            {# Individual Units Table (Technical Equipment only) #}
            {% if material.nature == 'EQUIPO_TECNICO' and material.units|length > 0 %}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                <div class="px-4 py-4 border-b border-gray-100 flex items-center justify-between">
                    <h2 class="text-sm font-bold text-gray-900 flex items-center">
                        <i data-lucide="package" class="w-4 h-4 mr-2 text-indigo-600"></i> Desglose por Unidades Individuales
                    </h2>
                </div>
                <div class="w-full overflow-hidden">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th scope="col" class="px-4 py-3 text-left text-xxs font-bold text-gray-500 uppercase tracking-wider">Alias / S/N</th>
                                <th scope="col" class="px-4 py-3 text-left text-xxs font-bold text-gray-500 uppercase tracking-wider">Modelo</th>
                                <th scope="col" class="px-4 py-3 text-left text-xxs font-bold text-gray-500 uppercase tracking-wider">F. Compra</th>
                                <th scope="col" class="px-4 py-3 text-left text-xxs font-bold text-gray-500 uppercase tracking-wider">Garantía</th>
                                <th scope="col" class="px-4 py-3 text-right text-xxs font-bold text-gray-500 uppercase tracking-wider">Valoración</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-100">
                            {% for unit in material.units %}
                                <tr class="hover:bg-gray-50/80 transition-colors">
                                    <td class="px-4 py-3 break-words">
                                        <div class="text-sm font-bold text-indigo-600">{{ unit.alias|default('S/A') }}</div>
                                        <div class="text-xxs text-gray-400 font-normal uppercase">S/N: {{ unit.serialNumber|default('N/S') }}</div>
                                    </td>
                                    <td class="px-4 py-3 text-sm text-gray-600 break-words">
                                        {{ unit.brandModel|default(material.brandModel)|default('-') }}
                                    </td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-600">
                                        {{ unit.purchaseDate ? unit.purchaseDate|date('d/m/Y') : '-' }}
                                    </td>
                                    <td class="px-4 py-3 whitespace-nowrap">
                                        {% set isExpired = unit.warrantyDate and unit.warrantyDate < date() %}
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium {{ isExpired ? 'bg-red-100 text-red-800' : 'bg-green-100 text-green-800' }}">
                                            <i data-lucide="shield" class="w-3 h-3 mr-1"></i>
                                            {{ unit.warrantyDate ? unit.warrantyDate|date('d/m/Y') : '-' }}
                                        </span>
                                    </td>
                                    <td class="px-4 py-3 whitespace-nowrap text-right text-sm font-bold text-gray-900">
                                        {{ unit.getValuation()|number_format(2, ',', '.') }}€
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
            {% endif %}

            {# History Table #}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                <div class="px-4 py-4 border-b border-gray-100 flex items-center justify-between">
                    <h2 class="text-sm font-bold text-gray-900 flex items-center">
                        <i data-lucide="history" class="w-4 h-4 mr-2 text-indigo-600"></i> Historial de Movimientos
                    </h2>
                </div>
                <div class="w-full overflow-hidden">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th scope="col" class="px-3 py-3 text-left text-xxs font-bold text-gray-500 uppercase tracking-wider">Tipo</th>
                                <th scope="col" class="px-3 py-3 text-left text-xxs font-bold text-gray-500 uppercase tracking-wider">Fecha</th>
                                <th scope="col" class="px-3 py-3 text-left text-xxs font-bold text-gray-500 uppercase tracking-wider">Usuario</th>
                                <th scope="col" class="px-3 py-3 text-left text-xxs font-bold text-gray-500 uppercase tracking-wider">{{ material.nature == 'EQUIPO_TECNICO' ? 'N/S' : 'Lote' }}</th>
                                <th scope="col" class="px-3 py-3 text-left text-xxs font-bold text-gray-500 uppercase tracking-wider">Origen → Destino</th>
                                <th scope="col" class="px-3 py-3 text-center text-xxs font-bold text-gray-500 uppercase tracking-wider">Cant</th>
                                <th scope="col" class="px-3 py-3 text-left text-xxs font-bold text-gray-500 uppercase tracking-wider">Motivo</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-100">
                            {% for movement in pagination %}
                            {% set isBaja = movement.quantity < 0 and movement.destination is null %}
                            {% set isEntrada = movement.quantity > 0 and movement.origin is null %}
                            {% set isTraspaso = movement.origin is not null and movement.destination is not null %}
                            <tr class="hover:bg-gray-50/80 transition-colors {{ isBaja ? 'bg-red-50/20' : (isEntrada ? 'bg-green-50/20' : '') }}">
                                <td class="px-3 py-2">
                                    {% if isBaja %}
                                        <span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-xs font-bold bg-red-100 text-red-700 border border-red-200">
                                            <i data-lucide="arrow-down-circle" class="w-3 h-3 mr-1"></i> BAJA
                                        </span>
                                    {% elseif isEntrada %}
                                        <span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-xs font-bold bg-green-100 text-green-700 border border-green-200">
                                            <i data-lucide="arrow-up-circle" class="w-3 h-3 mr-1"></i> ENTR.
                                        </span>
                                    {% elseif isTraspaso %}
                                        <span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-xs font-bold bg-blue-100 text-blue-700 border border-blue-200">
                                            <i data-lucide="arrow-left-right" class="w-3 h-3 mr-1"></i> TRASP.
                                        </span>
                                    {% else %}
                                        <span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-xs font-bold bg-gray-100 text-gray-600 border border-gray-200">
                                            <i data-lucide="refresh-cw" class="w-3 h-3 mr-1"></i> AJUS.
                                        </span>
                                    {% endif %}
                                </td>
                                <td class="px-3 py-2 whitespace-nowrap text-xs text-gray-600">
                                    {{ movement.createdAt|date('d/m/Y') }}
                                </td>
                                <td class="px-3 py-2 text-xs text-gray-900 break-words">
                                    {{ movement.user ? (movement.user.name ?: movement.user.email) : 'Sistema' }}
                                </td>
                                <td class="px-3 py-2 break-words">
                                    {% if material.nature == 'EQUIPO_TECNICO' %}
                                        {% if movement.materialUnit %}
                                            <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800 border border-gray-200">
                                                {{ movement.materialUnit.serialNumber ?: movement.materialUnit.alias }}
                                            </span>
                                        {% else %}
                                            <span class="text-gray-400 text-xs italic">-</span>
                                        {% endif %}
                                    {% else %}
                                        {% if movement.batch %}
                                        <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-indigo-50 text-indigo-700 border border-indigo-100">
                                            {{ movement.batch.batchNumber }}
                                        </span>
                                    {% else %}
                                        <span class="text-gray-400 text-xs italic">-</span>
                                    {% endif %}
                                    {% endif %}
                                </td>
                                <td class="px-3 py-2 text-xs text-gray-500 break-words leading-tight">
                                    <span class="font-medium text-gray-700 block sm:inline">{{ movement.origin ? movement.origin.name : '(Proveedor)' }}</span>
                                    <span class="mx-1 text-gray-300 hidden sm:inline">→</span>
                                    <span class="font-medium text-gray-700 block sm:inline">{{ movement.destination ? movement.destination.name : '(Baja)' }}</span>
                                </td>
                                <td class="px-3 py-2 whitespace-nowrap text-center">
                                    <span class="text-sm font-bold {{ movement.quantity > 0 ? 'text-green-600' : 'text-red-600' }}">
                                        {{ movement.quantity > 0 ? '+' : '' }}{{ movement.quantity }}
                                    </span>
                                </td>
                                <td class="px-3 py-2 text-xs text-gray-600 max-w-[150px] break-words leading-tight">
                                    {{ movement.reason }}
                                </td>
                            </tr>
                            {% else %}
                            <tr>
                                <td colspan="7" class="px-5 py-10 text-center text-sm text-gray-500 italic">
                                    No hay movimientos registrados.
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% if pagination.getTotalItemCount > 5 %}
                <div class="px-5 py-3 border-t border-gray-100 bg-gray-50/50 flex justify-center">
                    {{ knp_pagination_render(pagination) }}
                </div>
                {% endif %}
            </div>
