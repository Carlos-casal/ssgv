{% extends 'layout/app.html.twig' %}

{% block title %}
    Editar {{ material.category ?: 'Material' }}
{% endblock %}

{% block page_title %}
    <div class="d-flex justify-content-between align-items-center w-100">
        <span>
            Edición de {{ material.category ?: 'Material' }}
        </span>
        <div>
            <button type="submit" form="material-form" class="btn btn-primary shadow-sm px-4" aria-label="Guardar cambios" title="Guardar">
                <i class="fas fa-save mr-2"></i> Guardar Cambios
            </button>
            <a href="{{ path('app_material_show', {id: material.id}) }}" class="btn btn-outline-secondary ml-2" aria-label="Cancelar y volver" title="Cancelar">Cancelar</a>
        </div>
    </div>
{% endblock %}

{% block content %}
<div class="container-fluid py-4" data-controller="material-dynamic-form" data-material-category="{{ material.category }}">
    {{ form_start(form, {'attr': {'id': 'material-form', 'class': 'material-form', 'novalidate': 'novalidate'}}) }}

    <div class="row">
        {# Columna Izquierda (8) #}
        <div class="col-lg-8">
            {% if material.category == 'Comunicaciones' %}
                {# COMUNICACIONES LAYOUT #}
                <div class="card shadow-sm mb-4 border-0">
                    <div class="card-header bg-white py-3">
                        <h6 class="m-0 font-weight-bold text-primary">
                            <i class="fas fa-radio mr-2"></i> PANEL A: DATOS DEL EQUIPO (FÍSICO)
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-12">
                                {{ form_row(form.name, {'label': 'NOMBRE COMERCIAL*'}) }}
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-md-6">{{ form_row(form.nature, {'label': 'NATURALEZA*'}) }}</div>
                            <div class="col-md-6">{{ form_row(form.deviceType, {'label': 'TIPO DE EQUIPO'}) }}</div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-md-6">{{ form_row(form.brandModel, {'label': 'MARCA Y MODELO'}) }}</div>
                            <div class="col-md-6 d-none">{{ form_row(form.category) }}</div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm mb-4 border-0 border-left-info">
                    <div class="card-header bg-white py-3">
                        <h6 class="m-0 font-weight-bold text-info">
                            <i class="fas fa-network-wired mr-2"></i> PANEL B: DATOS DE RED (LÓGICO)
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-12">
                                {{ form_row(form.networkId, {'label': 'ID DE RED (ISSI / IMEI / MMSI / TEI)'}) }}
                            </div>
                        </div>
                    </div>
                </div>

                <div id="units-container" data-material-dynamic-form-target="unitsContainer" aria-live="polite"></div>

                <div class="card shadow-sm mb-4 border-0">
                    <div class="card-header bg-white py-3">
                        <h6 class="m-0 font-weight-bold text-secondary">
                            <i class="fas fa-tools mr-2"></i> PANEL C: MANTENIMIENTO Y ACCESORIOS
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">{{ form_row(form.purchaseDate, {'label': 'FECHA DE COMPRA'}) }}</div>
                            <div class="col-md-6">{{ form_row(form.warrantyEndDate, {'label': 'FIN DE GARANTÍA'}) }}</div>
                        </div>
                        <hr class="my-3">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-check custom-checkbox">
                                    {{ form_widget(form.hasCharger) }}
                                    {{ form_label(form.hasCharger, '¿INCLUYE CARGADOR?') }}
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check custom-checkbox">
                                    {{ form_widget(form.hasClip) }}
                                    {{ form_label(form.hasClip, '¿INCLUYE PINZA?') }}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            {% elseif material.category in ['Logística', 'Mar'] %}
                <div class="card shadow-sm mb-4 border-0">
                    <div class="card-header bg-white py-3">
                        <h6 class="m-0 font-weight-bold text-primary">
                            <i class="fas fa-boxes mr-2"></i> IDENTIDAD DEL MATERIAL
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-12">
                                {{ form_row(form.name, {'label': 'NOMBRE*'}) }}
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-md-6">{{ form_row(form.brandModel, {'label': 'MARCA / MODELO'}) }}</div>
                            <div class="col-md-6">{{ form_row(form.nature, {'label': 'NATURALEZA*'}) }}</div>
                        </div>
                    </div>
                </div>

            {% elseif material.category == 'Uniformidad' %}
                <div class="card shadow-sm mb-4 border-0">
                    <div class="card-header bg-white py-3">
                        <h6 class="m-0 font-weight-bold text-primary">
                            <i class="fas fa-tshirt mr-2"></i> DATOS DE UNIFORMIDAD
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-12">
                                {{ form_row(form.name, {'label': 'NOMBRE DE LA PRENDA*'}) }}
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-md-6">
                                {{ form_row(form.sizingType, {
                                    'label': 'SELECTOR DE TALLAJE',
                                    'attr': {
                                        'data-action': 'change->material-dynamic-form#updateSizingGrid',
                                        'data-material-dynamic-form-target': 'sizingType'
                                    }
                                }) }}
                            </div>
                            <div class="col-md-6">
                                {{ form_row(form.nature) }}
                            </div>
                        </div>
                    </div>
                </div>
                <div id="sizing-grid-container" data-material-dynamic-form-target="sizingGrid" aria-live="polite"></div>

            {% else %}
                <div class="card shadow-sm mb-4 border-0">
                    <div class="card-header bg-white py-3">
                        <h6 class="m-0 font-weight-bold text-primary">
                            <i class="fas fa-id-card mr-2"></i> IDENTIDAD DEL MATERIAL
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-12">
                                {{ form_row(form.name, {'label': 'NOMBRE COMERCIAL*'}) }}
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-md-6">{{ form_row(form.nature, {'label': 'NATURALEZA*'}) }}</div>
                            <div class="col-md-6">{{ form_row(form.subFamily, {'label': 'SUBFAMILIA'}) }}</div>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>

        {# Columna Derecha (4) #}
        <div class="col-lg-4">
            <div class="card shadow-sm mb-4 border-0" style="border-top: 4px solid #1cc88a !important;">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 font-weight-bold text-success">
                        <i class="fas fa-calculator mr-2"></i> BLOQUE D: STOCK Y COSTES
                    </h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        {{ form_row(form.stock, {
                            'label': 'STOCK TOTAL*',
                            'attr': {
                                'class': 'form-control font-weight-bold',
                                'data-material-dynamic-form-target': 'stockInput',
                                'data-action': 'input->material-dynamic-form#handleStockChange'
                            }
                        }) }}
                    </div>
                    <div class="mb-3">
                        {{ form_row(form.safetyStock, {'label': 'STOCK MÍNIMO*'}) }}
                    </div>
                    <hr>
                    <div class="mb-3">
                        {% set computed_total = material.stock * material.unitPrice %}
                        {{ form_label(form.totalPrice, 'COSTE TOTAL DE LA COMPRA') }}
                        <div class="input-group">
                            {{ form_widget(form.totalPrice, {
                                'value': computed_total,
                                'attr': {
                                    'class': 'form-control',
                                    'data-material-dynamic-form-target': 'totalPrice',
                                    'data-action': 'input->material-dynamic-form#calculateUnitPrice'
                                }
                            }) }}
                            <div class="input-group-append">
                                <span class="input-group-text">€</span>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-6">
                            {{ form_row(form.unitPrice, {
                                'label': 'PRECIO/Ud',
                                'attr': {'readonly': true, 'data-material-dynamic-form-target': 'unitPrice'}
                            }) }}
                        </div>
                        <div class="col-6">
                            {{ form_row(form.iva, {
                                'label': 'IVA (%)*',
                                'attr': {'data-action': 'change->material-dynamic-form#handleIvaChange'}
                            }) }}
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4 border-0">
                <div class="card-body text-center p-3">
                    {% if material.imagePath %}
                        <div class="mb-3">
                            <img src="{{ asset('uploads/material_images/' ~ material.imagePath) }}" alt="Preview" class="img-fluid rounded mb-2" style="max-height: 150px;">
                        </div>
                    {% else %}
                        <div class="mb-3">
                            <i class="fas fa-camera fa-3x text-gray-300"></i>
                        </div>
                    {% endif %}
                    {{ form_row(form.imageFile, {'label': 'CAMBIAR FOTO'}) }}
                </div>
            </div>
        </div>
    </div>
    {{ form_end(form) }}
</div>

<style>
    .material-form label {
        font-weight: 700;
        color: #4e73df;
        font-size: 0.75rem;
        text-transform: uppercase;
        margin-bottom: 0.25rem;
    }
</style>
{% endblock %}
