{% extends 'layout/app.html.twig' %}

{% block title %}Informe de Inventario Avanzado{% endblock %}

{% block page_title %}Informes y Valoración de Inventario{% endblock %}

{% block content %}
<div class="container-fluid py-4">
    <div class="row">
        <!-- VALORACIÓN TOTAL -->
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Coste Total Actual (Seguro/Robo)</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ totalValue|number_format(2, ',', '.') }}€</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-shield-alt fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- CONTROL ANUAL (Simulado) -->
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Gasto Anual (2026)</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ (totalValue * 0.8)|number_format(2, ',', '.') }}€</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-calendar-check fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Material Consumido (Anual)</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ (totalValue * 0.2)|number_format(2, ',', '.') }}€</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-chart-line fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- TABLA DE VALORACIÓN DETALLADA -->
    <div class="card shadow mb-4">
        <div class="card-header py-3 bg-white border-0">
            <h6 class="m-0 font-weight-bold text-primary text-uppercase">Desglose de Valoración por Ítem</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover" id="reportTable" width="100%" cellspacing="0">
                    <thead class="bg-light">
                        <tr class="text-xs text-primary font-weight-bold">
                            <th>MATERIAL</th>
                            <th>NATURALEZA</th>
                            <th>STOCK</th>
                            <th>ÚLTIMO PRECIO</th>
                            <th>VALOR TOTAL</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for material in materials %}
                            <tr>
                                <td class="font-weight-bold text-gray-800">{{ material.name }}</td>
                                <td>
                                    <span class="badge {{ material.nature == 'CONSUMIBLE' ? 'bg-blue-100 text-blue-700' : 'bg-slate-100 text-slate-700' }} text-xxs px-2 py-1 uppercase">
                                        {{ material.nature }}
                                    </span>
                                </td>
                                <td>{{ material.stock }}</td>
                                <td>{{ (material.totalPrice / (material.stock ?: 1))|number_format(2, ',', '.') }}€</td>
                                <td class="font-weight-bold">{{ material.getTotalValuation()|number_format(2, ',', '.') }}€</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
