{% extends 'layout/app.html.twig' %}

{% block title %}
    Alta de {{ material.category ?: 'Material' }}
{% endblock %}

{% block page_title %}
    <div class="d-flex justify-content-between align-items-center w-100">
        <span>
            Alta de {{ material.category ?: 'Nuevo Material' }}
        </span>
        <div class="d-flex align-items-center">
            <div id="header-add-btn-container" class="mr-2" data-material-dynamic-form-target="headerAddBtnContainer">
                {# Dinámicamente inyectado o visible vía Stimulus #}
                <button type="button" class="btn btn-danger shadow-sm px-4" data-action="click->material-dynamic-form#handleAddButton">
                    <i class="fas fa-plus mr-1"></i> Añadir
                </button>
            </div>
            <button type="submit" form="material-form" class="btn btn-primary shadow-sm px-4" aria-label="Guardar nuevo material" title="Guardar">
                <i class="fas fa-save mr-2"></i> Guardar
            </button>
            <a href="{{ path('app_material_index') }}" class="btn btn-outline-secondary ml-2" aria-label="Cancelar y volver al listado" title="Cancelar">Cancelar</a>
        </div>
    </div>
{% endblock %}

{% block content %}
<div class="container-fluid pt-0 pb-4"
     data-controller="material-dynamic-form" 
     data-material-category="{{ material.category }}" 
     data-material-action="new" 
     data-serial-check-url="{{ path('app_material_check_serial_number') }}"
     data-initial-units="{{ units_data|default([])|json_encode }}"
     data-initial-batches="{{ batches_data|default([])|json_encode }}">
    {{ form_start(form, {'attr': {'id': 'material-form', 'class': 'material-form', 'novalidate': 'novalidate'}}) }}
    
    <div class="row mb-3">
        <div class="col-12 text-danger">
            {{ form_errors(form) }}
        </div>
    </div>

    <div class="row">
        {# Columna Izquierda (8) #}
        <div class="col-lg-8">
            {% if material.category == 'Comunicaciones' %}
                {# COMUNICACIONES LAYOUT #}
                {# Panel A (Físico) #}
                <div class="card shadow-sm mb-4 border-0">
                    <div class="card-header bg-white py-3">
                        <h6 class="m-0 font-weight-bold text-primary">
                            <i class="fas fa-radio mr-2"></i> PANEL A: DATOS DEL EQUIPO (FÍSICO)
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-12">
                                {{ form_row(form.name, {'label': 'NOMBRE COMERCIAL*'}) }}
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-md-6">{{ form_row(form.nature, {'label': 'NATURALEZA*'}) }}</div>
                            <div class="col-md-6">{{ form_row(form.deviceType, {'label': 'TIPO DE EQUIPO'}) }}</div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-md-6">{{ form_row(form.brandModel, {'label': 'MARCA Y MODELO'}) }}</div>
                            <div class="col-md-6 d-none">{{ form_row(form.category) }}</div>
                        </div>
                    </div>
                </div>

                {# Panel B (Lógico) #}
                <div class="card shadow-sm mb-4 border-0 border-left-info">
                    <div class="card-header bg-white py-3">
                        <h6 class="m-0 font-weight-bold text-info">
                            <i class="fas fa-network-wired mr-2"></i> PANEL B: DATOS DE RED (LÓGICO)
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-12">
                                {{ form_row(form.networkId, {'label': 'ID DE RED (ISSI / IMEI / MMSI / TEI)'}) }}
                            </div>
                        </div>
                    </div>
                </div>

                {# Dinámica de Unidades (Managed by Stimulus) #}
                <div id="units-container" data-material-dynamic-form-target="unitsContainer" aria-live="polite"></div>

                {# Panel C (Mantenimiento) #}
                <div class="card shadow-sm mb-4 border-0">
                    <div class="card-header bg-white py-3">
                        <h6 class="m-0 font-weight-bold text-secondary">
                            <i class="fas fa-tools mr-2"></i> PANEL C: MANTENIMIENTO Y ACCESORIOS
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">{{ form_row(form.purchaseDate, {'label': 'FECHA DE COMPRA'}) }}</div>
                            <div class="col-md-6">{{ form_row(form.warrantyDate, {'label': 'GARANTÍA'}) }}</div>
                        </div>
                        <hr class="my-3">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-check custom-checkbox">
                                    {{ form_widget(form.hasCharger) }}
                                    {{ form_label(form.hasCharger, '¿INCLUYE CARGADOR?') }}
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check custom-checkbox">
                                    {{ form_widget(form.hasClip) }}
                                    {{ form_label(form.hasClip, '¿INCLUYE PINZA?') }}
                                </div>
                            </div>
                        </div>
                        <div class="d-none">
                            {{ form_row(form.hasMicrophone) }}
                        </div>
                    </div>
                </div>

            {% elseif material.category in ['Logística', 'Mar', 'Vehículos'] %}
                {# LOGÍSTICA / MAR LAYOUT (Simplified) #}
                <div class="card shadow-sm mb-4 border-0">
                    <div class="card-header bg-white py-3">
                        <h6 class="m-0 font-weight-bold text-primary">
                            <i class="fas fa-boxes mr-2"></i> IDENTIDAD DEL MATERIAL
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-12">
                                {{ form_row(form.name, {'label': 'NOMBRE*'}) }}
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-md-6">{{ form_row(form.brandModel, {'label': 'MARCA / MODELO'}) }}</div>
                            <div class="col-md-6">{{ form_row(form.nature, {'label': 'NATURALEZA*'}) }}</div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-md-6">
                                <label class="form-label">Subfamilia</label>
                                <div class="input-group">
                                    {{ form_widget(form.subFamily, {'attr': {'class': 'form-input', 'data-material-dynamic-form-target': 'subFamilySelect'}}) }}
                                    <button class="btn btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#addSubFamilyModal">
                                        <i class="fas fa-plus"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="d-none">
                            {{ form_row(form.category) }}
                        </div>
                    </div>
                </div>

            {% elseif material.category == 'Uniformidad' %}
                {# UNIFORMIDAD LAYOUT #}
                <div class="card shadow-sm mb-4 border-0">
                    <div class="card-header bg-white py-3">
                        <h6 class="m-0 font-weight-bold text-primary">
                            <i class="fas fa-tshirt mr-2"></i> DATOS DE UNIFORMIDAD
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-12">
                                {{ form_row(form.name, {'label': 'NOMBRE DE LA PRENDA*'}) }}
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-md-6">
                                {{ form_row(form.nature, {'label': 'NATURALEZA*'}) }}
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Prenda</label>
                                <div class="input-group">
                                    {{ form_widget(form.subFamily, {'attr': {'class': 'form-input', 'data-material-dynamic-form-target': 'subFamilySelect'}}) }}
                                    <button class="btn btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#addSubFamilyModal">
                                        <i class="fas fa-plus"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                {# SANITARIO / GENERIC LAYOUT #}
                {# BLOQUE A: IDENTIDAD DEL MATERIAL #}
                <div class="card shadow-sm mb-4 border-0 mt-n4" style="border-top: 4px solid #4e73df !important;">
                    <div class="card-header bg-white py-3 border-bottom-0">
                        <h6 class="m-0 font-weight-bold text-primary text-uppercase">
                            Bloque A: Identidad del Material
                        </h6>
                    </div>
                    <div class="card-body pt-0">
                        <div class="row">
                            <div class="col-md-8">
                                <label class="form-label pt-1">Nombre Comercial<span class="text-red-500">*</span></label>
                                {{ form_widget(form.name, {'attr': {'class': 'form-input', 'placeholder': 'Ej: Paracetamol 500mg', 'data-required': 'true'}}) }}
                            </div>
                            <div class="col-md-4">
                                <label class="form-label pt-1">Código de Barras<span class="text-red-500">*</span></label>
                                {{ form_widget(form.barcode, {
                                    'attr': {
                                        'class': 'form-input',
                                        'data-required': 'true',
                                        'data-material-dynamic-form-target': 'barcodeInput',
                                        'data-action': 'input->material-dynamic-form#checkBarcodeUniqueness',
                                        'data-check-url': path('app_material_check_barcode')
                                    }
                                }) }}
                                <div class="text-danger font-weight-bold mt-1" style="font-size: 0.7rem;">{{ form_errors(form.barcode) }}</div>
                            </div>
                        </div>
                        <div class="d-flex flex-wrap align-items-end gap-3 mt-3">
                            <div class="flex-shrink-0">
                                <label class="form-label">Naturaleza</label>
                                {{ form_widget(form.nature, {
                                    'attr': {
                                        'class': 'form-input w-auto',
                                        'data-material-dynamic-form-target': 'natureSelect',
                                        'data-action': 'change->material-dynamic-form#toggleTechnicalBlock change->material-dynamic-form#handleNatureChange'
                                    }
                                }) }}
                            </div>
                            <div class="flex-shrink-0">
                                {% if material.category in ['Sanitario', 'Uniformidad', 'Logística'] %}
                                    <label class="form-label">{{ material.category == 'Uniformidad' ? 'Prenda' : 'Subfamilia' }}</label>
                                    <div class="d-flex gap-0">
                                        {{ form_widget(form.subFamily, {'attr': {'class': 'form-input w-auto', 'style': 'border-top-right-radius: 0; border-bottom-right-radius: 0;', 'data-material-dynamic-form-target': 'subFamilySelect'}}) }}
                                        <button class="btn btn-primary d-flex align-items-center px-3" style="border-top-left-radius: 0; border-bottom-left-radius: 0;" type="button" data-bs-toggle="modal" data-bs-target="#addSubFamilyModal">
                                            <i class="fas fa-plus mr-1"></i>
                                            <span>Añadir</span>
                                        </button>
                                    </div>
                                {% else %}
                                    <div class="d-none">{{ form_row(form.subFamily) }}</div>
                                {% endif %}
                            </div>
                        </div>
                        <div class="row mt-3">
                            <div class="col-md-12">
                                <label class="form-label">Descripción</label>
                                {{ form_widget(form.description, {'attr': {'class': 'form-input', 'rows': '3'}}) }}
                            </div>
                        </div>
                    </div>
                </div>

            {% endif %}

            {# Contenedores Comunes para Dinámica de Materiales #}
            <div id="batches-container" data-material-dynamic-form-target="batchesContainer">
            </div>

            {# BLOQUE B: SEGURIDAD Y TRAZABILIDAD (OTROS) #}
            <div class="card shadow-sm mb-4 border-0 d-none" style="border-top: 4px solid #f6c23e !important;" data-material-dynamic-form-target="technicalBlock">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 font-weight-bold text-warning text-uppercase">
                        Bloque B: Seguridad y Trazabilidad (Otros)
                    </h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Marca y Modelo</label>
                            {{ form_widget(form.brandModel, {'attr': {'class': 'form-input'}}) }}
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Número de Serie (S/N)</label>
                            {{ form_widget(form.serialNumber, {'attr': {'class': 'form-input'}}) }}
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Fecha de Compra</label>
                            {{ form_widget(form.purchaseDate, {'attr': {'class': 'form-input'}}) }}
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Garantía</label>
                            {{ form_widget(form.warrantyDate, {'attr': {'class': 'form-input'}}) }}
                        </div>
                    </div>
                </div>
            </div>

            {# BLOQUE B: SEGURIDAD Y TRAZABILIDAD (FALLBACK) #}
            <div class="card shadow-sm mb-4 border-0 d-none" style="border-top: 4px solid #e74a3b !important;" data-material-dynamic-form-target="consumableBlock">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 font-weight-bold text-danger text-uppercase">
                        Bloque B: Seguridad y Trazabilidad (Lote Único)
                    </h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <label class="form-label">Lote</label>
                            {{ form_widget(form.batchNumber, {'attr': {'class': 'form-input'}}) }}
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Fecha de Caducidad</label>
                            {{ form_widget(form.expirationDate, {'attr': {'class': 'form-input'}}) }}
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Proveedor</label>
                            {{ form_widget(form.supplier, {'attr': {'class': 'form-input'}}) }}
                        </div>
                    </div>
                    <div class="d-none">{{ form_row(form.category) }}</div>
                </div>
            </div>

            {# Contenedor para Bloques Técnicos Dinámicos #}
            <div id="technical-blocks-container" class="d-none" data-material-dynamic-form-target="technicalBlocksContainer">
            </div>
        </div>

        {# Columna Derecha (4) - BLOQUE D E IMAGEN #}
        <div class="col-lg-4">
            {# BLOQUE D: STOCK Y COSTES - RECONSTRUIDO PARA COINCIDIR CON LA IMAGEN #}
            <div class="card shadow-sm mb-4 border-0" style="border-top: 4px solid #1cc88a !important;" data-material-dynamic-form-target="stockAndCostsBlock">
                <div class="card-header bg-white py-3 border-bottom-1">
                    <h6 class="m-0 font-weight-bold text-success text-uppercase">
                        Bloque D: Stock y Costes
                    </h6>
                </div>
                
                <div class="card-body p-4">
                    <div class="form-grid">
                        {# Fila: Uds/Envase #}
                        <div class="form-group" data-material-dynamic-form-target="unitsPerPackageContainer" data-redundant-multi-batch="true">
                            <label class="form-label">Unidades por Envase<span class="text-red-500">*</span></label>
                            {{ form_widget(form.unitsPerPackage, {
                                'attr': {
                                    'class': 'form-input border-blue-400',
                                    'data-material-dynamic-form-target': 'unitsPerPackageInput',
                                    'data-required': 'true',
                                    'data-action': 'input->material-dynamic-form#performCalculations input->material-dynamic-form#enforceNumericConstraints keyup->material-dynamic-form#enforceNumericConstraints paste->material-dynamic-form#enforceNumericConstraints blur->material-dynamic-form#formatInput'
                                }
                            }) }}
                        </div>

                        {# Nº Envases #}
                        <div class="form-group" data-redundant-multi-batch="true" data-material-dynamic-form-target="numPackagesContainer">
                            <label class="form-label">Total Nº Envases<span class="text-red-500">*</span></label>
                            {{ form_widget(form.numPackages, {
                                'attr': {
                                    'class': 'form-input border-blue-400',
                                    'data-material-dynamic-form-target': 'numPackagesInput',
                                    'data-required': 'true',
                                    'data-action': 'input->material-dynamic-form#performCalculations input->material-dynamic-form#enforceNumericConstraints keyup->material-dynamic-form#enforceNumericConstraints paste->material-dynamic-form#enforceNumericConstraints blur->material-dynamic-form#formatInput'
                                }
                            }) }}
                        </div>

                        {# Stock Total Calculado - Span 2 #}
                        <div class="form-group col-span-2 highlight-box">
                            <label class="form-label">Stock Total Registrado</label>
                            <div class="relative">
                                {{ form_widget(form.stock, {
                                    'attr': {
                                        'class': 'form-input text-center font-bold text-green-700 bg-white cursor-default',
                                        'readonly': true,
                                        'data-material-dynamic-form-target': 'totalStockInput'
                                    }
                                }) }}
                            </div>
                            <p class="text-hint">Calculado: Uds x Envases.</p>
                        </div>

                        {# Stock Mínimo - Span 2 #}
                        <div class="form-group col-span-2 border-b border-gray-100 pb-2" data-material-dynamic-form-target="safetyStockContainer">
                            <label class="form-label">Stock Mínimo (Nº Envases)<span class="text-red-500">*</span></label>
                            {{ form_widget(form.safetyStock, {
                                'attr': {
                                    'class': 'form-input',
                                    'data-required': 'true',
                                    'data-action': 'input->material-dynamic-form#enforceNumericConstraints keyup->material-dynamic-form#enforceNumericConstraints paste->material-dynamic-form#enforceNumericConstraints blur->material-dynamic-form#formatInput'
                                }
                            }) }}
                        </div>

                        {# Coste Total #}
                        <div class="form-group" data-redundant-multi-batch="true" data-material-dynamic-form-target="totalPriceContainer">
                            <label class="form-label">Coste Total<span class="text-red-500">*</span></label>
                            {{ form_widget(form.totalPrice, {
                                'attr': {
                                    'class': 'form-input border-emerald-400',
                                    'data-type': 'decimal',
                                    'data-material-dynamic-form-target': 'totalPrice',
                                    'data-action': 'input->material-dynamic-form#performCalculations input->material-dynamic-form#enforceNumericConstraints keyup->material-dynamic-form#enforceNumericConstraints paste->material-dynamic-form#enforceNumericConstraints blur->material-dynamic-form#formatInput'
                                }
                            }) }}
                        </div>

                        {# % Margen #}
                        <div class="form-group" data-redundant-multi-batch="true" data-material-dynamic-form-target="discountPercentageContainer">
                            <label class="form-label">% Margen</label>
                            {{ form_widget(form.discountPercentage, {
                                'attr': {
                                    'class': 'form-input border-emerald-400',
                                    'data-type': 'decimal',
                                    'data-material-dynamic-form-target': 'discountPercentageInput',
                                    'data-action': 'input->material-dynamic-form#performCalculations input->material-dynamic-form#enforceNumericConstraints keyup->material-dynamic-form#enforceNumericConstraints paste->material-dynamic-form#enforceNumericConstraints blur->material-dynamic-form#formatInput'
                                }
                            }) }}
                        </div>

                        {# Coste con Dto #}
                        <div class="form-group" data-redundant-multi-batch="true" data-material-dynamic-form-target="discountedPriceContainer">
                            <label class="form-label">Coste con Dto</label>
                            <div class="currency-wrapper">
                                {{ form_widget(form.discountedPrice, {
                                    'attr': {
                                        'class': 'form-input pr-8 bg-gray-50 cursor-default',
                                        'placeholder': '0,00€',
                                        'readonly': true,
                                        'data-material-dynamic-form-target': 'discountedPriceInput'
                                    }
                                }) }}
                                <span class="currency-symbol suffix">€</span>
                            </div>
                        </div>

                        {# Precio/Ud #}
                        <div class="form-group" data-redundant-multi-batch="true" data-material-dynamic-form-target="unitPriceContainer">
                            <label class="form-label">Precio/Ud</label>
                            <div class="currency-wrapper">
                                {{ form_widget(form.unitPrice, {
                                    'attr': {
                                        'class': 'form-input pr-8 bg-gray-50 cursor-default',
                                        'placeholder': '0,00€',
                                        'readonly': true,
                                        'data-material-dynamic-form-target': 'unitPrice'
                                    }
                                }) }}
                                <span class="currency-symbol suffix">€</span>
                            </div>
                        </div>

                        {# IVA #}
                        <div class="form-group" data-redundant-multi-batch="true" data-material-dynamic-form-target="ivaContainer">
                            <label class="form-label">IVA (%)</label>
                            {{ form_widget(form.iva, {
                                'attr': {
                                    'class': 'form-input border-emerald-400',
                                    'data-type': 'decimal',
                                    'data-action': 'input->material-dynamic-form#performCalculations input->material-dynamic-form#enforceNumericConstraints keyup->material-dynamic-form#enforceNumericConstraints paste->material-dynamic-form#enforceNumericConstraints blur->material-dynamic-form#formatInput'
                                }
                            }) }}
                        </div>
                    </div>
                </div>
            </div>

            {# ZONA DE IMAGEN #}
            <div class="bg-gray-50 rounded-lg shadow-sm border border-gray-200 p-6">
                <h6 class="block text-center text-xxs font-bold text-blue-600 uppercase mb-4 tracking-wider">
                    Imagen del Producto
                </h6>
                <div class="flex items-center space-x-2 border border-gray-200 rounded bg-white p-2">
                    <label class="bg-gray-100 hover:bg-gray-200 text-gray-700 text-xxs px-3 py-1 rounded cursor-pointer transition-colors border border-gray-300">
                        Seleccionar archivo
                        {{ form_widget(form.imageFile, {
                            'attr': {
                                'class': 'hidden'
                            }
                        }) }}
                    </label>
                    <span class="text-xxs text-gray-500 truncate">Ningún archivo seleccionado</span>
                </div>
                <p class="text-xxs text-center text-gray-400 mt-3">
                    Formatos permitidos: JPG, PNG. Tamaño máximo: 2MB
                </p>
            </div>
        </div>
    </div>
    <div class="d-none">
        {% if form.serialNumber is defined and not form.serialNumber.rendered %}{{ form_row(form.serialNumber) }}{% endif %}
        {% if form.brandModel is defined and not form.brandModel.rendered %}{{ form_row(form.brandModel) }}{% endif %}
        {% if form.purchaseDate is defined and not form.purchaseDate.rendered %}{{ form_row(form.purchaseDate) }}{% endif %}
        {% if form.warrantyDate is defined and not form.warrantyDate.rendered %}{{ form_row(form.warrantyDate) }}{% endif %}
        {% if form.operationalStatus is defined and not form.operationalStatus.rendered %}{{ form_row(form.operationalStatus) }}{% endif %}
        {% if form.batteryStatus is defined and not form.batteryStatus.rendered %}{{ form_row(form.batteryStatus) }}{% endif %}
        {% if form.deviceType is defined and not form.deviceType.rendered %}{{ form_row(form.deviceType) }}{% endif %}
        {% if form.frequencyBand is defined and not form.frequencyBand.rendered %}{{ form_row(form.frequencyBand) }}{% endif %}
        {% if form.phoneNumber is defined and not form.phoneNumber.rendered %}{{ form_row(form.phoneNumber) }}{% endif %}
        {% if form.networkId is defined and not form.networkId.rendered %}{{ form_row(form.networkId) }}{% endif %}
        {% if form.hasCharger is defined and not form.hasCharger.rendered %}{{ form_row(form.hasCharger) }}{% endif %}
        {% if form.hasClip is defined and not form.hasClip.rendered %}{{ form_row(form.hasClip) }}{% endif %}
        {% if form.hasMicrophone is defined and not form.hasMicrophone.rendered %}{{ form_row(form.hasMicrophone) }}{% endif %}
    </div>
    {{ form_end(form) }}
</div>

<!-- Modal Añadir Subfamilia / Prenda -->
<div class="modal fade" id="addSubFamilyModal" tabindex="-1" aria-labelledby="addSubFamilyModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="addSubFamilyModalLabel">
                    <i class="fas fa-plus-circle mr-2"></i> Añadir {{ material.category == 'Uniformidad' ? 'Prenda' : 'Subfamilia' }}
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="form-group">
                    <label class="form-label">Nombre de la nueva {{ material.category == 'Uniformidad' ? 'prenda' : 'subfamilia' }}</label>
                    <input type="text" id="new-subfamily-name" class="form-control" placeholder="Ej: Nueva Categoría">
                </div>
            </div>
            <div class="modal-footer bg-light border-0">
                <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary px-4" data-action="click->material-dynamic-form#saveNewSubFamily">Guardar y Seleccionar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Aviso Código de Barras Duplicado (Equipo Técnico) -->
<div class="modal fade" id="barcodeWarningModal" tabindex="-1" aria-labelledby="barcodeWarningModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-warning text-white">
                <h5 class="modal-title" id="barcodeWarningModalLabel">
                    <i class="fas fa-exclamation-triangle mr-2"></i> Aviso: Código de Barras Registrado
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <p class="mb-0 text-dark">Este Código de Barras ya pertenece al material:</p>
                <p class="mt-2 mb-3"><strong id="barcodeDuplicateName" class="text-primary font-size-lg border-bottom border-primary pb-1"></strong></p>
                <p class="text-muted small mt-2">Dado que es <strong>Equipo Técnico</strong>, puedes continuar si se trata de otra unidad de este mismo modelo, pero asegúrate de que el <strong>Número de Serie</strong> sea único.</p>
            </div>
            <div class="modal-footer bg-light border-0">
                <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">Cancelar</button>
                <a id="barcodeRedirectBtn" href="#" class="btn btn-primary px-4">Ir al material existente e insertar unidades</a>
            </div>
        </div>
    </div>
</div>

<style>
    .material-form label {
        font-weight: 700;
        color: #4e73df;
        font-size: 0.75rem;
        text-transform: uppercase;
        margin-bottom: 0.25rem;
    }
    .card-header {
        border-bottom: 1px solid #f2f2f2 !important;
    }
    .form-control:focus {
        border-color: #4e73df;
        box-shadow: 0 0 0 0.2rem rgba(78, 115, 223, 0.1);
    }
</style>
{% endblock %}
