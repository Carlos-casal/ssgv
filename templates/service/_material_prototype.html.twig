<div class="material-item border border-slate-100 dark:border-slate-800 rounded-xl p-3 bg-slate-50 dark:bg-slate-900/40 shadow-sm transition-all hover:shadow-md" data-action="change->service-form#onMaterialRowChange">
    <div class="flex items-center gap-2 mb-2">
        <div class="flex-grow min-w-0">
            {{ form_widget(form.material, {'attr': {'class': 'ui-input !h-[38px] !px-3 !text-[11px] material-selector', 'data-action': 'change->service-form#onMaterialSelectChange'}}) }}
        </div>
        <div style="width: 60px;">
            {{ form_widget(form.quantity, {'attr': {
                'class': 'ui-input !h-[38px] !px-2 text-center !text-[11px] font-bold quantity-input',
                'placeholder': '1',
                'value': form.quantity.vars.value ?: 1,
                'data-action': 'input->service-form#onQuantityInput input->service-form#clearError'
            }}) }}
        </div>
        <button type="button" class="text-slate-300 hover:text-rose-500 transition-colors p-1" data-action="click->service-form#removeMaterial" title="Eliminar material">
            <i data-lucide="trash-2" class="w-4 h-4"></i>
        </button>
    </div>

    <div class="availability-status text-[10px] font-bold px-1"></div>

    <div class="unit-selection-container mt-2 hidden">
        <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1 block px-1">Identificar Unidad (Opcional)</label>
        {{ form_widget(form.materialUnit, {'attr': {'class': 'ui-input !h-[32px] !px-2 !text-[10px] unit-selector'}}) }}
    </div>
</div>
