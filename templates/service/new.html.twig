{% extends 'layout/app.html.twig' %}

{% block title %}Crear Nuevo Servicio{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

        body {
            font-family: 'Inter', sans-serif;
        }

        .form-error {
            color: var(--ui-danger);
            font-size: 0.75rem;
            margin-top: 0.25rem;
            font-weight: 600;
        }

        /* iPhone Switch Styling */
        .form-switch .form-check-input {
            width: 2.5em;
            height: 1.25em;
            cursor: pointer;
        }
        .form-switch .form-check-input:checked {
            background-color: var(--ui-accent);
            border-color: var(--ui-accent);
        }

        .afluencia-baja { color: #16a34a !important; font-weight: 700; }
        .afluencia-media { color: #ea580c !important; font-weight: 700; }
        .afluencia-alta { color: #dc2626 !important; font-weight: 900; }

        /* Flatpickr Modern Customization */
        .flatpickr-calendar {
            background: #1f2937 !important;
            border: 1px solid rgba(255,255,255,0.1) !important;
            border-radius: 12px !important;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3) !important;
        }
        .flatpickr-day.selected {
            background: var(--ui-accent) !important;
            border-color: var(--ui-accent) !important;
        }
        .flatpickr-months .flatpickr-month {
            background: #1f2937 !important;
            color: #f8fafc !important;
        }
    </style>
{% endblock %}

{% block page_title %}{% endblock %}

{% block content %}
<div class="animate-in" data-controller="service-form">
    {{ form_start(form, {
        'attr': {
            'id': 'new-service-form-element',
            'data-service-form-target': 'form',
            'novalidate': 'novalidate'
        }
    }) }}

    <div class="mb-6 mt-4 lg:mt-0 flex flex-col lg:flex-row justify-between items-start lg:items-end gap-4">
        <div>
            <h1 class="text-2xl font-black text-slate-900 dark:text-white mb-1">Crear Nuevo Servicio</h1>
            <p class="text-sm text-slate-500 dark:text-slate-400">Planificación y gestión de dispositivos preventivos</p>
        </div>
        <div class="flex gap-2 w-full lg:w-auto">
            <a href="{{ path('app_services_list') }}" class="ui-btn btn-dark flex-1 lg:flex-none">
                <i data-lucide="x" class="w-4 h-4 mr-2"></i> Cancelar
            </a>
            <button type="button" data-action="click->service-form#submitForm" class="ui-btn btn-cyan flex-1 lg:flex-none">
                <i data-lucide="save" class="w-4 h-4 mr-2"></i> GUARDAR
            </button>
        </div>
    </div>

    <!-- Navigation Tabs -->
    <ul class="nav nav-tabs nav-tabs-custom border-b border-slate-200 dark:border-slate-800 mb-4 bg-slate-50/80 dark:bg-slate-900/80 backdrop-blur-md -mx-6 px-6" style="z-index: 100;" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="datos-tab" data-bs-toggle="tab" data-bs-target="#datos" type="button" role="tab" aria-controls="datos" aria-selected="true">
                <i data-lucide="file-text" class="w-4 h-4 inline me-2"></i> Datos Generales
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="recursos-tab" data-bs-toggle="tab" data-bs-target="#recursos" type="button" role="tab" aria-controls="recursos" aria-selected="false">
                <i data-lucide="truck" class="w-4 h-4 inline me-2"></i> Recursos y Dotación
            </button>
        </li>
    </ul>

    <div class="tab-content" id="serviceFormTabContent">
        <!-- TAB 1: DATOS GENERALES -->
        <div class="tab-pane fade show active" id="datos" role="tabpanel" aria-labelledby="datos-tab">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
                <!-- COLUMNA IZQUIERDA: Datos Identificativos -->
                <div class="lg:col-span-6">
                    <div class="ui-fieldset h-full !pb-4">
                        <div class="ui-legend">Datos Identificativos</div>
                        
                        <div class="field-group !mb-3">
                            <label class="field-label">Título del Servicio <span>*</span></label>
                            {{ form_widget(form.title, {'attr': {'class': 'ui-input font-bold', 'placeholder': 'Ej. Dispositivo Maratón', 'data-action': 'input->service-form#clearError', 'data-service-form-target': 'title'}}) }}
                            <div class="form-error hidden" id="error-service_title"></div>
                        </div>

                        <div class="field-group !mb-3">
                            <label class="field-label">Nº de Registro (ID)</label>
                            {{ form_widget(form.numeration, {'attr': {'class': 'ui-input font-mono !bg-slate-50 dark:!bg-slate-900', 'placeholder': 'Auto-generado si vacío', 'data-service-form-target': 'numeration'}}) }}
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 !mb-3">
                            <div class="field-group !mb-0">
                                <label class="field-label">Tipo <span>*</span></label>
                                <div class="flex">
                                    {{ form_widget(form.type, {'attr': {'class': 'ui-input !rounded-r-none border-r-0', 'data-action': 'change->service-form#updateCategories', 'data-service-form-target': 'typeSelect'}}) }}
                                    <button type="button" class="ui-btn btn-cyan !px-3 !rounded-l-none" data-action="click->service-form#openTypeModal">
                                        <i data-lucide="plus" class="w-4 h-4"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="field-group !mb-0">
                                <label class="field-label">Categoría <span>*</span></label>
                                <div class="flex">
                                    {{ form_widget(form.subcategory, {'attr': {'class': 'ui-input !rounded-r-none border-r-0', 'data-service-form-target': 'subcategorySelect'}}) }}
                                    <button type="button" class="ui-btn btn-cyan !px-3 !rounded-l-none" data-action="click->service-form#openSubcategoryModal">
                                        <i data-lucide="plus" class="w-4 h-4"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-4 !mb-0">
                            <div class="field-group !mb-0">
                                <label class="field-label">Afluencia Estimada <span>*</span></label>
                                {{ form_widget(form.afluencia, {'attr': {'class': 'ui-input', 'data-action': 'change->service-form#updateAfluenciaColor', 'data-service-form-target': 'afluenciaSelect'}}) }}
                            </div>
                            <div class="field-group !mb-0">
                                <label class="field-label">Nº aprox.</label>
                                {{ form_widget(form.estimatedPeople, {'attr': {'class': 'ui-input text-center', 'placeholder': 'Aprox.', 'data-service-form-target': 'estimatedPeopleInput'}}) }}
                            </div>
                        </div>
                    </div>
                </div>

                <!-- COLUMNA DERECHA: Cronología y Ubicación -->
                <div class="lg:col-span-6">
                    <div class="ui-fieldset h-full !pb-4">
                        <div class="ui-legend">Cronología y Ubicación</div>

                        <!-- Row 1: Dates & Location -->
                        <div class="grid grid-cols-1 sm:grid-cols-12 gap-4 !mb-4">
                            <div class="sm:col-span-7">
                                <div class="grid grid-cols-2 gap-3">
                                    <div class="date-input-container">
                                        <span class="date-badge">INICIO</span>
                                        <div class="ui-input-wrapper">
                                            {{ form_widget(form.startDate, {'attr': {'class': 'ui-input', 'data-service-form-target': 'startDateInput'}}) }}
                                            <i data-lucide="calendar" class="ui-input-icon-right"></i>
                                        </div>
                                    </div>
                                    <div class="date-input-container">
                                        <span class="date-badge">FIN</span>
                                        <div class="ui-input-wrapper">
                                            {{ form_widget(form.endDate, {'attr': {'class': 'ui-input', 'data-service-form-target': 'endDateInput'}}) }}
                                            <i data-lucide="calendar" class="ui-input-icon-right"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="sm:col-span-5">
                                <div class="field-group !mb-0">
                                    <label class="field-label">Ubicación / Lugar <span>*</span></label>
                                    <div class="ui-input-wrapper">
                                        <i data-lucide="map-pin" class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
                                        {{ form_widget(form.locality, {'attr': {'class': 'ui-input !pl-11', 'placeholder': 'Dirección...'}}) }}
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Row 2: Hours & Limits -->
                        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                            <div class="date-input-container">
                                <span class="date-badge">HORA EN BASE</span>
                                <div class="ui-input-wrapper">
                                    {{ form_widget(form.timeAtBase, {'attr': {'class': 'ui-input', 'data-service-form-target': 'timeAtBaseInput'}}) }}
                                    <i data-lucide="clock" class="ui-input-icon-right"></i>
                                </div>
                            </div>
                            <div class="date-input-container">
                                <span class="date-badge">HORA SALIDA</span>
                                <div class="ui-input-wrapper">
                                    {{ form_widget(form.departureTime, {'attr': {'class': 'ui-input', 'data-service-form-target': 'departureTimeInput'}}) }}
                                    <i data-lucide="clock" class="ui-input-icon-right"></i>
                                </div>
                            </div>
                            <div class="date-input-container">
                                <span class="date-badge">LÍMITE INSCRIPCION</span>
                                <div class="ui-input-wrapper">
                                    {{ form_widget(form.registrationLimitDate, {'attr': {'class': 'ui-input', 'data-service-form-target': 'registrationLimitInput'}}) }}
                                    <i data-lucide="calendar" class="ui-input-icon-right"></i>
                                </div>
                            </div>
                            <div class="field-group !mb-0">
                                <label class="field-label" style="font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 800; color: var(--text-secondary); margin-bottom: 0.35rem;">Límite Inscritos</label>
                                <div class="ui-input-wrapper">
                                    <i data-lucide="users" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
                                    {{ form_widget(form.maxAttendees, {'attr': {'class': 'ui-input !pl-9 text-xs', 'placeholder': 'Sin límite'}}) }}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- FILA 2: Descripción y Tareas (Ancho Completo) -->
                <div class="lg:col-span-12">
                    <div class="ui-fieldset">
                        <div class="ui-legend">Definición Operativa</div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                            <div class="field-group !mb-0">
                                <label class="field-label">Tareas del Servicio</label>
                                {{ form_widget(form.tasks, {'attr': {'class': 'ui-input ui-textarea', 'style': 'height: 250px;', 'placeholder': 'Describe brevemente las tareas...', 'data-service-form-target': 'tasksInput'}}) }}
                            </div>
                            <div class="field-group !mb-0">
                                <label class="field-label">Descripción Detallada</label>
                                {{ form_widget(form.description, {'attr': {'class': 'ui-input ui-textarea', 'style': 'height: 250px;', 'data-service-form-target': 'descriptionInput'}}) }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- TAB 2: RECURSOS Y DOTACIÓN -->
        <div class="tab-pane fade" id="recursos" role="tabpanel" aria-labelledby="recursos-tab">
            <div class="ui-fieldset">
                <div class="ui-legend">Recursos, Materiales y Dotación</div>

                <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
                    <!-- Materiales -->
                    <div class="lg:col-span-8 border-r border-slate-200 dark:border-slate-800 pr-8">
                        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6" id="materials-container"
                             data-service-form-target="materialsContainer"
                             data-index="{{ form.serviceMaterials|length }}"
                             data-prototype="{{ include('service/_material_prototype.html.twig', { 'form': form.serviceMaterials.vars.prototype })|e('html_attr') }}">

                            {% for category in ['Sanitario', 'Comunicaciones', 'Logística', 'Otros'] %}
                            <div class="mb-4">
                                <div class="flex justify-between items-center mb-4 bg-slate-50 dark:bg-slate-900/50 p-2 rounded-lg border border-slate-100 dark:border-slate-800">
                                    <span class="text-[10px] font-black text-slate-500 uppercase tracking-widest">{{ category }}</span>
                                    <button type="button" class="text-cyan-500 hover:text-cyan-600 transition-colors" data-action="click->service-form#addMaterial" data-category="{{ category }}">
                                        <i data-lucide="plus-circle" class="w-4 h-4"></i>
                                    </button>
                                </div>
                                <div class="space-y-3" data-material-category="{{ category }}">
                                    {% for sm in form.serviceMaterials %}
                                        {% if sm.vars.data.material and sm.vars.data.material.category == category %}
                                            {{ include('service/_material_prototype.html.twig', { 'form': sm }) }}
                                        {% endif %}
                                    {% endfor %}
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                    </div>

                    <!-- Dotación y Vehículos -->
                    <div class="lg:col-span-4">
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                            <!-- Personal -->
                            <div>
                                <span class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Personal Requerido</span>
                                <div class="space-y-2">
                                    {% for field in ['numTes', 'numTts', 'numDue', 'numDoctors'] %}
                                        <div class="flex justify-between items-center bg-slate-50 dark:bg-slate-900/50 p-1 px-3 rounded-lg border border-slate-100 dark:border-slate-800">
                                            <span class="text-[11px] font-bold text-slate-600 dark:text-slate-400">{{ form[field].vars.label }}</span>
                                            {{ form_widget(form[field], {'attr': {'class': 'ui-input !h-8 !w-12 !p-1 text-center', 'type': 'number', 'min': '0', 'placeholder': '0'}}) }}
                                        </div>
                                    {% endfor %}
                                    <div class="flex justify-between items-center bg-cyan-50/50 dark:bg-cyan-900/20 p-2 px-3 rounded-lg border border-cyan-100 dark:border-cyan-900/30 mt-4">
                                        <span class="text-[11px] font-bold text-cyan-700 dark:text-cyan-400">Hosp. Campaña</span>
                                        <div class="form-check form-switch m-0 p-0">
                                            {{ form_widget(form.hasFieldHospital, {'attr': {'class': 'form-check-input !mt-0'}}) }}
                                        </div>
                                    </div>

                            <div class="flex justify-between items-center bg-orange-50/50 dark:bg-orange-900/20 p-2 px-3 rounded-lg border border-orange-100 dark:border-orange-900/30 mt-2">
                                <span class="text-[11px] font-bold text-orange-700 dark:text-orange-400">Avituallamiento</span>
                                <div class="form-check form-switch m-0 p-0">
                                    {{ form_widget(form.hasProvisions, {'attr': {'class': 'form-check-input !mt-0'}}) }}
                                </div>
                            </div>
                                </div>
                            </div>
                            <!-- Ambulancias -->
                            <div>
                                <span class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Tipo Ambulancia</span>
                                <div class="space-y-2">
                                    {% for field in ['numSvb', 'numSva', 'numColectiva'] %}
                                        <div class="flex justify-between items-center bg-slate-50 dark:bg-slate-900/50 p-1 px-3 rounded-lg border border-slate-100 dark:border-slate-800">
                                            <span class="text-[11px] font-bold text-slate-600 dark:text-slate-400">{{ form[field].vars.label }}</span>
                                            {{ form_widget(form[field], {'attr': {'class': 'ui-input !h-8 !w-12 !p-1 text-center', 'type': 'number', 'min': '0', 'placeholder': '0'}}) }}
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                            <!-- Vehículos -->
                            <div class="col-span-2 mt-4">
                                <span class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Asignar Vehículos</span>
                                <div class="bg-slate-50 dark:bg-slate-900/50 rounded-xl border border-slate-100 dark:border-slate-800 overflow-hidden">
                                    <div class="max-h-60 overflow-y-auto p-2">
                                        {% for key, vehicle_choice in form.vehicles %}
                                            {% set vehicle = form.vehicles.vars.choices[key].data %}
                                            <div class="flex items-center justify-between p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors border-b border-slate-100 dark:border-slate-800 last:border-0">
                                                <div class="flex flex-col">
                                                    <span class="text-[11px] font-bold text-slate-700 dark:text-slate-300">{{ vehicle.alias ?: vehicle.model }}</span>
                                                    <span class="text-[9px] text-slate-400 font-mono">{{ vehicle.licensePlate }}</span>
                                                </div>
                                                <div class="form-check form-switch m-0 p-0">
                                                    <input class="form-check-input !mt-0" type="checkbox" name="{{ vehicle_choice.vars.full_name }}" id="{{ vehicle_choice.vars.id }}" value="{{ vehicle_choice.vars.value }}" {% if vehicle_choice.vars.checked %}checked{% endif %}>
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Hidden Fields -->
    <div style="display:none;">
        {{ form_rest(form) }}
    </div>

    {{ form_end(form) }}

    <!-- Modals -->
    <!-- Type Modal -->
    <div id="typeModal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm flex items-center justify-center z-[2000] hidden" style="display: none;" data-service-form-target="typeModal">
        <div class="bg-white dark:bg-slate-800 p-8 rounded-2xl shadow-2xl w-full max-w-md relative">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-xl font-black text-slate-800 dark:text-white uppercase tracking-tight">Nuevo Tipo</h3>
                <button type="button" data-action="click->service-form#closeTypeModal" class="text-slate-400 hover:text-rose-500 transition-colors">
                    <i data-lucide="x" class="h-6 w-6"></i>
                </button>
            </div>
            <form id="modal-new-type-form" data-action="submit->service-form#handleTypeSubmit" novalidate>
                <div class="field-group">
                    <label for="type_name_input" class="field-label">Nombre <span>*</span></label>
                    <input type="text" id="type_name_input" name="name" class="ui-input" required data-action="input->service-form#clearError">
                    <div class="form-error hidden" id="error-type_name_input"></div>
                </div>
                <div class="mt-8 flex justify-end">
                    <button type="submit" class="ui-btn btn-cyan w-full">Aceptar</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Subcategory Modal -->
    <div id="subcategoryModal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm flex items-center justify-center z-[2000] hidden" style="display: none;" data-service-form-target="subcategoryModal">
        <div class="bg-white dark:bg-slate-800 p-8 rounded-2xl shadow-2xl w-full max-w-md relative">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-xl font-black text-slate-800 dark:text-white uppercase tracking-tight">Nueva Categoría</h3>
                <button type="button" data-action="click->service-form#closeSubcategoryModal" class="text-slate-400 hover:text-rose-500 transition-colors">
                    <i data-lucide="x" class="h-6 w-6"></i>
                </button>
            </div>
            <form id="modal-new-subcategory-form" data-action="submit->service-form#handleSubcategorySubmit" novalidate>
                <input type="hidden" id="modal_type_id" name="type_id">

                <div class="field-group">
                    <label for="modal_category_select" class="field-label">Categoría (Nivel 2) <span>*</span></label>
                    <div class="flex">
                        <select id="modal_category_select" name="category" class="ui-input !rounded-r-none border-r-0" required data-action="change->service-form#clearError">
                            <option value="">Selecciona...</option>
                        </select>
                        <button type="button" class="ui-btn btn-dark !px-3 !rounded-l-none" data-action="click->service-form#showNewCategoryInput">
                            <i data-lucide="plus" class="w-4 h-4"></i>
                        </button>
                    </div>
                    <div class="form-error hidden" id="error-modal_category_select"></div>
                </div>

                <div id="new_category_input_container" class="field-group hidden">
                    <label for="modal_new_category_name" class="field-label">Nombre Nueva Categoría</label>
                    <input type="text" id="modal_new_category_name" name="new_category_name" class="ui-input" data-action="input->service-form#clearError">
                    <div class="form-error hidden" id="error-modal_new_category_name"></div>
                </div>

                <div class="field-group">
                    <label for="subcategory_name_input" class="field-label">Subcategoría (Nivel 3) <span>*</span></label>
                    <input type="text" id="subcategory_name_input" name="name" class="ui-input" required data-action="input->service-form#clearError">
                    <div class="form-error hidden" id="error-subcategory_name_input"></div>
                </div>

                <div class="mt-8 flex justify-end">
                    <button type="submit" class="ui-btn btn-cyan w-full">Aceptar</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
