{% extends 'layout/app.html.twig' %}

{% block title %}Listado de Servicios{% endblock %}
{% block page_title %}Listado de Servicios{% endblock %}


{% block content %}
<div class="p-6 space-y-6">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4 mb-6">
        <div>
            <h2 class="text-xl font-bold text-slate-800 dark:text-white">Gestión de Servicios</h2>
            <p class="text-xs text-slate-500 dark:text-slate-400">Listado y acciones para dispositivos preventivos</p>
        </div>
        {% if is_granted('ROLE_ADMIN') %}
        <div class="flex gap-3">
            <a href="{{ path('app_service_new') }}"
               class="flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
                <i data-lucide="plus" class="w-4 h-4"></i>
                Nuevo Servicio
            </a>
        </div>
        {% endif %}
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200">
        <div class="p-4 border-b border-gray-200">
            <ul class="flex gap-6">
                <li>
                    <a href="{{ path('app_services_list', {'status': 'abiertos'}) }}"
                       class="pb-2 {{ status == 'abiertos' ? 'border-b-2 border-blue-600 text-blue-600 font-semibold' : 'text-gray-600 hover:text-blue-600' }}">
                        Abiertos
                    </a>
                </li>
                <li>
                    <a href="{{ path('app_services_list', {'status': 'archivados'}) }}"
                       class="pb-2 {{ status == 'archivados' ? 'border-b-2 border-blue-600 text-blue-600 font-semibold' : 'text-gray-600 hover:text-blue-600' }}">
                        Archivados
                    </a>
                </li>
            </ul>
        </div>
        <div class="p-4">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-gray-200">
                        <th class="p-2 text-left text-sm font-semibold text-gray-600">Nº</th>
                        <th class="p-2 text-left text-sm font-semibold text-gray-600">Título</th>
                        <th class="p-2 text-left text-sm font-semibold text-gray-600">Asistentes</th>
                        <th class="p-2 text-left text-sm font-semibold text-gray-600">Fecha</th>
                        <th class="p-2 text-left text-sm font-semibold text-gray-600">Limite inscripción</th>
                        <th class="p-2 text-left text-sm font-semibold text-gray-600">Tipo</th>
                        <th class="p-2 text-left text-sm font-semibold text-gray-600">Subcategoría</th>
                        <th class="p-2 text-left text-sm font-semibold text-gray-600"></th>
                    </tr>
                </thead>
                <tbody>
                    {% if services is defined and services is not empty %}
                        {% for service in services %}
                            <tr class="border-b border-gray-200">
                                <td class="p-2 text-sm">{{ service.numeration ?? 'N/A' }}</td>
                                <td class="p-2 text-sm">{{ service.title }}</td>
                                <td class="p-2 text-sm">{{ attendeesByService[service.id] | default(0) }}</td>
                                <td class="p-2 text-sm">{{ service.startDate ? service.startDate|date('d/m/Y H:i') : 'N/A' }}</td>
                                <td class="p-2 text-sm">{{ service.registrationLimitDate ? service.registrationLimitDate|date('d/m/Y H:i') : 'N/A' }}</td>
                                <td class="p-2 text-sm">{{ service.type ?? 'N/A' }}</td>
                                <td class="p-2 text-sm">{{ service.subcategory ?? 'N/A' }}</td>
                                <td class="p-2 text-sm text-right">
                                    <div class="dropdown">
                                        <button class="p-1 text-gray-400 hover:bg-gray-100 dark:hover:bg-slate-800 rounded-lg transition-colors" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            <i data-lucide="more-horizontal" class="w-5 h-5"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-xl border-slate-200 dark:border-slate-700 rounded-xl p-1">
                                            {% if is_granted('ROLE_VOLUNTEER') %}
                                                {% if assistanceByService[service.id] is defined and assistanceByService[service.id] %}
                                                    <li>
                                                        <a href="{{ path('app_service_unattend', {'id': service.id}) }}" class="dropdown-item flex items-center gap-2 py-2 rounded-lg text-red-600 hover:bg-red-50 dark:hover:bg-red-950/30">
                                                            <i data-lucide="user-minus" class="w-4 h-4"></i> No Asistir
                                                        </a>
                                                    </li>
                                                {% else %}
                                                    <li>
                                                        <a href="{{ path('app_service_attend', {'id': service.id}) }}" class="dropdown-item flex items-center gap-2 py-2 rounded-lg text-green-600 hover:bg-green-50 dark:hover:bg-green-950/30">
                                                            <i data-lucide="user-plus" class="w-4 h-4"></i> Asistir
                                                        </a>
                                                    </li>
                                                {% endif %}
                                                <li><hr class="dropdown-divider"></li>
                                            {% endif %}

                                            <li>
                                                <a class="dropdown-item flex items-center gap-2 py-2 rounded-lg text-slate-700 dark:text-slate-300" href="{{ path('app_service_edit', {'id': service.id}) }}">
                                                    <i data-lucide="edit" class="w-4 h-4"></i> Editar
                                                </a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item flex items-center gap-2 py-2 rounded-lg text-slate-700 dark:text-slate-300" href="{{ path('app_service_view', {'id': service.id}) }}">
                                                    <i data-lucide="printer" class="w-4 h-4"></i> Imprimir
                                                </a>
                                            </li>
                                            <li>
                                                <form action="{{ path('app_service_archive', {id: service.id}) }}" method="POST">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('archive' ~ service.id) }}">
                                                    <button type="submit" class="dropdown-item flex items-center gap-2 py-2 rounded-lg text-slate-700 dark:text-slate-300 w-full text-start">
                                                        <i data-lucide="archive" class="w-4 h-4"></i> Archivar
                                                    </button>
                                                </form>
                                            </li>
                                            <li>
                                                <form action="{{ path('app_service_duplicate', {id: service.id}) }}" method="POST">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('duplicate' ~ service.id) }}">
                                                    <button type="submit" class="dropdown-item flex items-center gap-2 py-2 rounded-lg text-slate-700 dark:text-slate-300 w-full text-start">
                                                        <i data-lucide="copy" class="w-4 h-4"></i> Duplicar
                                                    </button>
                                                </form>
                                            </li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li>
                                                <form action="{{ path('app_service_delete', {id: service.id}) }}" method="POST"
                                                      data-controller="confirm"
                                                      data-confirm-text-value="¿Estás seguro de que deseas eliminar permanentemente este servicio?"
                                                      data-confirm-title-value="Eliminar Servicio"
                                                      data-confirm-confirm-button-text-value="Eliminar"
                                                      data-confirm-icon-value="error">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ service.id) }}">
                                                    <button type="button" data-action="click->confirm#confirm" class="dropdown-item flex items-center gap-2 py-2 rounded-lg text-red-600 hover:bg-red-50 dark:hover:bg-red-950/30 w-full text-start">
                                                        <i data-lucide="trash-2" class="w-4 h-4"></i> Eliminar
                                                    </button>
                                                </form>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    {% else %}
                        <tr>
                            <td colspan="8" class="p-4 text-center text-gray-500">No se encontraron servicios.</td>
                        </tr>
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}