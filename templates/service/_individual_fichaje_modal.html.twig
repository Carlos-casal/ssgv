<!-- Individual Fichaje Modal -->
<div class="hidden fixed inset-0 bg-slate-900/70 backdrop-blur-sm flex items-center justify-center z-[200]"
     style="display: none;"
     data-service-form-target="individualFichajeModal">
    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-2xl w-full max-w-2xl mx-4">

        <!-- Header -->
        <div class="flex justify-between items-center p-6 border-b border-slate-100 dark:border-slate-700">
            <div>
                <h3 class="text-xl font-black text-slate-900 dark:text-white"
                    data-service-form-target="individualFichajeModalTitle">Añadir Fichaje</h3>
                <p class="text-xs text-slate-400 mt-0.5">Registro manual de entrada/salida</p>
            </div>
            <button type="button"
                    data-action="click->service-form#closeIndividualFichajeModal"
                    class="text-slate-400 hover:text-rose-500 transition-colors p-2">
                <i data-lucide="x" class="h-5 w-5"></i>
            </button>
        </div>

        <!-- Body -->
        <form data-action="submit->service-form#handleIndividualFichajeSubmit" novalidate>
            <!-- Last clock-out info box -->
            <div class="mx-6 mt-4 p-3 bg-blue-50 dark:bg-blue-900/30 border border-blue-200 dark:border-blue-800 rounded-xl flex items-start gap-3">
                <i data-lucide="clock" class="w-4 h-4 text-blue-500 mt-0.5 flex-shrink-0"></i>
                <div>
                    <p class="text-xs font-bold text-blue-800 dark:text-blue-300">
                        Último registro de salida:
                        <span class="font-black" data-service-form-target="lastClockOutTime">--:--</span>
                    </p>
                    <p class="text-xs text-blue-600 dark:text-blue-400 mt-0.5">
                        La nueva hora de entrada no puede ser anterior a esta hora.
                    </p>
                </div>
            </div>

            <div class="p-6 space-y-4">
                <!-- Date/Time grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <!-- Entrada -->
                    <div class="ui-fieldset !pb-4">
                        <div class="ui-legend text-green-700 dark:text-green-400">Entrada</div>
                        <div class="grid grid-cols-2 gap-3">
                            <div class="field-group !mb-0">
                                <label for="individual-start-date" class="field-label">Fecha <span>*</span></label>
                                <div class="ui-input-wrapper">
                                    <input type="date" id="individual-start-date" name="start_date" required
                                           class="ui-input">
                                    <i data-lucide="calendar" class="ui-input-icon-right"></i>
                                </div>
                            </div>
                            <div class="field-group !mb-0">
                                <label for="individual-start-time" class="field-label">Hora <span>*</span></label>
                                <div class="ui-input-wrapper">
                                    <input type="time" id="individual-start-time" name="start_time" required
                                           class="ui-input">
                                    <i data-lucide="clock" class="ui-input-icon-right"></i>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Salida -->
                    <div class="ui-fieldset !pb-4">
                        <div class="ui-legend text-red-700 dark:text-red-400">Salida</div>
                        <div class="grid grid-cols-2 gap-3">
                            <div class="field-group !mb-0">
                                <label for="individual-end-date" class="field-label">Fecha</label>
                                <div class="ui-input-wrapper">
                                    <input type="date" id="individual-end-date" name="end_date"
                                           class="ui-input">
                                    <i data-lucide="calendar" class="ui-input-icon-right"></i>
                                </div>
                            </div>
                            <div class="field-group !mb-0">
                                <label for="individual-end-time" class="field-label">Hora</label>
                                <div class="ui-input-wrapper">
                                    <input type="time" id="individual-end-time" name="end_time"
                                           class="ui-input">
                                    <i data-lucide="clock" class="ui-input-icon-right"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Notes -->
                <div class="field-group !mb-0">
                    <label for="individual-notes" class="field-label">Notas / Comentarios</label>
                    <div class="ui-input-wrapper">
                        <i data-lucide="message-square" class="absolute left-4 top-3 w-4 h-4 text-slate-400"></i>
                        <textarea id="individual-notes" name="notes" rows="2"
                                  class="ui-input ui-textarea !pl-11"
                                  placeholder="Ej: Pausa para comer, llegada tarde, etc."></textarea>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="flex justify-between items-center px-6 pb-6 pt-0 gap-3">
                <button type="button"
                        data-action="click->service-form#closeIndividualFichajeModal"
                        class="ui-btn btn-dark">
                    <i data-lucide="x" class="w-4 h-4 mr-2"></i> Cancelar
                </button>
                <div class="flex gap-2">
                    <button type="button"
                            data-action="click->service-form#saveAndAddAnother"
                            class="ui-btn btn-dark">
                        <i data-lucide="plus-circle" class="w-4 h-4 mr-2"></i> Guardar y Añadir Otro
                    </button>
                    <button type="submit"
                            class="ui-btn btn-cyan">
                        <i data-lucide="save" class="w-4 h-4 mr-2"></i> Guardar y Cerrar
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>