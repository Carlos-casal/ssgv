                                                        <li>
                                                            <form method="post" action="{{ path('app_assistance_confirmation_toggle_role', {'id': confirmation.id, 'role': 'socorrista'}) }}">
                                                                <input type="hidden" name="_token" value="{{ csrf_token('toggle-role' ~ confirmation.id) }}">
