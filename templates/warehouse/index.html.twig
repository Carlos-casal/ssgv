{% extends 'layout/app.html.twig' %}

{% block title %}Gestión de Almacén{% endblock %}

{% block page_title %}Gestión de Almacén{% endblock %}

{% block content %}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <p class="text-muted">Control centralizado de recursos y materiales</p>
        </div>
        <div class="dropdown">
            <button class="btn btn-primary btn-lg shadow-sm dropdown-toggle" type="button" id="addMaterialDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="z-index: 1060;">
                Añadir Material
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="addMaterialDropdown">
                <li><h6 class="dropdown-header">Seleccionar Sección</h6></li>
                <li><a class="dropdown-item py-2 d-flex align-items-center" href="{{ path('app_material_new', {category: 'Sanitario'}) }}"><i data-lucide="cross" class="w-4 h-4 me-3 text-danger"></i> Sanitario</a></li>
                <li><a class="dropdown-item py-2 d-flex align-items-center" href="{{ path('app_material_new', {category: 'Comunicaciones'}) }}"><i data-lucide="radio" class="w-4 h-4 me-3 text-primary"></i> Comunicaciones</a></li>
                <li><a class="dropdown-item py-2 d-flex align-items-center" href="{{ path('app_vehicle_new') }}"><i data-lucide="truck" class="w-4 h-4 me-3 text-warning"></i> Vehículos (Alta Flota)</a></li>
                <li><a class="dropdown-item py-2 d-flex align-items-center" href="{{ path('app_material_new', {category: 'Logística'}) }}"><i data-lucide="package" class="w-4 h-4 me-3 text-info"></i> Logística</a></li>
                <li><a class="dropdown-item py-2 d-flex align-items-center" href="{{ path('app_material_new', {category: 'Mar'}) }}"><i data-lucide="anchor" class="w-4 h-4 me-3 text-info"></i> Mar</a></li>
                <li><a class="dropdown-item py-2 d-flex align-items-center" href="{{ path('app_material_new', {category: 'Uniformidad'}) }}"><i data-lucide="shirt" class="w-4 h-4 me-3 text-secondary"></i> Uniformidad</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item py-2 d-flex align-items-center" href="{{ path('app_material_new', {category: 'Varios'}) }}"><i data-lucide="more-horizontal" class="w-4 h-4 me-3"></i> Varios</a></li>
            </ul>
        </div>
    </div>

    <!-- Stats Summary -->
    <div class="row g-4 mb-4">
        <div class="col-xl-4 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="p-3 bg-blue-100 rounded-lg me-3">
                            <i data-lucide="box" class="w-6 h-6 text-blue-600"></i>
                        </div>
                        <div>
                            <p class="text-sm font-medium text-slate-500 mb-0">Total Artículos</p>
                            <h3 class="mb-0 fw-bold">{{ stats.total_items }}</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="p-3 bg-red-100 rounded-lg me-3">
                            <i data-lucide="alert-triangle" class="w-6 h-6 text-red-600"></i>
                        </div>
                        <div>
                            <p class="text-sm font-medium text-slate-500 mb-0">Bajo Stock</p>
                            <h3 class="mb-0 fw-bold">{{ stats.low_stock }}</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="p-3 bg-green-100 rounded-lg me-3">
                            <i data-lucide="truck" class="w-6 h-6 text-green-600"></i>
                        </div>
                        <div>
                            <p class="text-sm font-medium text-slate-500 mb-0">Flota Operativa</p>
                            <h3 class="mb-0 fw-bold">{{ stats.total_vehicles }}</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Valuation and Full Traceability Section -->
    <div class="row g-4 mb-4">
        <div class="col-xl-12">
            <div class="card border-0 shadow-sm border-start border-4 border-indigo">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-md-3 border-end">
                            <p class="text-sm font-medium text-slate-500 mb-1">Valoración Total del Inventario</p>
                            <h2 class="fw-bold text-indigo-600 mb-0">{{ stats.total_valuation|number_format(2, ',', '.') }}€</h2>
                            <p class="text-xs text-muted mt-2">Calculado como Stock Total * Precio Unitario</p>
                        </div>
                        <div class="col-md-9 ps-md-4">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="fw-bold mb-0">Distribución de Stock por Ubicación (Muestra)</h6>
                                <a href="{{ path('app_material_index') }}" class="small text-decoration-none">Ver todo el inventario</a>
                            </div>
                            <div class="table-responsive" style="max-height: 250px; overflow-y: auto;">
                                <table class="table table-sm table-hover mb-0">
                                    <thead class="sticky-top bg-white">
                                        <tr class="text-xs text-muted">
                                            <th>Producto</th>
                                            <th>Stock Total</th>
                                            <th>Desglose por Ubicación</th>
                                            <th>Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody class="text-sm">
                                        {% for material in materials|slice(0, 15) %}
                                        <tr>
                                            <td class="fw-bold">{{ material.name }}</td>
                                            <td>
                                                <span class="badge {{ material.isLowStock ? 'bg-danger' : 'bg-success' }}">
                                                    {% if material.nature == 'CONSUMIBLE' %}
                                                        {{ material.stock }}
                                                    {% else %}
                                                        {{ material.units|length }}
                                                    {% endif %}
                                                </span>
                                            </td>
                                            <td>
                                                {% set loc_totals = {} %}
                                                {% if material.nature == 'CONSUMIBLE' %}
                                                    {% for stock in material.stocks %}
                                                        {% set loc_name = stock.location.name %}
                                                        {% set loc_totals = loc_totals|merge({ (loc_name): (loc_totals[loc_name] ?? 0) + stock.quantity }) %}
                                                    {% endfor %}
                                                {% else %}
                                                    {% for unit in material.units %}
                                                        {% set loc_name = unit.location.name|default('Sin ubicación') %}
                                                        {% set loc_totals = loc_totals|merge({ (loc_name): (loc_totals[loc_name] ?? 0) + 1 }) %}
                                                    {% endfor %}
                                                {% endif %}

                                                <div class="d-flex flex-wrap gap-1">
                                                    {% for loc, qty in loc_totals %}
                                                        {% if qty > 0 %}
                                                            <span class="badge border font-normal {{ loc == 'Almacén Central' or loc == 'Almacén Farmacia' or loc == 'Almacén CECOM' ? 'bg-primary-subtle text-primary border-primary-subtle' : 'bg-light text-slate-600 border-slate-100' }}">
                                                                <i data-lucide="{{ loc == 'Almacén Central' or loc == 'Almacén Farmacia' or loc == 'Almacén CECOM' ? 'warehouse' : 'briefcase' }}" class="w-2 h-2 inline me-0.5 opacity-50"></i>
                                                                {{ loc }}: <span class="font-bold">{{ qty }}</span>
                                                            </span>
                                                        {% endif %}
                                                    {% else %}
                                                        <span class="text-muted small italic">Sin existencias en ubicaciones</span>
                                                    {% endfor %}
                                                </div>
                                            </td>
                                            <td>
                                                <a href="{{ path('app_material_show', {id: material.id}) }}" class="btn btn-xs btn-link p-0 text-decoration-none">
                                                    <i data-lucide="eye" class="w-3 h-3 me-1"></i>Ver
                                                </a>
                                            </td>
                                        </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scheduled Reviews and Traceability Actions -->
    <div class="row g-4 mb-4">
        <div class="col-xl-7">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3 border-0">
                    <div class="d-flex justify-content-between align-items-center">
                        <h6 class="fw-bold mb-0 text-slate-900">
                            <i data-lucide="clipboard-check" class="w-4 h-4 me-2 text-primary"></i>
                            Revisiones Programadas y Auditoría
                        </h6>
                        <button class="btn btn-sm btn-outline-primary" onclick="alert('Nueva revisión próximamente')">Nueva Revisión</button>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr class="text-xs text-muted text-uppercase">
                                    <th class="ps-3 py-3">Ubicación</th>
                                    <th>Fecha</th>
                                    <th>Resultado</th>
                                    <th>Próxima Alerta</th>
                                    <th>Responsable</th>
                                </tr>
                            </thead>
                            <tbody class="text-sm">
                                {% for review in recent_reviews %}
                                <tr>
                                    <td class="ps-3 fw-medium">
                                        {% if review.location.type == 'VEHICULO' %}
                                            <i data-lucide="truck" class="w-3 h-3 me-1 text-warning"></i>
                                        {% elseif review.location.type == 'KIT' %}
                                            <i data-lucide="briefcase" class="w-3 h-3 me-1 text-info"></i>
                                        {% endif %}
                                        {{ review.location.name }}
                                    </td>
                                    <td>{{ review.reviewDate|date('d/m/Y') }}</td>
                                    <td>
                                        <span class="badge {{ review.result == 'CONFORME' ? 'bg-success-subtle text-success' : 'bg-danger-subtle text-danger' }} rounded-pill px-3">
                                            {{ review.result }}
                                        </span>
                                    </td>
                                    <td class="fw-bold {{ review.nextReviewDate < date() ? 'text-danger' : 'text-slate-600' }}">
                                        {{ review.nextReviewDate|date('d/m/Y') }}
                                    </td>
                                    <td class="text-muted small">{{ review.responsible.name|default('S/A') }}</td>
                                </tr>
                                {% else %}
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        <i data-lucide="info" class="w-8 h-8 mb-2 opacity-25"></i>
                                        <p class="mb-0">No hay revisiones registradas en el sistema</p>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-5">
             <div class="card border-0 shadow-sm h-100 bg-primary text-white overflow-hidden position-relative">
                <div class="card-body d-flex flex-column justify-content-center p-4 position-relative" style="z-index: 2;">
                    <h5 class="fw-bold mb-2">Sistema de Trazabilidad</h5>
                    <p class="text-white text-opacity-75 mb-4">Gestiona movimientos entre el Almacén Central, Vehículos, Mochilas y Desplegados con trazabilidad completa por Responsable y Lote/Serie.</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a href="{{ path('app_material_index') }}" class="btn btn-white text-primary fw-bold px-4 shadow-sm">
                            <i data-lucide="move" class="w-4 h-4 me-2"></i>Nueva Transferencia
                        </a>
                        <a href="{{ path('app_material_index') }}" class="btn btn-outline-light px-4 border-2">
                            <i data-lucide="trash-2" class="w-4 h-4 me-2"></i>Registrar Consumo
                        </a>
                    </div>
                </div>
                <i data-lucide="arrow-right-left" class="position-absolute end-0 bottom-0 text-white opacity-10" style="width: 200px; height: 200px; margin-right: -50px; margin-bottom: -50px;"></i>
            </div>
        </div>
    </div>

    <!-- Global Inventory Breakdown by Location -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3 border-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 text-slate-900">
                        <i data-lucide="map-pin" class="w-5 h-5 me-2 text-indigo-600"></i>
                        Inventario Global por Ubicación
                    </h5>
                    <span class="badge bg-indigo-100 text-indigo-600 px-3 py-2 rounded-pill">Total: {{ locations|length }} Ubicaciones</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light dark:bg-slate-800">
                                <tr class="text-xs text-muted text-uppercase">
                                    <th class="ps-4 py-3">Ubicación</th>
                                    <th>Tipo</th>
                                    <th>Total Consumibles (Uds)</th>
                                    <th>Total Equipos Técnicos</th>
                                    <th class="text-end pe-4">Acciones</th>
                                </tr>
                            </thead>
                            <tbody class="text-sm dark:text-slate-100">
                                {% set global_consumables = 0 %}
                                {% set global_technical = 0 %}

                                {% for loc in locations|sort((a, b) => a.type <=> b.type) %}
                                    {% set loc_consumables = 0 %}
                                    {% for s in loc.stocks %}
                                        {% if s.material.nature == 'CONSUMIBLE' %}
                                            {% set loc_consumables = loc_consumables + s.quantity %}
                                        {% endif %}
                                    {% endfor %}

                                    {% set loc_technical = 0 %}
                                    {% for unit in loc.units %}
                                        {# technical units are strictly separated from consumable stocks #}
                                        {% set loc_technical = loc_technical + 1 %}
                                    {% endfor %}

                                    {% set global_consumables = global_consumables + loc_consumables %}
                                    {% set global_technical = global_technical + loc_technical %}

                                    <tr>
                                        <td class="ps-4 py-3">
                                            <div class="d-flex align-items-center">
                                                <div class="p-2 rounded bg-{{ loc.type == 'ALMACEN' ? 'primary' : (loc.type == 'KIT' ? 'info' : (loc.type == 'VEHICULO' ? 'warning' : 'secondary')) }} bg-opacity-10 me-3">
                                                    <i data-lucide="{{ loc.type == 'ALMACEN' ? 'warehouse' : (loc.type == 'KIT' ? 'briefcase' : (loc.type == 'VEHICULO' ? 'truck' : 'map-pin')) }}"
                                                       class="w-4 h-4 text-{{ loc.type == 'ALMACEN' ? 'primary' : (loc.type == 'KIT' ? 'info' : (loc.type == 'VEHICULO' ? 'warning' : 'secondary')) }}"></i>
                                                </div>
                                                <div>
                                                    <span class="fw-bold d-block">{{ loc.name }}</span>
                                                    {% if loc.type == 'KIT' and loc.materialUnit %}
                                                        <small class="text-muted">ID: {{ loc.materialUnit.alias ?: loc.materialUnit.serialNumber }}</small>
                                                    {% endif %}
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge bg-light text-slate-600 border border-slate-200">
                                                {{ loc.type }}
                                            </span>
                                        </td>
                                        <td>
                                            <span class="fw-medium {{ loc_consumables > 0 ? 'text-slate-900' : 'text-muted opacity-50' }}">
                                                {{ loc_consumables|number_format(0, ',', '.') }}
                                            </span>
                                        </td>
                                        <td>
                                            <span class="fw-medium {{ loc_technical > 0 ? 'text-slate-900' : 'text-muted opacity-50' }}">
                                                {{ loc_technical|number_format(0, ',', '.') }}
                                            </span>
                                        </td>
                                        <td class="text-end pe-4">
                                            {% if loc.type == 'KIT' and loc.materialUnit %}
                                                <a href="{{ path('app_kit_inventory', {id: loc.materialUnit.id}) }}" class="btn btn-xs btn-outline-primary">
                                                    Ver Inventario
                                                </a>
                                            {% elseif loc.type == 'VEHICULO' and loc.vehicle %}
                                                <a href="{{ path('app_vehicle_show', {id: loc.vehicle.id}) }}" class="btn btn-xs btn-outline-primary">
                                                    Ver Ficha
                                                </a>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                            <tfoot class="bg-indigo-50 dark:bg-indigo-900 bg-opacity-50">
                                <tr class="fw-bold text-indigo-900 dark:text-indigo-100">
                                    <td colspan="2" class="ps-4 py-3">TOTAL GLOBAL</td>
                                    <td>{{ global_consumables|number_format(0, ',', '.') }} uds</td>
                                    <td>{{ global_technical|number_format(0, ',', '.') }} equipos</td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sections Grid -->
    <h5 class="fw-bold mb-3">Secciones del Almacén</h5>
    <div class="row g-4">
        {% for name, config in categories %}
        <div class="col-xl-3 col-lg-4 col-md-6">
            <a href="{{ path('app_material_index', {category: name}) }}" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 hover-shadow transition-all">
                    <div class="card-body text-center p-4">
                        <div class="w-16 h-16 bg-{{ config.color }}-100 rounded-circle d-flex align-items-center justify-center mx-auto mb-3 text-{{ config.color }}-600">
                            <i data-lucide="{{ config.icon }}" class="w-8 h-8"></i>
                        </div>
                        <h5 class="fw-bold text-slate-900 mb-1">{{ name }}</h5>
                        <p class="text-sm text-slate-500 mb-2">{{ config.count }} artículos registrados</p>
                        {% if config.low_stock > 0 %}
                            <span class="badge bg-danger rounded-pill">
                                <i data-lucide="alert-circle" class="w-3 h-3 me-1"></i>
                                {{ config.low_stock }} bajo stock
                            </span>
                        {% else %}
                            <span class="badge bg-success rounded-pill">
                                <i data-lucide="check" class="w-3 h-3 me-1"></i>
                                Stock OK
                            </span>
                        {% endif %}
                    </div>
                </div>
            </a>
        </div>
        {% endfor %}

        <!-- Special Card for Vehicles -->
        <div class="col-xl-3 col-lg-4 col-md-6">
            <a href="{{ path('app_vehicle_index') }}" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 hover-shadow transition-all border-top border-4 border-warning">
                    <div class="card-body text-center p-4">
                        <div class="w-16 h-16 bg-warning bg-opacity-10 rounded-circle d-flex align-items-center justify-center mx-auto mb-3 text-warning">
                            <i data-lucide="truck" class="w-8 h-8"></i>
                        </div>
                        <h5 class="fw-bold text-slate-900 mb-1">Vehículos</h5>
                        <p class="text-sm text-slate-500 mb-1">Control de flota y mantenimiento</p>
                        <span class="badge bg-warning text-dark">{{ vehicle_count }} unidades</span>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>

<style>
    .dropdown-menu {
        z-index: 1070 !important;
    }
    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.175)!important;
    }
    .transition-all {
        transition: all 0.3s ease;
    }
    .bg-red-100 { background-color: #fee2e2; }
    .text-red-600 { color: #dc2626; }
    .bg-blue-100 { background-color: #dbeafe; }
    .text-blue-600 { color: #2563eb; }
    .bg-amber-100 { background-color: #fef3c7; }
    .text-amber-600 { color: #d97706; }
    .bg-cyan-100 { background-color: #cffafe; }
    .text-cyan-600 { color: #0891b2; }
    .bg-indigo-100 { background-color: #e0e7ff; }
    .text-indigo-600 { color: #4f46e5; }
    .bg-slate-100 { background-color: #f1f5f9; }
    .text-slate-600 { color: #475569; }
</style>
{% endblock %}
