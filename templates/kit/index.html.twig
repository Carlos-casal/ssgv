{% extends 'layout/app.html.twig' %}

{% block title %}Botiquines Registrados{% endblock %}

{% block page_title %}
    <div class="d-flex justify-content-between align-items-center w-100">
        <div class="d-flex align-items-center">
            <i data-lucide="briefcase" class="w-6 h-6 text-blue-600 mr-2"></i>
            <span class="font-black tracking-tight uppercase">BOTIQUINES FÍSICOS REGISTRADOS</span>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_kit_template_index') }}" class="btn btn-outline-secondary btn-sm px-3">
                <i data-lucide="layout" class="w-4 h-4 inline mr-1"></i> GESTIONAR PLANTILLAS
            </a>
            <a href="{{ path('app_kit_new') }}" class="btn btn-primary btn-sm px-4 shadow-sm font-bold">
                <i data-lucide="plus" class="w-4 h-4 inline mr-1"></i> REGISTRAR NUEVO BOTIQUÍN
            </a>
        </div>
    </div>
{% endblock %}

{% block content %}
<div class="container-fluid px-4">
    <div class="row g-4">
        {% for kit in kits %}
            <div class="col-md-4 col-lg-3">
                <div class="card border-0 shadow-sm rounded-3 overflow-hidden h-100 hover:shadow-md transition-shadow">
                    <div class="bg-blue-600 p-3 flex items-center justify-between text-white relative group">
                        <div class="flex flex-col">
                            <span class="text-[10px] font-black uppercase tracking-widest text-blue-200">{{ kit.template.name }}</span>
                            <span class="text-[8px] font-bold uppercase text-blue-300">{{ kit.template.containerType }}</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="px-2 py-0.5 bg-blue-500 rounded text-[9px] font-black uppercase text-white">{{ kit.operationalStatus }}</span>
                            <button type="button"
                                    class="text-blue-200 hover:text-white transition-colors"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteKitModal"
                                    onclick="document.getElementById('deleteKitForm').action = '{{ path('app_kit_delete', {id: kit.id}) }}'; document.getElementById('deleteKitName').textContent = '{{ kit.alias ?: 'este botiquín' }}';">
                                <i data-lucide="trash-2" class="w-3.5 h-3.5"></i>
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-4 text-center">
                        <div class="bg-slate-50 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-3 border border-slate-100">
                            <i data-lucide="package" class="w-8 h-8 text-slate-400"></i>
                        </div>
                        <h4 class="font-black text-slate-800 dark:text-slate-100 mb-1">{{ kit.alias ?: 'Botiquín' }}</h4>
                        <p class="text-xs text-slate-400 dark:text-slate-400 font-monospace mb-4">{{ kit.serialNumber ?: 'S/N' }}</p>

                        <div class="d-grid gap-2">
                            <a href="{{ path('app_kit_inventory', {id: kit.id}) }}" class="btn btn-primary btn-sm rounded-pill font-bold shadow-sm">
                                <i data-lucide="clipboard-list" class="w-3.5 h-3.5 inline mr-1"></i> VER INVENTARIO
                            </a>
                            <a href="{{ path('app_kit_edit', {id: kit.id}) }}" class="btn btn-outline-amber btn-sm rounded-pill font-bold border-amber-200 text-amber-600 hover:bg-amber-50">
                                <i data-lucide="edit-3" class="w-3.5 h-3.5 inline mr-1"></i> EDITAR IDENTIDAD
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center py-5">
                <div class="bg-slate-50 rounded-2xl p-10 border border-slate-100 max-w-lg mx-auto">
                    <i data-lucide="package" class="w-16 h-16 text-slate-200 mx-auto mb-4"></i>
                    <h3 class="font-black text-slate-400 mb-2 uppercase tracking-tight">No hay botiquines registrados</h3>
                    <p class="text-slate-400 text-sm mb-6">Empieza registrando un botiquín físico basándote en una plantilla predefinida.</p>
                    <a href="{{ path('app_kit_new') }}" class="btn btn-primary px-5 font-black uppercase shadow-sm">REGISTRAR PRIMER BOTIQUÍN</a>
                </div>
            </div>
        {% endfor %}
    </div>
</div>

{# Delete Confirmation Modal #}
<div class="modal fade" id="deleteKitModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-2xl rounded-4 overflow-hidden bg-white dark:bg-slate-900">
            <div class="p-4 text-end">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="px-5 pb-5 text-center">
                <div class="w-20 h-20 bg-red-50 dark:bg-red-500/10 rounded-full flex items-center justify-center mx-auto mb-6">
                    <i data-lucide="alert-triangle" class="w-10 h-10 text-red-600 dark:text-red-500"></i>
                </div>
                <h3 class="text-xl font-black text-slate-800 dark:text-slate-100 mb-3 uppercase tracking-tight">¿ELIMINAR BOTIQUÍN?</h3>
                <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed mb-8">
                    Estás a punto de eliminar el botiquín <strong id="deleteKitName" class="text-slate-800 dark:text-slate-200"></strong>.
                    Esta acción es permanente y se perderá toda la información de su stock actual.
                </p>

                <div class="flex gap-3 justify-center">
                    <button type="button" class="btn btn-light px-5 py-2.5 rounded-3 font-bold text-slate-400 uppercase text-xs tracking-widest" data-bs-dismiss="modal">
                        CANCELAR
                    </button>
                    <form id="deleteKitForm" method="POST">
                        {% for kit in kits %}
                            <input type="hidden" id="token-{{ kit.id }}" value="{{ csrf_token('delete_kit_' ~ kit.id) }}">
                        {% endfor %}
                        <input type="hidden" name="_token" id="deleteKitToken">
                        <button type="submit" class="btn btn-danger px-5 py-2.5 rounded-3 font-black text-white uppercase text-xs tracking-widest shadow-lg shadow-red-500/20"
                                onclick="const action = this.form.action; const parts = action.split('/'); const kitId = parts[parts.length - 2]; document.getElementById('deleteKitToken').value = document.getElementById('token-' + kitId).value;">
                            ELIMINAR DEFINITIVAMENTE
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}
