{% extends 'layout/app.html.twig' %}

{% block title %}Confirmar Registro: {{ alias ?: 'Nuevo Botiquín' }}{% endblock %}

{% block page_title %}
    <div class="d-flex align-items-center">
        <i data-lucide="check-circle" class="w-6 h-6 text-green-600 mr-2"></i>
        <span class="font-black tracking-tight uppercase">VISTA PREVIA Y CONFIRMACIÓN</span>
    </div>
{% endblock %}

{% block content %}
<div class="container-fluid px-4">
    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden dark:bg-slate-800">
                <div class="bg-blue-600 p-4 text-white">
                    <h5 class="text-xs font-black uppercase tracking-widest text-blue-200 m-0">RESUMEN DEL DISPOSITIVO</h5>
                </div>
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <div class="bg-blue-50 dark:bg-blue-900/30 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-3">
                            <i data-lucide="briefcase" class="w-10 h-10 text-blue-600 dark:text-blue-400"></i>
                        </div>
                        <h3 class="font-black text-slate-800 dark:text-slate-100 mb-1 uppercase tracking-tight">{{ alias ?: 'BOTIQUÍN SIN ALIAS' }}</h3>
                        <p class="text-slate-400 dark:text-slate-500 text-xs font-monospace uppercase">{{ serial_number ?: 'Sin número de serie' }}</p>
                    </div>

                    <div class="space-y-3">
                        <div class="flex justify-between items-center py-2 border-b border-slate-50 dark:border-slate-700">
                            <span class="text-xs font-bold text-slate-400 uppercase">Plantilla</span>
                            <span class="text-sm font-black text-slate-700 dark:text-slate-300">{{ template.name }}</span>
                        </div>
                        <div class="flex justify-between items-center py-2 border-b border-slate-50 dark:border-slate-700">
                            <span class="text-xs font-bold text-slate-400 uppercase">Contenedor</span>
                            <span class="text-sm font-black text-slate-700 dark:text-slate-300">{{ template.containerType }}</span>
                        </div>
                        <div class="flex justify-between items-center py-2">
                            <span class="text-xs font-bold text-slate-400 uppercase">Estado Inicial</span>
                            <span class="px-2 py-0.5 bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 rounded text-[9px] font-black uppercase">OPERATIVO</span>
                        </div>
                    </div>
                </div>
            </div>

            <form action="{{ path('app_kit_create_confirm') }}" method="POST">
                <input type="hidden" name="_token" value="{{ csrf_token('kit_create_confirm') }}">
                <input type="hidden" name="template_id" value="{{ template.id }}">
                <input type="hidden" name="alias" value="{{ alias }}">
                <input type="hidden" name="serial_number" value="{{ serial_number }}">

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary btn-lg rounded-3 font-black uppercase tracking-widest shadow-lg shadow-blue-500/20 py-3">
                        CONFIRMAR Y REGISTRAR <i data-lucide="chevron-right" class="w-5 h-5 inline ml-1"></i>
                    </button>
                    <a href="{{ path('app_kit_new') }}" class="btn btn-link text-slate-400 text-xs font-bold uppercase text-decoration-none py-2">
                        <i data-lucide="arrow-left" class="w-3 h-3 inline mr-1"></i> Volver a edición
                    </a>
                </div>
            </form>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 dark:bg-slate-800">
                <div class="card-header bg-white dark:bg-slate-800 py-4 px-5 border-bottom border-slate-100 dark:border-slate-700">
                    <h5 class="text-xs font-black uppercase tracking-widest text-slate-400 m-0">Contenido Según Plantilla ({{ template.items|length }} productos)</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0 dark:text-slate-200">
                            <thead class="bg-slate-50 dark:bg-slate-900/80">
                                <tr>
                                    <th class="ps-5 text-[10px] font-black uppercase text-slate-400 border-0">Material / Consumible</th>
                                    <th class="text-[10px] font-black uppercase text-slate-400 border-0">Categoría</th>
                                    <th class="text-[10px] font-black uppercase text-slate-400 border-0 text-end pe-5" style="width: 150px;">Cant. Ideal</th>
                                </tr>
                            </thead>
                            <tbody class="dark:border-slate-700">
                                {% for item in template.items %}
                                    <tr class="dark:bg-slate-800/50 dark:border-slate-700">
                                        <td class="ps-5 py-3">
                                            <div class="font-bold text-slate-800 dark:text-slate-100">{{ item.material.name }}</div>
                                            <div class="text-[9px] text-slate-400 dark:text-slate-500 uppercase font-black">{{ item.material.nature }}</div>
                                        </td>
                                        <td class="py-3">
                                            <span class="px-2 py-1 bg-slate-100 dark:bg-slate-900/50 rounded text-[9px] font-black uppercase text-slate-500 dark:text-slate-400">{{ item.material.category }}</span>
                                        </td>
                                        <td class="pe-5 py-3 text-end font-monospace font-black text-blue-600 dark:text-blue-400">
                                            {{ item.quantity }} <small class="text-slate-400 text-[10px]">uds.</small>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-slate-50 dark:bg-slate-900/20 p-4 px-5 border-top border-slate-100 dark:border-slate-700">
                    <div class="flex items-center gap-3">
                        <i data-lucide="info" class="w-5 h-5 text-blue-500"></i>
                        <p class="text-xs text-slate-500 dark:text-slate-400 m-0">
                            Al confirmar, se creará el registro del botiquín y se te redirigirá automáticamente a la <strong>Propuesta de Carga</strong> para transferir estos materiales desde el Almacén Central.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
