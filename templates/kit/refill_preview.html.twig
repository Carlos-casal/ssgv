{% extends 'layout/app.html.twig' %}

{% block title %}Propuesta de Carga: {{ unit.alias ?: unit.serialNumber }}{% endblock %}

{% block page_title %}
    <div class="d-flex align-items-center w-100">
        <i data-lucide="refresh-cw" class="w-6 h-6 text-blue-600 mr-2"></i>
        <span class="font-black tracking-tight uppercase">PROPUESTA DE CARGA / REPOSICIÓN</span>
    </div>
{% endblock %}

{% block content %}
<div class="container-fluid px-4">
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-3 mb-4">
                <div class="card-header bg-white py-3 border-bottom border-slate-100 d-flex justify-content-between align-items-center">
                    <h5 class="text-xs font-black uppercase tracking-widest text-blue-600 m-0">Transferencias Propuestas (FIFO)</h5>
                    <span class="badge bg-blue-50 text-blue-600 font-black px-3 py-1 rounded-pill">{{ proposals|length }} MOVIMIENTOS</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="bg-slate-50">
                                <tr>
                                    <th class="ps-4 text-[10px] font-black uppercase text-slate-400 border-0">Material</th>
                                    <th class="text-[10px] font-black uppercase text-slate-400 border-0">Identificación (Lote/Serie)</th>
                                    <th class="text-[10px] font-black uppercase text-slate-400 border-0">Caducidad</th>
                                    <th class="text-[10px] font-black uppercase text-slate-400 border-0 text-end pe-4">Cantidad</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% set proposals_json = [] %}
                                {% for p in proposals %}
                                    {% set proposals_json = proposals_json|merge([{
                                        'material_id': p.material.id,
                                        'origin_id': p.origin.id,
                                        'quantity': p.quantity,
                                        'batch_id': p.batch ? p.batch.id : null,
                                        'unit_id': p.unit ? p.unit.id : null
                                    }]) %}
                                    <tr>
                                        <td class="ps-4">
                                            <div class="font-bold text-slate-800">{{ p.material.name }}</div>
                                            <div class="text-[9px] text-slate-400 uppercase font-black">{{ p.material.category }}</div>
                                        </td>
                                        <td>
                                            {% if p.batch is defined and p.batch is not null %}
                                                <span class="badge bg-slate-100 text-slate-600 font-mono">LOTE: {{ p.batch.batchNumber }}</span>
                                            {% elseif p.unit is defined and p.unit is not null %}
                                                <span class="badge bg-blue-50 text-blue-600 font-mono">S/N: {{ p.unit.serialNumber }}</span>
                                                {% if p.unit.alias %}
                                                    <div class="text-[10px] text-blue-400 font-bold mt-1">Alias: {{ p.unit.alias }}</div>
                                                {% endif %}
                                            {% else %}
                                                <span class="text-slate-400 italic">Genérico (Sin lote)</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% set expDate = p.batch ? p.batch.expirationDate : (p.unit ? p.unit.material.expirationDate : null) %}
                                            {% if expDate %}
                                                <span class="text-xs font-bold {{ expDate < date() ? 'text-red-500' : 'text-slate-600' }}">
                                                    {{ expDate|date('d/m/Y') }}
                                                </span>
                                            {% else %}
                                                <span class="text-slate-300">-</span>
                                            {% endif %}
                                        </td>
                                        <td class="text-end pe-4 font-monospace font-bold">
                                            {{ p.quantity }}
                                        </td>
                                    </tr>
                                {% else %}
                                    {% if shortages|length == 0 %}
                                        <tr>
                                            <td colspan="4" class="text-center py-5">
                                                <div class="text-green-500 mb-2"><i data-lucide="check-circle" class="w-8 h-8 mx-auto"></i></div>
                                                <div class="font-black text-slate-400 uppercase tracking-tight">El botiquín ya está completo según su plantilla</div>
                                            </td>
                                        </tr>
                                    {% else %}
                                        <tr>
                                            <td colspan="4" class="text-center py-5 text-slate-400 italic">No hay transferencias posibles desde el almacén central para cubrir las faltas.</td>
                                        </tr>
                                    {% endif %}
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
                {% if proposals|length > 0 %}
                    <div class="card-footer bg-slate-50 p-4 border-top border-slate-100 d-flex justify-content-end">
                        <form action="{{ path('app_kit_refill_confirm', {id: unit.id}) }}" method="POST">
                            <input type="hidden" name="_token" value="{{ csrf_token('kit_refill_confirm') }}">
                            <input type="hidden" name="proposals_data" value="{{ proposals_json|json_encode }}">
                            <button type="submit" class="btn btn-primary px-5 font-black uppercase shadow-md">
                                <i data-lucide="send" class="w-4 h-4 inline mr-2"></i> CONFIRMAR Y TRASLADAR
                            </button>
                        </form>
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-3 mb-4 bg-red-50 border-start border-red-200" style="border-width: 0 0 0 4px !important;">
                <div class="card-header bg-transparent py-3 border-bottom border-red-100">
                    <h5 class="text-xs font-black uppercase tracking-widest text-red-600 m-0">Faltas de Stock (Almacén Central)</h5>
                </div>
                <div class="card-body p-4">
                    {% for s in shortages %}
                        <div class="mb-4 last:mb-0">
                            <div class="flex justify-between items-start mb-2">
                                <div>
                                    <div class="font-black text-slate-800 uppercase leading-none text-red-600">{{ s.material.name }}</div>
                                    <div class="text-[11px] text-red-400 font-black mt-1">FALTAN {{ s.needed }} UNIDADES</div>
                                </div>
                            </div>

                            {% if s.alternatives %}
                                <div class="bg-white rounded-lg p-2 border border-red-100 shadow-sm mt-2">
                                    <div class="text-[9px] font-black text-slate-400 uppercase mb-2">DISPONIBLE EN OTRAS UBICACIONES:</div>
                                    {% for alt in s.alternatives %}
                                        <div class="flex justify-between items-center text-xs mb-1 last:mb-0">
                                            <span class="text-slate-600"><i data-lucide="{{ alt.type == 'KIT' ? 'briefcase' : 'truck' }}" class="w-3 h-3 inline mr-1"></i> {{ alt.location }}</span>
                                            <span class="font-bold text-blue-600">{{ alt.quantity }}</span>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <div class="text-[9px] text-slate-400 italic">No hay stock disponible en ninguna otra ubicación.</div>
                            {% endif %}
                        </div>
                    {% else %}
                        <div class="text-center py-4">
                            <i data-lucide="check-circle" class="w-8 h-8 text-green-500 mx-auto mb-2"></i>
                            <div class="text-xs font-bold text-slate-500 uppercase">Stock suficiente en almacén</div>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white py-3 border-bottom border-slate-100">
                    <h5 class="text-xs font-black uppercase tracking-widest text-slate-400 m-0">Resumen de Operación</h5>
                </div>
                <div class="card-body p-4">
                    <div class="text-sm mb-3">
                        <strong class="text-slate-600">Destino:</strong><br>
                        <span class="font-bold text-blue-600">{{ unit.alias ?: unit.serialNumber }}</span>
                    </div>
                    <div class="text-sm mb-3">
                        <strong class="text-slate-600">Origen Principal:</strong><br>
                        <span class="font-bold text-slate-800">Almacén Central</span>
                    </div>
                    <hr class="my-4 border-slate-100">
                    <a href="{{ path('app_kit_inventory', {id: unit.id}) }}" class="btn btn-outline-secondary w-100 rounded-pill font-bold">
                        CANCELAR Y VOLVER
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
