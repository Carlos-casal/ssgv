{% extends 'layout/app.html.twig' %}

{% block title %}
    {% if is_new|default(false) %}
        Propuesta de Carga: {{ unit.alias ?: unit.serialNumber }} (NUEVO)
    {% else %}
        Propuesta de Carga: {{ unit.alias ?: unit.serialNumber }}
    {% endif %}
{% endblock %}

{% block page_title %}
    <div class="d-flex align-items-center w-100">
        <i data-lucide="refresh-cw" class="w-6 h-6 text-blue-600 mr-2"></i>
        <span class="font-black tracking-tight uppercase">
            {% if is_new|default(false) %}
                REGISTRO Y CARGA DE NUEVO BOTIQUÍN
            {% else %}
                PROPUESTA DE CARGA / REPOSICIÓN
            {% endif %}
        </span>
    </div>
{% endblock %}

{% block content %}
<div class="container-fluid px-4" data-controller="kit-refill" data-kit-refill-origin-id-value="{{ centralWarehouse.id }}">
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-3 mb-4 dark:bg-slate-800">
                <div class="card-header bg-white dark:bg-slate-800 py-3 border-bottom border-slate-100 dark:border-slate-700 d-flex justify-content-between align-items-center">
                    <h5 class="text-xs font-black uppercase tracking-widest text-blue-600 dark:text-blue-400 m-0">Transferencias Propuestas (FIFO)</h5>
                    <button type="button" class="btn btn-outline-primary btn-sm" data-action="kit-refill#addRow">
                         <i data-lucide="plus" class="w-3 h-3 inline"></i> AÑADIR MANUAL
                    </button>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="bg-slate-50 dark:bg-slate-900/50">
                                <tr>
                                    <th class="ps-4 text-[10px] font-black uppercase text-slate-400 border-0">Material / Alias</th>
                                    <th class="text-[10px] font-black uppercase text-slate-400 border-0">Lote / Unidad</th>
                                    <th class="text-[10px] font-black uppercase text-slate-400 border-0 text-end pe-4" style="width: 150px;">Cantidad</th>
                                    <th class="border-0" style="width: 50px;"></th>
                                </tr>
                            </thead>
                            <tbody data-kit-refill-target="container">
                                {# Existing Contents (Non-editable, just for context) #}
                                {% for item in currentContents %}
                                    <tr class="bg-blue-50/30 dark:bg-blue-900/10">
                                        <td class="ps-4">
                                            <div class="font-bold text-blue-800 dark:text-blue-300">
                                                {% if item.unit and item.unit.alias %}
                                                    {{ item.unit.alias }} <span class="text-blue-400 text-[10px] font-normal">({{ item.material.name }})</span>
                                                {% else %}
                                                    {{ item.material.name }}
                                                {% endif %}
                                                <span class="ms-2 badge bg-blue-100 text-blue-600 text-[9px] uppercase">EN BOTIQUÍN</span>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="text-xs text-slate-500">
                                                {% if item.material.nature == 'CONSUMIBLE' %}
                                                    {{ item.batch ? 'Lote: ' ~ item.batch.batchNumber : 'Sin Lote' }}
                                                {% else %}
                                                    {{ item.unit.serialNumber ?: 'S/N' }}
                                                {% endif %}
                                            </span>
                                        </td>
                                        <td class="pe-4 text-end">
                                            <span class="font-black text-blue-700 dark:text-blue-400">{{ item.quantity }} uds.</span>
                                        </td>
                                        <td></td>
                                    </tr>
                                {% endfor %}

                                {% for p in proposals %}
                                    <tr class="refill-row {{ p.placeholder|default(false) ? 'opacity-75' : '' }}"
                                        data-material-id="{{ p.material.id }}"
                                        data-nature="{{ p.material.nature }}"
                                        style="{{ p.placeholder|default(false) ? 'border-left: 3px solid #f87171;' : '' }}">
                                        <td class="ps-4">
                                            <div class="font-bold text-slate-800 dark:text-slate-200">
                                                {% if p.unit and p.unit.alias %}
                                                    {{ p.unit.alias }} <span class="text-slate-400 text-[10px] font-normal">({{ p.material.name }})</span>
                                                {% else %}
                                                    {{ p.material.name }}
                                                {% endif %}
                                            </div>
                                            <div class="text-[9px] text-slate-400 dark:text-slate-500 uppercase font-black">{{ p.material.category }}</div>
                                            <input type="hidden" class="material-id" value="{{ p.material.id }}">
                                        </td>
                                        <td>
                                            <select class="form-select form-select-sm identifier-select dark:bg-slate-900/50 dark:border-slate-700 dark:text-slate-300" data-action="change->kit-refill#updateAvailable">
                                                {% set target_id = null %}
                                                {% if p.material.nature == 'CONSUMIBLE' %}
                                                    {% set target_id = p.batch ? p.batch.id : 'NO_BATCH' %}
                                                {% else %}
                                                    {% set target_id = p.unit ? p.unit.id : null %}
                                                {% endif %}

                                                {% if not target_id or (p.placeholder|default(false)) %}
                                                    {# Placeholder or missing: find first available #}
                                                    {% set found_avail = false %}
                                                    {% for opt in warehouseOptions[p.material.id] %}
                                                        {% if not found_avail and not opt.busy|default(false) %}
                                                            {% set target_id = opt.id %}
                                                            {% set found_avail = true %}
                                                        {% endif %}
                                                    {% endfor %}
                                                {% endif %}

                                                {% for opt in warehouseOptions[p.material.id] %}
                                                    <option value="{{ opt.id }}"
                                                            data-available="{{ opt.available }}"
                                                            data-busy="{{ opt.busy|default(false) ? 'true' : 'false' }}"
                                                            data-location-name="{{ opt.locationName|default('') }}"
                                                            style="{{ opt.busy|default(false) ? 'color: #f87171 !important; font-weight: bold;' : '' }}"
                                                            {{ opt.id == target_id ? 'selected' : '' }}>
                                                        {{ opt.label }} 
                                                        {% if p.material.nature == 'CONSUMIBLE' %}(Disp: {{ opt.available }}){% endif %}
                                                        {% if opt.busy|default(false) %} (OCUPADO: {{ opt.locationName }}){% endif %}
                                                    </option>
                                                {% endfor %}
                                            </select>
                                        </td>
                                        <td class="pe-4">
                                            <div class="input-group input-group-sm">
                                                <input type="number" class="form-control text-end font-bold quantity-input dark:bg-slate-900/50 dark:border-slate-700 dark:text-slate-300"
                                                       value="{{ p.quantity }}" min="1"
                                                       data-action="input->kit-refill#validateQuantity"
                                                       {{ p.material.nature == 'EQUIPO_TECNICO' ? 'readonly' : '' }}>
                                                <span class="input-group-text bg-white dark:bg-slate-900/50 dark:border-slate-700 dark:text-slate-400">uds.</span>
                                            </div>
                                        </td>
                                        <td>
                                            <button type="button" class="btn btn-link text-red-400 p-0" data-action="click->kit-refill#removeRow">
                                                <i data-lucide="trash-2" class="w-4 h-4"></i>
                                            </button>
                                        </td>
                                    </tr>
                                {% endfor %}
                                {% if proposals|length == 0 %}
                                    <tr class="empty-row">
                                        <td colspan="4" class="text-center py-5">
                                            <div class="text-slate-400 italic">No hay propuestas automáticas.</div>
                                        </td>
                                    </tr>
                                {% endif %}
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-slate-50 dark:bg-slate-900/20 p-4 border-top border-slate-100 dark:border-slate-700 d-flex justify-content-end">
                    {% set form_action = is_new|default(false) ? path('app_kit_new_confirm') : path('app_kit_refill_confirm', {id: unit.id}) %}
                    {% set csrf_token_name = is_new|default(false) ? 'kit_new_confirm' : 'kit_refill_confirm' %}
                    
                    <form action="{{ form_action }}" method="POST" data-action="submit->kit-refill#submit">
                        <input type="hidden" name="_token" value="{{ csrf_token(csrf_token_name) }}">
                        <input type="hidden" name="proposals_data" id="proposals_data">
                        <button type="submit" class="btn btn-primary px-5 font-black uppercase shadow-md">
                            <i data-lucide="send" class="w-4 h-4 inline mr-2"></i> 
                            {% if is_new|default(false) %}
                                CONFIGURAR Y TRASLADAR
                            {% else %}
                                CONFIRMAR Y TRASLADAR
                            {% endif %}
                        </button>
                    </form>
                </div>
            </div>

            {# Hidden Template for adding rows #}
            <template data-kit-refill-target="prototype">
                <tr class="refill-row" data-material-id="__MAT_ID__" data-nature="__NATURE__">
                    <td class="ps-4">
                        <select class="form-select form-select-sm material-selector" data-action="change->kit-refill#onMaterialChange">
                            <option value="" disabled selected>Selecciona Material...</option>
                            {% for m in allMaterials %}
                                {# Exclude kit container from manual addition #}
                                {% if 'botiquín' not in m.name|lower and 'contenedor' not in m.name|lower and m.id != unit.material.id %}
                                    <option value="{{ m.id }}" data-nature="{{ m.nature }}">{{ m.name }}</option>
                                {% endif %}
                            {% endfor %}
                        </select>
                    </td>
                    <td class="identifier-container">
                        <select class="form-select form-select-sm identifier-select" disabled>
                            <option value="">Selecciona Lote/Unidad...</option>
                        </select>
                    </td>
                    <td class="pe-4">
                        <div class="input-group input-group-sm">
                            <input type="number" class="form-control text-end font-bold quantity-input" value="1" min="1" data-action="input->kit-refill#validateQuantity">
                            <span class="input-group-text bg-white">uds.</span>
                        </div>
                    </td>
                    <td>
                        <button type="button" class="btn btn-link text-red-400 p-0" data-action="click->kit-refill#removeRow">
                            <i data-lucide="trash-2" class="w-4 h-4"></i>
                        </button>
                    </td>
                </tr>
            </template>
        </div>

        <div class="col-lg-4">
            {# Pass warehouse options to JS #}
            <script id="warehouse-options-data" type="application/json">
                {{ warehouseOptions|json_encode|raw }}
            </script>

            <div class="card border-0 shadow-sm rounded-3 mb-4 bg-red-50 dark:bg-red-900/10 border-start border-red-200 dark:border-red-900/50" style="border-width: 0 0 0 4px !important;">
                <div class="card-header bg-transparent py-3 border-bottom border-red-100 dark:border-red-900/20">
                    <h5 class="text-xs font-black uppercase tracking-widest text-red-600 dark:text-red-400 m-0">Carencias (Vs Plantilla)</h5>
                </div>
                <div class="card-body p-4">
                    {% for s in shortages %}
                        <div class="mb-4 last:mb-0">
                            <div class="flex justify-between items-start mb-1">
                                <div>
                                    <div class="font-black text-slate-800 dark:text-slate-200 uppercase leading-none text-red-600 dark:text-red-400">{{ s.material.name }}</div>
                                    <div class="text-[10px] text-red-500 dark:text-red-400 font-black mt-1 uppercase">Faltan {{ s.needed }} unidades</div>
                                </div>
                            </div>

                            {% if s.alternatives %}
                                <div class="bg-white dark:bg-slate-900/30 rounded-lg p-2 border border-red-100 dark:border-red-900/20 shadow-sm mt-2">
                                    <div class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase mb-2">En otras ubicaciones:</div>
                                    {% for alt in s.alternatives %}
                                        <div class="flex justify-between items-center text-xs mb-1 last:mb-0">
                                            <span class="text-slate-600 dark:text-slate-400"><i data-lucide="{{ alt.type == 'KIT' ? 'briefcase' : 'truck' }}" class="w-3 h-3 inline mr-1"></i> {{ alt.location }}</span>
                                            <span class="font-bold text-blue-600 dark:text-blue-400">{{ alt.quantity }}</span>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                    {% else %}
                        <div class="text-center py-4">
                            <i data-lucide="check-circle" class="w-8 h-8 text-green-500 mx-auto mb-2"></i>
                            <div class="text-xs font-bold text-slate-500 uppercase">Sin carencias críticas</div>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-3 mb-4 bg-red-50 dark:bg-red-900/10 border-start border-red-200 dark:border-red-900/50" style="border-width: 0 0 0 4px !important;">
                <div class="card-header bg-transparent py-3 border-bottom border-red-100 dark:border-red-900/20">
                    <h5 class="text-xs font-black uppercase tracking-widest text-red-600 dark:text-red-400 m-0">Unidades en otros botiquines</h5>
                </div>
                <div class="card-body p-4">
                    {% set has_busy = false %}
                    {% for matId, opts in warehouseOptions %}
                        {% for opt in opts %}
                            {% if opt.busy|default(false) %}
                                {% set has_busy = true %}
                                <div class="mb-3 last:mb-0">
                                    <div class="flex justify-between items-start">
                                        <div>
                                            <div class="text-[10px] font-black text-red-600 dark:text-red-400 uppercase">{{ opt.label }}</div>
                                            <div class="text-[9px] text-slate-500 dark:text-slate-400 font-bold">Ubicación: {{ opt.locationName }}</div>
                                        </div>
                                        <button type="button" class="btn btn-xs btn-outline-red py-0 px-2 text-[10px] font-black" 
                                                data-action="kit-refill#forceSelect" 
                                                data-material-id="{{ matId }}" 
                                                data-unit-id="{{ opt.id }}">
                                            USAR ESTE
                                        </button>
                                    </div>
                                </div>
                            {% endif %}
                        {% endfor %}
                    {% endfor %}
                    
                    {% if not has_busy %}
                        <div class="text-center py-2 text-xs text-slate-400 italic">No hay unidades ocupadas relevantes.</div>
                    {% endif %}
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-3 dark:bg-slate-800">
                <div class="card-header bg-white dark:bg-slate-800 py-3 border-bottom border-slate-100 dark:border-slate-700">
                    <h5 class="text-xs font-black uppercase tracking-widest text-slate-400 m-0">Resumen de Operación</h5>
                </div>
                <div class="card-body p-4">
                    <div class="text-sm mb-3">
                        <strong class="text-slate-600 dark:text-slate-400">Destino:</strong><br>
                        <span class="font-bold text-blue-600 dark:text-blue-400">{{ unit.alias ?: unit.serialNumber }}</span>
                    </div>
                    <div class="text-sm mb-3">
                        <strong class="text-slate-600 dark:text-slate-400">Origen Principal:</strong><br>
                        <span class="font-bold text-slate-800 dark:text-slate-200">Almacenes (Central / Farmacia / CECOM)</span>
                    </div>
                    <hr class="my-4 border-slate-100 dark:border-slate-700">
                    <div class="d-grid">
                        {% if is_new|default(false) %}
                            <a href="{{ path('app_kit_new') }}" class="btn btn-outline-secondary rounded-pill font-bold dark:text-slate-300 dark:border-slate-600">
                                CANCELAR Y VOLVER
                            </a>
                        {% else %}
                            <a href="{{ path('app_kit_inventory', {id: unit.id}) }}" class="btn btn-outline-secondary rounded-pill font-bold dark:text-slate-300 dark:border-slate-600">
                                CANCELAR Y VOLVER
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
