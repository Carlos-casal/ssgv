{% extends 'layout/app.html.twig' %}

{% block title %}Registrar Nuevo Botiquín{% endblock %}

{% block page_title %}
    <div class="d-flex align-items-center">
        <i data-lucide="plus-circle" class="w-6 h-6 text-blue-600 mr-2"></i>
        <span class="font-black tracking-tight uppercase">REGISTRAR NUEVO BOTIQUÍN</span>
    </div>
{% endblock %}

{% block content %}
<div class="container-fluid px-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5">
                    <form action="{{ path('app_kit_new') }}" method="POST"
                          data-controller="kit-registration"
                          data-kit-registration-check-alias-url-value="{{ path('app_kit_check_alias') }}"
                          data-action="submit->kit-registration#handleSubmit">
                        <input type="hidden" name="_token" value="{{ csrf_token('kit_new') }}">

                        <div class="mb-4">
                            <label for="template_id" class="form-label text-xs font-black uppercase tracking-widest text-slate-400">Plantilla Base</label>
                            <select name="template_id" id="template_id" class="form-select form-select-lg border-0 bg-slate-50 rounded-3 text-sm font-bold" required>
                                <option value="" disabled selected>Selecciona una plantilla...</option>
                                {% for template in templates %}
                                    <option value="{{ template.id }}">{{ template.name }} ({{ template.containerType }})</option>
                                {% endfor %}
                            </select>
                            <div class="form-text text-xxs mt-2">Los productos se cargarán automáticamente según esta plantilla.</div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label for="alias" class="form-label text-xs font-black uppercase tracking-widest text-slate-400">Alias / Identificador</label>
                                <input type="text" name="alias" id="alias" 
                                       class="form-control form-control-lg border-0 bg-slate-50 rounded-3 text-sm font-bold" 
                                       placeholder="Ej: Botiquín Alfa 1"
                                       data-kit-registration-target="alias"
                                       data-action="input->kit-registration#checkAlias">
                                <div id="alias_warning" class="text-xxs text-red-500 font-bold mt-1 d-none"
                                     data-kit-registration-target="aliasWarning">
                                    <i data-lucide="alert-triangle" class="w-3 h-3 inline"></i> Este alias ya está en uso.
                                </div>
                            </div>
    
                            <div class="col-md-6 mb-4">
                                <label for="serial_number" class="form-label text-xs font-black uppercase tracking-widest text-slate-400">Número de Serie</label>
                                <input type="text" name="serial_number" id="serial_number" class="form-control form-control-lg border-0 bg-slate-50 rounded-3 text-sm font-bold" placeholder="Ej: SN-2024-001">
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label for="supplier" class="form-label text-xs font-black uppercase tracking-widest text-slate-400">Proveedor</label>
                                <input type="text" name="supplier" id="supplier" class="form-control form-control-lg border-0 bg-slate-50 rounded-3 text-sm font-bold" placeholder="Ej: Cruz Roja Española">
                            </div>
    
                            <div class="col-md-6 mb-4">
                                <label for="purchase_price" class="form-label text-xs font-black uppercase tracking-widest text-slate-400">Precio de Compra</label>
                                <div class="input-group">
                                    <input type="number" step="0.01" name="purchase_price" id="purchase_price" 
                                           class="form-control form-control-lg border-0 bg-slate-50 rounded-s-3 text-sm font-bold" 
                                           placeholder="0.00"
                                           data-kit-registration-target="purchasePrice"
                                           data-action="input->kit-registration#calculate">
                                    <span class="input-group-text border-0 bg-slate-50 rounded-e-3 text-slate-400">€</span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label for="margin_percentage" class="form-label text-xs font-black uppercase tracking-widest text-slate-400">% Margen</label>
                                <div class="input-group">
                                    <input type="number" step="0.1" name="margin_percentage" id="margin_percentage" 
                                           class="form-control form-control-lg border-0 bg-slate-50 rounded-s-3 text-sm font-bold" 
                                           placeholder="0.0"
                                           data-kit-registration-target="margin"
                                           data-action="input->kit-registration#calculate">
                                    <span class="input-group-text border-0 bg-slate-50 rounded-e-3 text-slate-400">%</span>
                                </div>
                            </div>
    
                            <div class="col-md-6 mb-4">
                                <label for="iva" class="form-label text-xs font-black uppercase tracking-widest text-slate-400">IVA (%)</label>
                                <select name="iva" id="iva" class="form-select form-select-lg border-0 bg-slate-50 rounded-3 text-sm font-bold"
                                        data-kit-registration-target="iva"
                                        data-action="change->kit-registration#calculate">
                                    <option value="included" selected>IVA Incluido</option>
                                    <option value="0.21">21%</option>
                                    <option value="0.10">10%</option>
                                    <option value="0.04">4%</option>
                                    <option value="0">0%</option>
                                </select>
                            </div>
                        </div>

                        <div class="bg-blue-50/50 rounded-4 p-4 mb-5">
                            <div class="flex justify-between items-center">
                                <span class="text-xs font-black uppercase tracking-widest text-blue-600">Precio Total (Valuación)</span>
                                <span class="text-2xl font-black text-blue-700" id="total_price_display"
                                      data-kit-registration-target="totalDisplay">0.00 €</span>
                            </div>
                            <div id="iva_included_hint" class="text-xxs text-blue-500 font-bold mt-2 d-none"
                                 data-kit-registration-target="ivaHint">
                                * El precio de compra introducido se tratará como TOTAL. La base imponible se calculará automáticamente.
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg rounded-3 font-black uppercase tracking-widest shadow-sm py-3">
                                <i data-lucide="save" class="w-5 h-5 inline mr-2"></i> REGISTRAR Y CARGAR STOCK
                            </button>
                            <a href="{{ path('app_kit_index') }}" class="btn btn-link text-slate-400 text-xs font-bold uppercase text-decoration-none py-2">
                                Cancelar y volver
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
