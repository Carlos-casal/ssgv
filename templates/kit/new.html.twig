{% extends 'layout/app.html.twig' %}

{% block title %}Registrar Nuevo Botiquín{% endblock %}

{% block page_title %}
    <div class="d-flex align-items-center w-100">
        <i data-lucide="plus-circle" class="w-6 h-6 text-blue-600 mr-2"></i>
        <span class="font-black tracking-tight uppercase">REGISTRAR BOTIQUÍN FÍSICO</span>
    </div>
{% endblock %}

{% block content %}
<div class="container-fluid px-4">
    <form method="POST">
        <input type="hidden" name="_token" value="{{ csrf_token('kit_new') }}">
        <div class="row g-4 max-w-4xl mx-auto">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-header bg-white py-3 border-bottom border-slate-100">
                        <h5 class="text-xs font-black uppercase tracking-widest text-slate-400 m-0">Información Física</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <label class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1 d-block">Alias Identificativo</label>
                            <input type="text" name="alias" class="form-control form-control-sm font-bold" placeholder="Ej: Mochila 01" required>
                        </div>
                        <div>
                            <label class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1 d-block">Número de Serie</label>
                            <input type="text" name="serial_number" class="form-control form-control-sm font-monospace" placeholder="Ej: SN-4923-939" required>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-header bg-white py-3 border-bottom border-slate-100">
                        <h5 class="text-xs font-black uppercase tracking-widest text-slate-400 m-0">Selección de Plantilla</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <label class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1 d-block">Tipo de Botiquín</label>
                            <select name="template_id" class="form-select form-select-sm font-bold" required>
                                <option value="" disabled selected>Elige una configuración...</option>
                                {% for template in templates %}
                                    <option value="{{ template.id }}">{{ template.name }} ({{ template.items|length }} productos)</option>
                                {% endfor %}
                            </select>
                            <p class="text-[9px] text-slate-400 mt-2 mb-0 italic">Se cargará automáticamente el stock definido en la plantilla desde el Almacén Central.</p>
                        </div>
                        <div class="p-3 bg-blue-50 rounded-2 border border-blue-100">
                            <h6 class="text-[9px] font-black uppercase text-blue-600 mb-1">Nota sobre Stock:</h6>
                            <p class="text-[10px] text-blue-800 m-0">Al confirmar, se generarán los movimientos de trasvase correspondientes.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 mt-4 d-flex justify-content-end gap-2">
                <a href="{{ path('app_kit_index') }}" class="btn btn-light px-4 font-bold uppercase">CANCELAR</a>
                <button type="submit" class="btn btn-primary px-5 font-black uppercase shadow-md">REGISTRAR Y CARGAR STOCK</button>
            </div>
        </div>
    </form>
</div>
{% endblock %}
