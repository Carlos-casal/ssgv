{% extends 'layout/app.html.twig' %}

{% block title %}Editar Identidad de Botiquín{% endblock %}

{% block page_title %}
    <div class="d-flex align-items-center w-100">
        <i data-lucide="edit-3" class="w-6 h-6 text-blue-600 mr-2"></i>
        <span class="font-black tracking-tight uppercase">IDENTIDAD: {{ unit.alias ?: unit.serialNumber }}</span>
    </div>
{% endblock %}

{% block content %}
<div class="container-fluid px-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white py-3 border-bottom border-slate-100">
                    <h5 class="text-xs font-black uppercase tracking-widest text-slate-400 m-0">Datos del Contenedor Físico</h5>
                </div>
                <form method="POST">
                    <input type="hidden" name="_token" value="{{ csrf_token('kit_edit_' ~ unit.id) }}">
                    <div class="card-body p-4">
                        <div class="mb-4">
                            <label class="text-xxs font-black uppercase tracking-widest text-slate-400 mb-1 d-block">Alias (Nombre Operativo)</label>
                            <input type="text" name="alias" class="form-control form-control-sm font-bold" value="{{ unit.alias }}" placeholder="Ej: Mochila SVB 1">
                            <div class="form-text text-xxs uppercase">Este es el nombre visible en servicios y almacén.</div>
                        </div>

                        <div class="mb-4">
                            <label class="text-xxs font-black uppercase tracking-widest text-slate-400 mb-1 d-block">Número de Serie (S/N)</label>
                            <input type="text" name="serial_number" class="form-control form-control-sm font-bold" value="{{ unit.serialNumber }}" placeholder="S/N grabado en el equipo">
                        </div>

                        <div class="mb-0">
                            <label class="text-xxs font-black uppercase tracking-widest text-slate-400 mb-1 d-block">Configuración / Plantilla</label>
                            <select name="template_id" class="form-select form-select-sm font-bold" required>
                                {% for t in templates %}
                                    <option value="{{ t.id }}" {{ unit.template and unit.template.id == t.id ? 'selected' : '' }}>{{ t.name }} ({{ t.containerType }})</option>
                                {% endfor %}
                            </select>
                            <div class="form-text text-xxs uppercase">Define qué materiales debe contener este botiquín.</div>
                        </div>
                    </div>
                    <div class="card-footer bg-white p-4 border-top border-slate-100 d-flex justify-content-end gap-2">
                        <a href="{{ path('app_kit_index') }}" class="btn btn-light px-4 font-bold">CANCELAR</a>
                        <button type="submit" class="btn btn-primary px-5 font-black shadow-md">GUARDAR CAMBIOS</button>
                    </div>
                </form>
            </div>

            <div class="mt-4 text-center">
                <p class="text-xxs font-black uppercase tracking-widest text-slate-400">¿Quieres cambiar el contenido sugerido?</p>
                <a href="{{ path('app_kit_template_edit', {id: unit.template.id}) }}" class="btn btn-outline-secondary btn-sm">
                    <i data-lucide="settings" class="w-3 h-3 inline mr-1"></i> CONFIGURAR PRODUCTOS DE LA PLANTILLA
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
