{% extends 'layout/app.html.twig' %}

{% block title %}Plantillas de Botiquines{% endblock %}

{% block page_title %}
    <div class="d-flex justify-content-between align-items-center w-100">
        <div class="d-flex align-items-center">
            <i data-lucide="layout" class="w-6 h-6 text-blue-600 mr-2"></i>
            <span class="font-black tracking-tight uppercase">PLANTILLAS DE CONFIGURACIÓN</span>
        </div>
        <div class="d-flex gap-2">
            {% if templates|length == 0 %}
                <form action="{{ path('app_kit_template_seed_defaults') }}" method="POST">
                    <input type="hidden" name="_token" value="{{ csrf_token('seed_defaults') }}">
                    <button type="submit" class="btn btn-outline-primary btn-sm px-3">
                        <i data-lucide="sparkles" class="w-4 h-4 inline mr-1"></i> CREAR BASE POR DEFECTO
                    </button>
                </form>
            {% endif %}
            <a href="{{ path('app_kit_template_new') }}" class="btn btn-primary btn-sm px-4 shadow-sm font-bold">
                <i data-lucide="plus" class="w-4 h-4 inline mr-1"></i> NUEVA PLANTILLA
            </a>
        </div>
    </div>
{% endblock %}

{% block content %}
<div class="container-fluid px-4">
    <div class="row g-4">
        {% for template in templates %}
            <div class="col-md-4 col-lg-3">
                <div class="card border-0 shadow-sm rounded-3 overflow-hidden h-100 hover:shadow-md transition-shadow">
                    <div class="bg-slate-100 p-3 flex items-center justify-between">
                        <span class="text-[10px] font-black uppercase tracking-widest text-slate-500">{{ template.containerType }}</span>
                        <span class="px-2 py-0.5 bg-white border border-slate-200 rounded text-[9px] font-black uppercase text-slate-500">{{ template.items|length }} PRODUCTOS</span>
                    </div>
                    <div class="card-body p-4 text-center">
                        <div class="bg-blue-50 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-3 border border-blue-100">
                            <i data-lucide="layout" class="w-8 h-8 text-blue-600"></i>
                        </div>
                        <h4 class="font-black text-slate-800 mb-1">{{ template.name }}</h4>
                        <p class="text-xs text-slate-400 font-monospace mb-4">{{ template.description ?: 'Sin descripción' }}</p>

                        <div class="d-grid gap-2">
                            <a href="{{ path('app_kit_template_edit', {'id': template.id}) }}" class="btn btn-outline-secondary btn-sm rounded-pill font-bold">
                                <i data-lucide="edit-3" class="w-3.5 h-3.5 inline mr-1"></i> EDITAR PLANTILLA
                            </a>
                            <button type="button"
                                    class="btn btn-link text-red-500 text-xs font-bold uppercase tracking-widest p-0"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteTemplateModal"
                                    data-template-id="{{ template.id }}"
                                    data-template-name="{{ template.name }}"
                                    data-template-token="{{ csrf_token('delete_template_' ~ template.id) }}">
                                <i data-lucide="trash-2" class="w-3 h-3 inline mr-1"></i> ELIMINAR
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center py-5">
                <div class="bg-slate-50 rounded-2xl p-10 border border-slate-100 max-w-lg mx-auto">
                    <i data-lucide="layout" class="w-16 h-16 text-slate-200 mx-auto mb-4"></i>
                    <h3 class="font-black text-slate-400 mb-2 uppercase tracking-tight">No hay plantillas de botiquín</h3>
                    <p class="text-slate-400 text-sm mb-6">Crea una plantilla para definir qué productos deben contener tus botiquines.</p>
                    <a href="{{ path('app_kit_template_new') }}" class="btn btn-primary px-5 font-black uppercase shadow-sm">CREAR PRIMERA PLANTILLA</a>
                </div>
            </div>
        {% endfor %}
    </div>
</div>

<!-- Delete Template Modal -->
<div class="modal fade" id="deleteTemplateModal" tabindex="-1" aria-labelledby="deleteTemplateModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header bg-white border-0 pt-4 px-4 pb-2">
                <div class="w-12 h-12 bg-red-50 rounded-full flex items-center justify-center mb-0">
                    <i data-lucide="alert-triangle" class="w-6 h-6 text-red-600"></i>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body px-4 pb-4">
                <h4 class="font-black text-slate-800 mb-2 uppercase tracking-tight" id="deleteTemplateModalLabel">¿Eliminar plantilla?</h4>
                <p class="text-slate-500 text-sm mb-0">Estás a punto de eliminar la plantilla <span id="modalTemplateName" class="font-bold text-slate-800"></span>. Esta acción no se puede deshacer y los botiquines que usen esta plantilla se quedarán sin configuración.</p>
            </div>
            <div class="modal-footer bg-slate-50 border-0 p-4 d-flex gap-2">
                <button type="button" class="btn btn-light px-4 font-bold uppercase text-xs tracking-widest" data-bs-dismiss="modal">CANCELAR</button>
                <form id="deleteTemplateForm" method="POST" action="">
                    <input type="hidden" name="_token" id="deleteTemplateToken" value="">
                    <button type="submit" class="btn btn-danger px-4 font-black uppercase text-xs tracking-widest shadow-sm">ELIMINAR DEFINITIVAMENTE</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const deleteModal = document.getElementById('deleteTemplateModal');
    if (deleteModal) {
        deleteModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const templateId = button.getAttribute('data-template-id');
            const templateName = button.getAttribute('data-template-name');

            const modalTemplateName = deleteModal.querySelector('#modalTemplateName');
            const deleteForm = deleteModal.querySelector('#deleteTemplateForm');
            const tokenInput = deleteModal.querySelector('#deleteTemplateToken');

            modalTemplateName.textContent = templateName;
            deleteForm.action = '/kits/templates/' + templateId + '/delete';
            tokenInput.value = button.getAttribute('data-template-token');
        });
    }
});
</script>
{% endblock %}
