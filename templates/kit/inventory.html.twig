{% extends 'layout/app.html.twig' %}

{% block title %}Inventario del Botiquín: {{ unit.alias ?: unit.serialNumber }}{% endblock %}

{% block page_title %}
    <div class="d-flex justify-content-between align-items-center w-100">
        <div class="d-flex align-items-center">
            <i data-lucide="package" class="w-6 h-6 text-blue-600 mr-2"></i>
            <span class="font-black tracking-tight uppercase">BOTIQUÍN: {{ unit.alias ?: unit.serialNumber }}</span>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_kit_edit', {id: unit.id}) }}" class="btn btn-outline-amber btn-sm px-3 font-bold">
                <i data-lucide="edit-3" class="w-4 h-4 inline mr-1"></i> IDENTIDAD
            </a>
            <form action="{{ path('app_kit_refill', {id: unit.id}) }}" method="POST" onsubmit="return confirm('¿Reponer todos los productos hasta completar la plantilla?')">
                <input type="hidden" name="_token" value="{{ csrf_token('kit_refill') }}">
                <button type="submit" class="btn btn-outline-primary btn-sm">
                    <i data-lucide="refresh-cw" class="w-4 h-4 inline mr-1"></i> REPONER
                </button>
            </form>
            <a href="{{ path('app_kit_consume', {id: unit.id}) }}" class="btn btn-outline-danger btn-sm px-4 font-bold">
                <i data-lucide="minus-circle" class="w-4 h-4 inline mr-1"></i> REGISTRAR CONSUMO
            </a>
            <a href="{{ path('app_kit_refill_preview', {id: unit.id}) }}" class="btn btn-primary btn-sm px-4 shadow-sm font-bold">
                <i data-lucide="plus-circle" class="w-4 h-4 inline mr-1"></i> AÑADIR PRODUCTO EXTRA
            </a>
        </div>
    </div>
{% endblock %}

{% block content %}
<div class="container-fluid px-4" data-controller="kit-inventory" data-kit-inventory-update-url-value="{{ path('app_kit_update_ideal_quantity', {id: unit.id}) }}">
    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-3 mb-4">
                <div class="card-body p-4 text-center">
                    <div class="bg-blue-50 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-3">
                        <i data-lucide="briefcase" class="w-8 h-8 text-blue-600"></i>
                    </div>
                    <h3 class="font-bold text-xl mb-1">{{ unit.alias ?: 'Sin Alias' }}</h3>
                    <p class="text-slate-500 text-sm mb-1">Plantilla: <span class="font-bold text-slate-700">{{ unit.template.name }}</span></p>
                    <p class="text-slate-400 text-xs mb-3 uppercase font-black tracking-widest">{{ unit.template.containerType }}</p>
                    <div class="flex justify-center gap-2">
                        <span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-xxs font-black uppercase">{{ unit.operationalStatus }}</span>
                        <span class="px-3 py-1 bg-slate-100 text-slate-700 rounded-full text-xxs font-black uppercase">SN: {{ unit.serialNumber ?: 'N/A' }}</span>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white py-3 border-bottom border-slate-100">
                    <h5 class="text-xs font-black uppercase tracking-widest text-slate-400 m-0">Información de Ubicación</h5>
                </div>
                <div class="card-body p-4">
                    <p class="text-sm mb-2"><strong class="text-slate-600">Nombre Ubicación:</strong><br> {{ unit.kitLocation ? unit.kitLocation.name : 'N/A' }}</p>
                    <p class="text-sm mb-0"><strong class="text-slate-600">Tipo:</strong><br> Móvil (Kit)</p>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-3 mb-4">
                <div class="card-header bg-white py-3 border-bottom border-slate-100 d-flex justify-content-between align-items-center">
                    <h5 class="text-xs font-black uppercase tracking-widest text-slate-400 m-0">Contenido Actual (Stock Real)</h5>
                    <div class="flex items-center gap-4">
                        <div class="flex items-center gap-1.5">
                            <span class="w-2.5 h-2.5 rounded-full bg-green-500"></span>
                            <span class="text-xxs font-black text-slate-400 uppercase">Correcto</span>
                        </div>
                        <div class="flex items-center gap-1.5">
                            <span class="w-2.5 h-2.5 rounded-full bg-yellow-500"></span>
                            <span class="text-xxs font-black text-slate-400 uppercase">Próxima Cad.</span>
                        </div>
                        <div class="flex items-center gap-1.5">
                            <span class="w-2.5 h-2.5 rounded-full bg-red-500"></span>
                            <span class="text-xxs font-black text-slate-400 uppercase">Caducado</span>
                        </div>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-slate-50">
                                <tr>
                                    <th class="ps-4 text-xxs font-black uppercase text-slate-400 border-0">Producto</th>
                                    <th class="text-xxs font-black uppercase text-slate-400 border-0 text-center">Estado Cad.</th>
                                    <th class="text-xxs font-black uppercase text-slate-400 border-0 text-end" title="Cantidad física presente en este botiquín">Stock Actual</th>
                                    <th class="text-xxs font-black uppercase text-slate-400 border-0 text-end">Ideal (Plantilla)</th>
                                    <th class="text-xxs font-black uppercase text-slate-400 border-0 text-end pe-4">Acciones</th>
                                </tr>
                            </thead>
                            {# --- TABLE BODY --- #}
                            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                                {# 1. TEMPLATE ITEMS #}
                                {% for row in templateRows %}
                                    {% set item = row.templateItem %}
                                    {% set material = row.material %}
                                    {% set currentQty = row.currentQty %}
                                    
                                    <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-colors">
                                        <td class="px-3 py-3">
                                            <div class="flex items-center">
                                                <div class="w-8 h-8 rounded-lg bg-slate-100 dark:bg-slate-800 flex items-center justify-center mr-3">
                                                    {% if material and material.imagePath %}
                                                        <img src="{{ material.imagePath }}" class="w-6 h-6 object-contain" alt="">
                                                    {% elseif row.matchedMaterial and row.matchedMaterial.imagePath %}
                                                        <img src="{{ row.matchedMaterial.imagePath }}" class="w-6 h-6 object-contain" alt="">
                                                    {% else %}
                                                        <i data-lucide="{{ material ? 'package' : 'help-circle' }}" class="w-4 h-4 text-slate-400"></i>
                                                    {% endif %}
                                                </div>
                                                <div>
                                                    {% set targetMaterial = material ?: row.matchedMaterial|default(null) %}
                                                    {% set isLinked = targetMaterial is not null %}
                                                    {% set isShortage = currentQty < row.idealQuantity %}
                                                    
                                                    {% set nameClass = 'text-slate-700 dark:text-slate-200' %}
                                                    {% if isLinked %}
                                                        {% if isShortage %}
                                                            {% set nameClass = 'text-red-600 dark:text-red-400 font-black' %}
                                                        {% else %}
                                                            {% set nameClass = 'text-green-600 dark:text-green-400 font-bold' %}
                                                        {% endif %}
                                                    {% endif %}

                                                    <div class="font-bold {{ nameClass }} leading-tight">
                                                        {% if isLinked %}
                                                            {{ targetMaterial.name }}
                                                        {% else %}
                                                            {{ item.suggestedName }}
                                                        {% endif %}
                                                    </div>
                                                    
                                                    <div class="text-[10px] text-slate-400 uppercase tracking-wider mt-0.5">
                                                        {% if isLinked %}
                                                            <span class="font-medium text-slate-500">{{ targetMaterial.nature }}</span>
                                                        {% endif %}
                                                        
                                                        {% if row.matchedAliases is defined and row.matchedAliases|length > 0 %}
                                                            <div class="mt-1 flex flex-wrap gap-1">
                                                                {% for alias in row.matchedAliases %}
                                                                    <span class="text-[9px] bg-slate-100 dark:bg-slate-800 text-slate-500 px-1 rounded border border-slate-200 dark:border-slate-700">{{ alias }}</span>
                                                                {% endfor %}
                                                            </div>
                                                        {% endif %}

                                                        {% if row.sources is defined and row.sources|length > 1 %}
                                                            <div class="mt-1">
                                                                <span class="text-[8px] font-bold text-amber-600 bg-amber-50 px-1 rounded uppercase">Origen duplicado: {{ row.sources|join(' + ') }}</span>
                                                            </div>
                                                        {% endif %}
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-3 py-3 text-center">
                                            {% set status = null %}
                                            {% if material %}
                                                {% set status = material.expirationStatus %}
                                            {% elseif row.matchedMaterial %}
                                                {% set status = row.matchedMaterial.expirationStatus %}
                                            {% endif %}
                                            
                                            {% if status %}
                                                <div class="w-2 h-2 rounded-full bg-{{ status == 'green' ? 'green' : (status == 'red' ? 'red' : (status == 'orange' ? 'orange' : 'yellow')) }}-500 mx-auto shadow-sm"></div>
                                            {% elseif currentQty > 0 %}
                                                <div class="w-2 h-2 rounded-full bg-green-500 mx-auto shadow-sm shadow-green-500/50"></div>
                                            {% else %}
                                                <div class="w-2 h-2 rounded-full bg-slate-200 dark:bg-slate-700 mx-auto"></div>
                                            {% endif %}
                                        </td>
                                        <td class="px-3 py-3 text-end">
                                            <span class="text-sm {% if isLinked %}{% if isShortage %}text-red-600 font-bold{% else %}text-green-600 font-bold{% endif %}{% else %}text-slate-600 dark:text-slate-400{% endif %}">
                                                {{ currentQty }}
                                            </span>
                                        </td>
                                        <td class="px-3 py-3 text-end">
                                            <input type="number" 
                                                   value="{{ row.idealQuantity }}" 
                                                   class="form-control form-control-sm text-end w-16 d-inline-block font-monospace bg-slate-50 border-slate-200"
                                                   data-action="blur->kit-inventory#updateIdeal"
                                                   data-item-id="{{ item.id }}"
                                                   min="0">
                                        </td>
                                        <td class="px-3 py-3 text-end pe-4">
                                            <div class="flex justify-end gap-1">
                                                {% if material %}
                                                    <a href="{{ path('app_material_transfer', {id: material.id, origin_id: unit.kitLocation.id}) }}" class="btn btn-xs btn-outline-secondary px-2 py-1" title="Gestionar traslados">
                                                        <i data-lucide="arrow-right-left" class="w-3 h-3 inline mr-1"></i> Mover
                                                    </a>
                                                {% elseif row.matchedMaterial %}
                                                    <a href="{{ path('app_material_transfer', {id: row.matchedMaterial.id, origin_id: unit.kitLocation.id}) }}" class="btn btn-xs btn-outline-secondary px-2 py-1" title="Gestionar traslados">
                                                        <i data-lucide="arrow-right-left" class="w-3 h-3 inline mr-1"></i> Mover
                                                    </a>
                                                {% endif %}
                                                
                                                {% if currentQty < row.idealQuantity %}
                                                    <a href="{{ path('app_kit_refill_preview', {id: unit.id}) }}" class="btn btn-xs btn-primary px-2 py-1" title="Reponer stock">
                                                        <i data-lucide="shopping-cart" class="w-3 h-3 inline mr-1"></i> Reponer
                                                    </a>
                                                {% endif %}
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}

                                {# 2. EXTRA ITEMS (Product added that are NOT in the template) #}
                                {% if extraRows|length > 0 %}
                                    <tr class="bg-slate-50/50 dark:bg-slate-900/20">
                                        <td colspan="5" class="px-3 py-2 text-[10px] font-black text-slate-400 uppercase tracking-widest">
                                            Productos Extra (No en plantilla)
                                        </td>
                                    </tr>
                                    {% for row in extraRows %}
                                        {% set material = row.material %}
                                        <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-colors border-l-2 border-l-blue-400">
                                            <td class="px-3 py-3">
                                                <div class="flex items-center">
                                                    <div class="w-8 h-8 rounded-lg bg-blue-50 dark:bg-blue-900/20 flex items-center justify-center mr-3">
                                                        {% if material.imagePath %}
                                                            <img src="{{ material.imagePath }}" class="w-6 h-6 object-contain" alt="">
                                                        {% else %}
                                                            <i data-lucide="package-plus" class="w-4 h-4 text-blue-400"></i>
                                                        {% endif %}
                                                    </div>
                                                    <div>
                                                        <div class="font-bold text-slate-700 dark:text-slate-200">{{ material.name }}</div>
                                                        <div class="text-[10px] text-slate-400 uppercase tracking-wider">{{ material.nature }}</div>
                                                        {% if row.aliases is defined and row.aliases|length > 0 %}
                                                            <div class="mt-1 flex flex-wrap gap-1">
                                                                {% for alias in row.aliases %}
                                                                    <span class="text-[9px] bg-blue-50 dark:bg-blue-900/30 text-blue-600 px-1 rounded border border-blue-100 dark:border-blue-800">{{ alias }}</span>
                                                                {% endfor %}
                                                            </div>
                                                        {% endif %}
                                                        
                                                        {% if row.sources is defined and row.sources|length > 1 %}
                                                            <div class="mt-1">
                                                                <span class="text-[8px] font-bold text-amber-600 bg-amber-50 px-1 rounded uppercase">Origen duplicado: {{ row.sources|join(' + ') }}</span>
                                                            </div>
                                                        {% endif %}
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="px-3 py-3 text-center">
                                                {% set status = material.expirationStatus %}
                                                <div class="w-2 h-2 rounded-full bg-{{ status == 'green' ? 'green' : (status == 'red' ? 'red' : (status == 'orange' ? 'orange' : 'yellow')) }}-500 mx-auto shadow-sm"></div>
                                            </td>
                                            <td class="px-3 py-3 text-end font-bold text-blue-600">
                                                {{ row.quantity }}
                                            </td>
                                            <td class="px-3 py-3 text-end text-slate-400">
                                                -
                                            </td>
                                            <td class="px-3 py-3 text-end pe-4">
                                                <a href="{{ path('app_material_transfer', {id: material.id, origin_id: unit.kitLocation.id}) }}" class="btn btn-xs btn-outline-secondary px-2 py-1" title="Gestionar traslados">
                                                    <i data-lucide="arrow-right-left" class="w-3 h-3 inline mr-1"></i> Mover
                                                </a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                {% endif %}

                                {% if templateRows|length == 0 and extraRows|length == 0 %}
                                    <tr>
                                        <td colspan="5" class="text-center py-5 text-slate-400 italic">Este botiquín está vacío y no tiene plantilla asignada.</td>
                                    </tr>
                                {% endif %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-3 mt-4">
                <div class="card-header bg-white py-3 border-bottom border-slate-100">
                    <h5 class="text-xs font-black uppercase tracking-widest text-slate-400 m-0">Historial de Movimientos</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-slate-50">
                                <tr>
                                    <th class="ps-4 text-xxs font-black uppercase text-slate-400 border-0">Fecha</th>
                                    <th class="text-xxs font-black uppercase text-slate-400 border-0">Material</th>
                                    <th class="text-xxs font-black uppercase text-slate-400 border-0 text-center">Tipo</th>
                                    <th class="text-xxs font-black uppercase text-slate-400 border-0 text-end">Cantidad</th>
                                    <th class="text-xxs font-black uppercase text-slate-400 border-0 pe-4">Motivo / Usuario</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for movement in movements|default([]) %}
                                    {% set isEntry = movement.destination and unit.kitLocation and movement.destination.id == unit.kitLocation.id %}
                                    <tr>
                                        <td class="ps-4">
                                            <div class="font-bold text-slate-800">{{ movement.createdAt|date('d/m/Y', 'Europe/Madrid') }}</div>
                                            <div class="text-xxs text-slate-400 font-bold uppercase">{{ movement.createdAt|date('H:i', 'Europe/Madrid') }}</div>
                                        </td>
                                        <td>
                                            <div class="font-bold text-slate-800">{{ movement.material.name }}</div>
                                            {% if movement.batch %}
                                                <div class="text-xxs text-slate-400 uppercase">Lote: {{ movement.batch.batchNumber }}</div>
                                            {% elseif movement.materialUnit and movement.materialUnit.serialNumber %}
                                                <div class="text-xxs text-slate-400 uppercase">SN: {{ movement.materialUnit.serialNumber }}</div>
                                            {% endif %}
                                        </td>
                                        <td class="text-center">
                                            {% if isEntry %}
                                                <span class="badge bg-green-100 text-green-700 text-xxs uppercase"><i data-lucide="arrow-down-right" class="w-3 h-3 inline"></i> ENTRADA</span>
                                            {% else %}
                                                <span class="badge bg-red-100 text-red-700 text-xxs uppercase"><i data-lucide="arrow-up-right" class="w-3 h-3 inline"></i> SALIDA</span>
                                            {% endif %}
                                        </td>
                                        <td class="text-end font-monospace font-bold {% if isEntry %}text-green-600{% else %}text-red-600{% endif %}">
                                            {{ isEntry ? '+' : '-' }}{{ movement.quantity|abs }}
                                        </td>
                                        <td class="pe-4">
                                            <div class="text-sm text-slate-700">{{ movement.reason }}</div>
                                            <div class="text-xxs text-slate-400"><i data-lucide="user" class="w-3 h-3 inline"></i> {{ movement.user ? movement.user.email : (movement.responsible ? movement.responsible.name : 'Sistema') }}</div>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="5" class="text-center py-5 text-slate-400 italic">No hay movimientos registrados para este botiquín.</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
