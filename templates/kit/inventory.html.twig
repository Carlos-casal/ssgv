{% extends 'layout/app.html.twig' %}

{% block title %}Inventario del Botiquín: {{ unit.alias ?: unit.serialNumber }}{% endblock %}

{% block page_title %}
    <div class="d-flex justify-content-between align-items-center w-100">
        <div class="d-flex align-items-center">
            <i data-lucide="package" class="w-6 h-6 text-blue-600 mr-2"></i>
            <span class="font-black tracking-tight uppercase">BOTIQUÍN: {{ unit.alias ?: unit.serialNumber }}</span>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_kit_edit', {id: unit.id}) }}" class="btn btn-outline-amber btn-sm px-3 font-bold">
                <i data-lucide="edit-3" class="w-4 h-4 inline mr-1"></i> IDENTIDAD
            </a>
            <form action="{{ path('app_kit_refill', {id: unit.id}) }}" method="POST" onsubmit="return confirm('¿Reponer todos los productos hasta completar la plantilla?')">
                <input type="hidden" name="_token" value="{{ csrf_token('kit_refill') }}">
                <button type="submit" class="btn btn-outline-primary btn-sm">
                    <i data-lucide="refresh-cw" class="w-4 h-4 inline mr-1"></i> REPONER
                </button>
            </form>
            <a href="{{ path('app_kit_consume', {id: unit.id}) }}" class="btn btn-outline-danger btn-sm px-4 font-bold">
                <i data-lucide="minus-circle" class="w-4 h-4 inline mr-1"></i> REGISTRAR CONSUMO
            </a>
            <a href="{{ path('app_kit_refill_preview', {id: unit.id}) }}" class="btn btn-primary btn-sm px-4 shadow-sm font-bold">
                <i data-lucide="plus-circle" class="w-4 h-4 inline mr-1"></i> AÑADIR PRODUCTO EXTRA
            </a>
        </div>
    </div>
{% endblock %}

{% block content %}
<div class="container-fluid px-4">
    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-3 mb-4">
                <div class="card-body p-4 text-center">
                    <div class="bg-blue-50 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-3">
                        <i data-lucide="briefcase" class="w-8 h-8 text-blue-600"></i>
                    </div>
                    <h3 class="font-bold text-xl mb-1">{{ unit.alias ?: 'Sin Alias' }}</h3>
                    <p class="text-slate-500 text-sm mb-1">Plantilla: <span class="font-bold text-slate-700">{{ unit.template.name }}</span></p>
                    <p class="text-slate-400 text-xs mb-3 uppercase font-black tracking-widest">{{ unit.template.containerType }}</p>
                    <div class="flex justify-center gap-2">
                        <span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-xxs font-black uppercase">{{ unit.operationalStatus }}</span>
                        <span class="px-3 py-1 bg-slate-100 text-slate-700 rounded-full text-xxs font-black uppercase">SN: {{ unit.serialNumber ?: 'N/A' }}</span>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white py-3 border-bottom border-slate-100">
                    <h5 class="text-xs font-black uppercase tracking-widest text-slate-400 m-0">Información de Ubicación</h5>
                </div>
                <div class="card-body p-4">
                    <p class="text-sm mb-2"><strong class="text-slate-600">Nombre Ubicación:</strong><br> {{ unit.kitLocation ? unit.kitLocation.name : 'N/A' }}</p>
                    <p class="text-sm mb-0"><strong class="text-slate-600">Tipo:</strong><br> Móvil (Kit)</p>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-3 mb-4">
                <div class="card-header bg-white py-3 border-bottom border-slate-100 d-flex justify-content-between align-items-center">
                    <h5 class="text-xs font-black uppercase tracking-widest text-slate-400 m-0">Contenido Actual (Stock Real)</h5>
                    <div class="flex items-center gap-4">
                        <div class="flex items-center gap-1.5">
                            <span class="w-2.5 h-2.5 rounded-full bg-green-500"></span>
                            <span class="text-xxs font-black text-slate-400 uppercase">Correcto</span>
                        </div>
                        <div class="flex items-center gap-1.5">
                            <span class="w-2.5 h-2.5 rounded-full bg-yellow-500"></span>
                            <span class="text-xxs font-black text-slate-400 uppercase">Próxima Cad.</span>
                        </div>
                        <div class="flex items-center gap-1.5">
                            <span class="w-2.5 h-2.5 rounded-full bg-red-500"></span>
                            <span class="text-xxs font-black text-slate-400 uppercase">Caducado</span>
                        </div>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-slate-50">
                                <tr>
                                    <th class="ps-4 text-xxs font-black uppercase text-slate-400 border-0">Producto</th>
                                    <th class="text-xxs font-black uppercase text-slate-400 border-0 text-center">Estado Cad.</th>
                                    <th class="text-xxs font-black uppercase text-slate-400 border-0 text-end" title="Cantidad física presente en este botiquín">Stock Actual</th>
                                    <th class="text-xxs font-black uppercase text-slate-400 border-0 text-end">Ideal (Plantilla)</th>
                                    <th class="text-xxs font-black uppercase text-slate-400 border-0 text-end pe-4">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% set locationQuantities = {} %}

                                {% if unit.kitLocation %}
                                    {# Aggregate consumable stock #}
                                    {% for stock in unit.kitLocation.stocks %}
                                        {% if stock.material.nature == 'CONSUMIBLE' %}
                                            {% set matId = 'mat_' ~ stock.material.id %}
                                            {% set currentCount = locationQuantities[matId] ?? 0 %}
                                            {% set locationQuantities = locationQuantities|merge({(matId): currentCount + stock.quantity}) %}
                                        {% endif %}
                                    {% endfor %}

                                    {# Add technical unit counts #}
                                    {% for techUnit in unit.kitLocation.units %}
                                        {% if techUnit.id != unit.id %} {# Don't count the kit itself #}
                                            {% set matId = 'mat_' ~ techUnit.material.id %}
                                            {% set currentCount = locationQuantities[matId] ?? 0 %}
                                            {% set locationQuantities = locationQuantities|merge({(matId): currentCount + 1}) %}
                                        {% endif %}
                                    {% endfor %}
                                {% endif %}

                                {% set displayedMaterialIds = [] %}

                                {# First, items in the template #}
                                {% for item in unit.template.items %}
                                    {% if item.material %}
                                        {% set mId = 'mat_' ~ item.material.id %}
                                        {% set displayedMaterialIds = displayedMaterialIds|merge([mId]) %}
                                        {% set currentQty = locationQuantities[mId] ?? 0 %}
                                        <tr>
                                            <td class="ps-4">
                                                <div class="d-flex align-items-center">
                                                    {% if item.material.imagePath %}
                                                        <img src="{{ asset('uploads/material/' ~ item.material.imagePath) }}" class="rounded-2 me-3" style="width: 40px; height: 40px; object-fit: cover;">
                                                    {% else %}
                                                        <div class="bg-slate-100 rounded-2 me-3 flex items-center justify-center" style="width: 40px; height: 40px;">
                                                            <i data-lucide="package" class="w-5 h-5 text-slate-400"></i>
                                                        </div>
                                                    {% endif %}
                                                    <div>
                                                        <div class="font-bold text-slate-800">{{ item.material.name }}</div>
                                                        <div class="text-xxs text-slate-400 uppercase font-bold">{{ item.material.category }}</div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                {% set status = item.material.expirationStatus %}
                                                <span class="w-3 h-3 rounded-full inline-block bg-{{ status == 'green' ? 'green' : (status == 'red' ? 'red' : (status == 'orange' ? 'orange' : 'yellow')) }}-500" title="Caducidad: {{ item.material.expirationDate ? item.material.expirationDate|date('d/m/Y') : 'N/A' }}"></span>
                                            </td>
                                            <td class="text-end font-monospace">
                                                <span class="{% if currentQty < item.quantity %}text-red-600 font-bold{% endif %}">{{ currentQty }}</span>
                                            </td>
                                            <td class="text-end text-slate-400 font-monospace">
                                                {{ item.quantity }}
                                            </td>
                                            <td class="text-end pe-4">
                                                <a href="{{ path('app_material_transfer', {id: item.material.id, origin_id: unit.kitLocation.id}) }}" class="btn btn-xs btn-outline-secondary" title="Traspasar desde este botiquín">
                                                    <i data-lucide="move" class="w-3 h-3"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    {% else %}
                                        <tr class="bg-red-50/30">
                                            <td class="ps-4">
                                                <div class="d-flex align-items-center">
                                                    <div class="bg-slate-100 rounded-2 me-3 flex items-center justify-center" style="width: 40px; height: 40px;">
                                                        <i data-lucide="help-circle" class="w-5 h-5 text-amber-500"></i>
                                                    </div>
                                                    <div>
                                                        <div class="font-bold text-slate-800">{{ item.suggestedName }} <small class="text-slate-400 font-normal">(No registrado)</small></div>
                                                        <div class="text-xxs text-amber-600 uppercase font-bold">Por registrar</div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                <span class="w-3 h-3 rounded-full inline-block bg-slate-200" title="Material no registrado en inventario"></span>
                                            </td>
                                            <td class="text-end font-monospace">
                                                <span class="text-red-600 font-bold">0</span>
                                            </td>
                                            <td class="text-end text-slate-400 font-monospace">
                                                {{ item.quantity }}
                                            </td>
                                            <td class="text-end pe-4">
                                                <span class="text-xxs text-slate-400 italic">No disponible</span>
                                            </td>
                                        </tr>
                                    {% endif %}
                                {% endfor %}

                                {# Then, extra items in the location #}
                                {% for materialId, quantity in locationQuantities %}
                                    {% if materialId not in displayedMaterialIds %}
                                        {# Find a material object to get name and image #}
                                        {% set extraMaterial = null %}
                                        {% for stock in unit.kitLocation.stocks %}
                                            {% if 'mat_' ~ stock.material.id == materialId %}{% set extraMaterial = stock.material %}{% endif %}
                                        {% endfor %}
                                        {% if not extraMaterial %}
                                            {% for techUnit in unit.kitLocation.units %}
                                                {% if 'mat_' ~ techUnit.material.id == materialId %}{% set extraMaterial = techUnit.material %}{% endif %}
                                            {% endfor %}
                                        {% endif %}

                                        {% if extraMaterial %}
                                            <tr class="bg-slate-50">
                                                <td class="ps-4">
                                                    <div class="d-flex align-items-center opacity-75">
                                                        {% if extraMaterial.imagePath %}
                                                            <img src="{{ asset('uploads/material/' ~ extraMaterial.imagePath) }}" class="rounded-2 me-3" style="width: 40px; height: 40px; object-fit: cover;">
                                                        {% else %}
                                                            <div class="bg-slate-100 rounded-2 me-3 flex items-center justify-center" style="width: 40px; height: 40px;">
                                                                <i data-lucide="package" class="w-5 h-5 text-slate-400"></i>
                                                            </div>
                                                        {% endif %}
                                                        <div>
                                                            <div class="font-bold text-slate-800">{{ extraMaterial.name }} <small class="text-slate-400">(Extra)</small></div>
                                                            <div class="text-xxs text-slate-400 uppercase font-bold">{{ extraMaterial.category }}</div>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="text-center">
                                                    {% set status = extraMaterial.expirationStatus %}
                                                    <span class="w-3 h-3 rounded-full inline-block bg-{{ status == 'green' ? 'green' : (status == 'red' ? 'red' : (status == 'orange' ? 'orange' : 'yellow')) }}-500"></span>
                                                </td>
                                                <td class="text-end font-monospace">
                                                    {{ quantity }}
                                                </td>
                                                <td class="text-end text-slate-400 font-monospace">
                                                    -
                                                </td>
                                                <td class="text-end pe-4">
                                                    <a href="{{ path('app_material_transfer', {id: extraMaterial.id, origin_id: unit.kitLocation.id}) }}" class="btn btn-xs btn-outline-secondary" title="Traspasar desde este botiquín">
                                                        <i data-lucide="move" class="w-3 h-3"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                        {% endif %}
                                    {% endif %}
                                {% endfor %}

                                {% if unit.template.items|length == 0 and locationQuantities|length == 0 %}
                                    <tr>
                                        <td colspan="4" class="text-center py-5 text-slate-400 italic">Este botiquín está vacío y no tiene plantilla asignada.</td>
                                    </tr>
                                {% endif %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-3 mt-4">
                <div class="card-header bg-white py-3 border-bottom border-slate-100">
                    <h5 class="text-xs font-black uppercase tracking-widest text-slate-400 m-0">Historial de Movimientos</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-slate-50">
                                <tr>
                                    <th class="ps-4 text-xxs font-black uppercase text-slate-400 border-0">Fecha</th>
                                    <th class="text-xxs font-black uppercase text-slate-400 border-0">Material</th>
                                    <th class="text-xxs font-black uppercase text-slate-400 border-0 text-center">Tipo</th>
                                    <th class="text-xxs font-black uppercase text-slate-400 border-0 text-end">Cantidad</th>
                                    <th class="text-xxs font-black uppercase text-slate-400 border-0 pe-4">Motivo / Usuario</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for movement in movements|default([]) %}
                                    {% set isEntry = movement.destination and unit.kitLocation and movement.destination.id == unit.kitLocation.id %}
                                    <tr>
                                        <td class="ps-4">
                                            <div class="font-bold text-slate-800">{{ movement.createdAt|date('d/m/Y', 'Europe/Madrid') }}</div>
                                            <div class="text-xxs text-slate-400 font-bold uppercase">{{ movement.createdAt|date('H:i', 'Europe/Madrid') }}</div>
                                        </td>
                                        <td>
                                            <div class="font-bold text-slate-800">{{ movement.material.name }}</div>
                                            {% if movement.batch %}
                                                <div class="text-xxs text-slate-400 uppercase">Lote: {{ movement.batch.batchNumber }}</div>
                                            {% elseif movement.materialUnit and movement.materialUnit.serialNumber %}
                                                <div class="text-xxs text-slate-400 uppercase">SN: {{ movement.materialUnit.serialNumber }}</div>
                                            {% endif %}
                                        </td>
                                        <td class="text-center">
                                            {% if isEntry %}
                                                <span class="badge bg-green-100 text-green-700 text-xxs uppercase"><i data-lucide="arrow-down-right" class="w-3 h-3 inline"></i> ENTRADA</span>
                                            {% else %}
                                                <span class="badge bg-red-100 text-red-700 text-xxs uppercase"><i data-lucide="arrow-up-right" class="w-3 h-3 inline"></i> SALIDA</span>
                                            {% endif %}
                                        </td>
                                        <td class="text-end font-monospace font-bold {% if isEntry %}text-green-600{% else %}text-red-600{% endif %}">
                                            {{ isEntry ? '+' : '-' }}{{ movement.quantity|abs }}
                                        </td>
                                        <td class="pe-4">
                                            <div class="text-sm text-slate-700">{{ movement.reason }}</div>
                                            <div class="text-xxs text-slate-400"><i data-lucide="user" class="w-3 h-3 inline"></i> {{ movement.user ? movement.user.email : (movement.responsible ? movement.responsible.name : 'Sistema') }}</div>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="5" class="text-center py-5 text-slate-400 italic">No hay movimientos registrados para este botiquín.</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
