{% extends 'layout/app.html.twig' %}

{% block title %}Registrar Consumo: {{ unit.alias ?: unit.serialNumber }}{% endblock %}

{% block page_title %}
    <div class="d-flex align-items-center">
        <i data-lucide="minus-circle" class="w-6 h-6 text-red-600 mr-2"></i>
        <span class="font-black tracking-tight uppercase">REGISTRAR GASTO DE MATERIAL</span>
    </div>
{% endblock %}

{% block content %}
<div class="container px-4">
    <div class="max-w-4xl mx-auto">
        <form method="POST">
            <input type="hidden" name="_token" value="{{ csrf_token('kit_consume') }}">
            <div class="card border-0 shadow-lg rounded-3 overflow-hidden">
                <div class="bg-red-600 p-4 text-white">
                    <h5 class="m-0 font-bold uppercase tracking-tight">Selecciona lo que se ha consumido</h5>
                    <p class="text-red-100 text-xs mb-0 mt-1">Se restará del stock actual de: {{ unit.alias ?: unit.serialNumber }}</p>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="bg-slate-50">
                                <tr>
                                    <th class="ps-4 text-[10px] font-black uppercase text-slate-400 border-0">Producto</th>
                                    <th class="text-[10px] font-black uppercase text-slate-400 border-0 text-center">Disponible</th>
                                    <th class="text-[10px] font-black uppercase text-slate-400 border-0 text-end pe-4" style="width: 150px;">Gasto / Consumo</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for stock in unit.kitLocation.stocks %}
                                    {% if stock.quantity > 0 %}
                                    <tr>
                                        <td class="ps-4">
                                            <div class="font-bold text-slate-800">{{ stock.material.name }}</div>
                                            <div class="text-[10px] text-slate-400 uppercase">{{ stock.material.category }}</div>
                                        </td>
                                        <td class="text-center font-monospace">
                                            {{ stock.quantity }}
                                        </td>
                                        <td class="text-end pe-4">
                                            <div class="input-group input-group-sm">
                                                <input type="number"
                                                       name="consumption[{{ stock.material.id }}]"
                                                       class="form-control text-center font-bold"
                                                       value="0"
                                                       min="0"
                                                       max="{{ stock.quantity }}">
                                                <span class="input-group-text bg-white">unids.</span>
                                            </div>
                                        </td>
                                    </tr>
                                    {% endif %}
                                {% else %}
                                    <tr>
                                        <td colspan="3" class="text-center py-5 text-slate-400 italic">No hay productos con stock para consumir en este botiquín.</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-white p-4 border-top border-slate-100 d-flex justify-content-between">
                    <a href="{{ path('app_kit_inventory', {id: unit.id}) }}" class="btn btn-light px-4 font-bold">CANCELAR</a>
                    <button type="submit" class="btn btn-danger px-5 font-black shadow-md">CONFIRMAR GASTO</button>
                </div>
            </div>
        </form>
    </div>
</div>
{% endblock %}
