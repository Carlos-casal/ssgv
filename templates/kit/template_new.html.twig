{% extends 'layout/app.html.twig' %}

{% block title %}Nueva Plantilla de Botiquín{% endblock %}

{% block page_title %}
    <div class="d-flex align-items-center w-100">
        <i data-lucide="plus-circle" class="w-6 h-6 text-blue-600 mr-2"></i>
        <span class="font-black tracking-tight uppercase">CREAR NUEVA PLANTILLA DE CONFIGURACIÓN</span>
    </div>
{% endblock %}

{% block content %}
<div class="container-fluid px-4" data-controller="kit-template">
    <form method="POST">
        <input type="hidden" name="_token" value="{{ csrf_token('kit_template') }}">
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-3 h-100">
                    <div class="card-header bg-white py-3 border-bottom border-slate-100">
                        <h5 class="text-xs font-black uppercase tracking-widest text-slate-400 m-0">Detalles Básicos</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <label class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1 d-block">Nombre de la Plantilla</label>
                            <input type="text" name="name" class="form-control form-control-sm font-bold" placeholder="Ej: Mochila SVB Básica" required>
                        </div>
                        <div>
                            <label class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1 d-block">Descripción / Notas</label>
                            <textarea name="description" class="form-control form-control-sm" rows="4" placeholder="Para qué se usa esta configuración..."></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-header bg-white py-3 border-bottom border-slate-100 d-flex justify-content-between align-items-center">
                        <h5 class="text-xs font-black uppercase tracking-widest text-slate-400 m-0">Contenido Sugerido</h5>
                        <button type="button" class="btn btn-outline-primary btn-sm" data-action="click->kit-template#addItem">
                            <i data-lucide="plus" class="w-3 h-3 inline"></i> AÑADIR PRODUCTO
                        </button>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead class="bg-slate-50">
                                    <tr>
                                        <th class="ps-4 text-[10px] font-black uppercase text-slate-400 border-0">Material / Consumible</th>
                                        <th class="text-[10px] font-black uppercase text-slate-400 border-0 text-end pe-4" style="width: 150px;">Cantidad Ideal</th>
                                        <th class="border-0" style="width: 50px;"></th>
                                    </tr>
                                </thead>
                                <tbody data-kit-template-target="container">
                                    <!-- Row template for items -->
                                    <template data-kit-template-target="prototype">
                                        <tr class="kit-item-row">
                                            <td class="ps-4">
                                                <select name="items[__index__][material]" class="form-select form-select-sm" required>
                                                    <option value="" disabled selected>Selecciona material...</option>
                                                    {% for material in materials %}
                                                        <option value="{{ material.id }}">{{ material.name }} (Stock: {{ material.stock }})</option>
                                                    {% endfor %}
                                                </select>
                                            </td>
                                            <td class="pe-4">
                                                <div class="input-group input-group-sm">
                                                    <input type="number" name="items[__index__][quantity]" class="form-control text-end font-bold" min="1" value="1" required>
                                                    <span class="input-group-text bg-white">unids.</span>
                                                </div>
                                            </td>
                                            <td>
                                                <button type="button" class="btn btn-link text-red-400 p-0" data-action="click->kit-template#removeItem">
                                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    </template>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="card-footer bg-white p-4 border-top border-slate-100 d-flex justify-content-end gap-2">
                        <a href="{{ path('app_kit_template_index') }}" class="btn btn-light px-4 font-bold">CANCELAR</a>
                        <button type="submit" class="btn btn-primary px-5 font-black shadow-md">GUARDAR PLANTILLA</button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
{% endblock %}
