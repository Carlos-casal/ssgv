<!-- Sidebar -->
<div class="bg-slate-900 text-slate-300 flex flex-col flex-shrink-0 m-0 p-0 overflow-y-auto border-r border-slate-800 sidebar h-screen"
     id="sidebar"
     data-sidebar-target="sidebar">

    <!-- Header/Logo -->
    <div class="p-6 border-b border-slate-800 flex items-center justify-between">
        <div class="flex items-center gap-3 overflow-hidden">
            <div class="w-10 h-10 bg-blue-600 rounded-xl flex items-center justify-center shadow-lg shadow-blue-600/20 flex-shrink-0">
                <i data-lucide="command" class="w-6 h-6 text-white"></i>
            </div>
            <span class="font-black text-white tracking-tighter text-lg uppercase sidebar-header-text">Command<span class="text-blue-500">Center</span></span>
        </div>
        <div class="flex gap-2">
            <!-- Notification Bell -->
            <div class="dropdown">
                <button class="text-slate-500 hover:text-white transition-colors position-relative" type="button" id="alertsDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                    <i data-lucide="bell" class="w-5 h-5"></i>
                    {% if system_alerts|length > 0 %}
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-light" style="padding: 0.25em 0.4em; font-size: 0.5rem;">
                            {{ system_alerts|length }}
                        </span>
                    {% endif %}
                </button>
                <div class="dropdown-menu dropdown-menu-end shadow border-0 py-0 overflow-hidden" aria-labelledby="alertsDropdown" style="width: 300px; max-height: 400px; overflow-y: auto;">
                    <div class="bg-primary text-white p-3 text-xs font-bold uppercase tracking-wider">
                        Alertas del Sistema ({{ system_alerts|length }})
                    </div>
                    {% for alert in system_alerts %}
                        <a class="dropdown-item p-3 border-bottom d-flex align-items-start gap-3" href="{{ alert.link }}">
                            <div class="p-2 rounded bg-{{ alert.severity }}-soft text-{{ alert.severity }}">
                                <i data-lucide="{{ alert.type == 'low_stock' ? 'package' : 'calendar-off' }}" class="w-4 h-4"></i>
                            </div>
                            <div style="white-space: normal;">
                                <p class="mb-0 fw-bold text-xs">{{ alert.title }}</p>
                                <p class="mb-0 text-muted" style="font-size: 0.7rem;">{{ alert.message }}</p>
                            </div>
                        </a>
                    {% else %}
                        <div class="p-4 text-center text-muted">
                            <i data-lucide="check-circle" class="w-8 h-8 mb-2 opacity-25"></i>
                            <p class="mb-0 small">No hay alertas pendientes</p>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <button data-controller="theme" data-action="click->theme#toggle" class="text-slate-500 hover:text-white transition-colors">
                <i data-lucide="moon" class="w-5 h-5" data-theme-target="icon"></i>
            </button>
            <button data-action="click->sidebar#toggleCollapse" class="text-slate-500 hover:text-white transition-colors">
                <i data-lucide="panel-left-close" class="w-5 h-5" data-sidebar-target="toggleIcon"></i>
            </button>
        </div>
    </div>

    <!-- Navegación Principal -->
    <div class="flex-1 no-scrollbar overflow-y-auto pt-6">
        <nav class="space-y-8" id="main-nav">
            <!-- Dashboard Link -->
            <div class="px-6">
                {% set active = app.request.attributes.get('_route') == 'app_dashboard' %}
                <a href="{{ path('app_dashboard') }}" class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-bold text-sm sidebar-item {{ active ? 'bg-blue-600 text-white shadow-lg shadow-blue-600/20' : 'text-slate-400 hover:text-white' }}">
                    <i data-lucide="layout-dashboard" class="w-5 h-5 flex-shrink-0"></i>
                    <span class="sidebar-text">Dashboard</span>
                </a>
            </div>

            {% if is_granted('ROLE_ADMIN') %}
            <!-- OPERATIVA -->
            <div class="px-6">
                <p class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500 mb-4 ml-4 sidebar-section-title">Operativa</p>
                <ul class="space-y-1">
                    <li>
                        {% set active = app.request.attributes.get('_route') == 'app_services_list' %}
                        <a href="{{ path('app_services_list') }}" class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item {{ active ? 'bg-blue-600/10 text-blue-400' : 'text-slate-400 hover:text-white hover:bg-white/5' }}">
                            <i data-lucide="briefcase" class="w-5 h-5 flex-shrink-0"></i>
                            <span class="sidebar-text {{ active ? 'font-bold' : '' }}">Servicios</span>
                        </a>
                    </li>
                    <li>
                        <a href="#" class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item text-slate-400 hover:text-white hover:bg-white/5">
                            <i data-lucide="map" class="w-5 h-5 flex-shrink-0"></i>
                            <span class="sidebar-text">Mapa Operativo</span>
                        </a>
                    </li>
                </ul>
            </div>

            <!-- RECURSOS -->
            <div class="px-6">
                <p class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500 mb-4 ml-4 sidebar-section-title">Recursos</p>
                <ul class="space-y-1">
                    <li>
                        {% set active = app.request.attributes.get('_route') == 'app_volunteer_list' %}
                        <a href="{{ path('app_volunteer_list') }}" class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item {{ active ? 'bg-blue-600/10 text-blue-400' : 'text-slate-400 hover:text-white hover:bg-white/5' }}">
                            <i data-lucide="users" class="w-5 h-5 flex-shrink-0"></i>
                            <span class="sidebar-text {{ active ? 'font-bold' : '' }}">Voluntarios</span>
                        </a>
                    </li>
                    <li>
                        {% set active = app.request.attributes.get('_route') == 'app_warehouse_dashboard' %}
                        <a href="{{ path('app_warehouse_dashboard') }}" class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item {{ active ? 'bg-blue-600/10 text-blue-400' : 'text-slate-400 hover:text-white hover:bg-white/5' }}">
                            <i data-lucide="boxes" class="w-5 h-5 flex-shrink-0"></i>
                            <span class="sidebar-text {{ active ? 'font-bold' : '' }}">Almacén</span>
                        </a>
                    </li>
                    <li>
                        {% set active = app.request.attributes.get('_route') == 'app_vehicle_index' %}
                        <a href="{{ path('app_vehicle_index') }}" class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item {{ active ? 'bg-blue-600/10 text-blue-400' : 'text-slate-400 hover:text-white hover:bg-white/5' }}">
                            <i data-lucide="truck" class="w-5 h-5 flex-shrink-0"></i>
                            <span class="sidebar-text {{ active ? 'font-bold' : '' }}">Parque Móvil</span>
                        </a>
                    </li>
                    <li>
                        {% set active = app.request.attributes.get('_route') starts with 'app_material' %}
                        <a href="{{ path('app_material_index') }}" class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item {{ active ? 'bg-blue-600/10 text-blue-400' : 'text-slate-400 hover:text-white hover:bg-white/5' }}">
                            <i data-lucide="package" class="w-5 h-5 flex-shrink-0"></i>
                            <span class="sidebar-text {{ active ? 'font-bold' : '' }}">Inventario</span>
                        </a>
                    </li>
                    <li>
                        {% set active = app.request.attributes.get('_route') starts with 'app_kit' %}
                        <a href="{{ path('app_kit_index') }}" class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item {{ active ? 'bg-blue-600/10 text-blue-400' : 'text-slate-400 hover:text-white hover:bg-white/5' }}">
                            <i data-lucide="briefcase" class="w-5 h-5 flex-shrink-0"></i>
                            <span class="sidebar-text {{ active ? 'font-bold' : '' }}">Botiquines</span>
                        </a>
                    </li>
                </ul>
            </div>

            <!-- SISTEMA -->
            <div class="px-6">
                <p class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500 mb-4 ml-4 sidebar-section-title">Sistema</p>
                <ul class="space-y-1">
                    <li>
                        <a href="#" class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item text-slate-400 hover:text-white hover:bg-white/5">
                            <i data-lucide="settings" class="w-5 h-5 flex-shrink-0"></i>
                            <span class="sidebar-text">Configuración</span>
                        </a>
                    </li>
                    <li>
                        <a href="#" class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item text-slate-400 hover:text-white hover:bg-white/5">
                            <i data-lucide="user-cog" class="w-5 h-5 flex-shrink-0"></i>
                            <span class="sidebar-text">Usuarios</span>
                        </a>
                    </li>
                </ul>
            </div>
            {% else %}
                <div class="px-6">
                    <ul class="space-y-1">
                        <li>
                            <a href="{{ path('app_services_list') }}" class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item text-slate-400 hover:text-white hover:bg-white/5">
                                <i data-lucide="briefcase" class="w-5 h-5 flex-shrink-0"></i>
                                <span class="sidebar-text">Servicios</span>
                            </a>
                        </li>
                        <li>
                            <a href="{{ path('app_my_services') }}" class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item text-slate-400 hover:text-white hover:bg-white/5">
                                <i data-lucide="star" class="w-5 h-5 flex-shrink-0"></i>
                                <span class="sidebar-text">Mis servicios</span>
                            </a>
                        </li>
                    </ul>
                </div>
            {% endif %}
        </nav>
    </div>

    <!-- User Profile Fixed at Bottom -->
    <div class="mt-auto p-6 border-t border-slate-800 bg-slate-900/50 backdrop-blur-md">
        {% if app.user %}
            <div class="flex items-center gap-3 mb-4 sidebar-user-info overflow-hidden">
                <div class="w-10 h-10 rounded-full overflow-hidden border-2 border-slate-700 flex-shrink-0">
                    <img src="{{ asset('uploads/profile_pictures/' ~ (app.user.volunteer.profilePicture|default('default.png'))) }}"
                         alt="Foto de perfil"
                         class="w-full h-full object-cover">
                </div>
                <div class="flex-1 min-w-0">
                    <p class="font-bold text-white text-xs truncate">{{ app.user.volunteer.name|default('Usuario') }}</p>
                    <p class="text-[10px] text-slate-500 truncate">{{ app.user.email }}</p>
                </div>
            </div>
            <a href="{{ path('app_logout') }}" class="w-full flex items-center justify-center gap-2 px-4 py-2 rounded-lg bg-red-500/10 text-red-500 hover:bg-red-500 hover:text-white text-xs font-bold transition-all duration-200">
                <i data-lucide="log-out" class="w-4 h-4 flex-shrink-0"></i>
                <span class="sidebar-text">Salir</span>
            </a>
        {% endif %}
    </div>

</div>