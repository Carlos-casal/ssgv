<!-- Sidebar -->
<div class="bg-slate-900 text-slate-300 flex flex-col flex-shrink-0 m-0 p-0 border-r border-slate-800 sidebar h-screen"
     id="sidebar"
     style="overflow: visible !important;"
     data-sidebar-target="sidebar">

    <!-- Header/Logo -->
    <div class="p-4 border-b border-slate-800 flex items-center justify-between sidebar-header">
        <div class="flex flex-col gap-0 min-w-0 sidebar-header-container">
            <span class="font-black text-white tracking-tighter text-sm uppercase leading-tight sidebar-header-text truncate">PANEL</span>
            <span class="font-black text-white tracking-tighter text-sm uppercase leading-tight sidebar-header-text truncate">GESTIÓN</span>
        </div>
        <div class="flex items-center gap-2 flex-shrink-0 sidebar-actions">
            <button data-action="click->sidebar#toggleCollapse" class="text-slate-500 hover:text-white transition-colors flex items-center">
                <i data-lucide="panel-left-close" class="w-5 h-5" data-sidebar-target="toggleIcon"></i>
            </button>

            <button data-controller="theme" data-action="click->theme#toggle" class="text-slate-500 hover:text-white transition-colors flex items-center">
                <i data-lucide="sun" class="w-5 h-5" data-theme-target="icon"></i>
            </button>

            <!-- Notification Bell -->
            <div class="dropdown" data-controller="notification" style="position: relative;">
                <button class="text-slate-500 hover:text-white transition-colors position-relative flex items-center" type="button" id="alertsDropdown" data-bs-toggle="dropdown" data-bs-boundary="viewport" aria-expanded="false">
                    <i data-lucide="bell" class="w-5 h-5"></i>
                    {% set unread_count = 0 %}
                    {% for alert in system_alerts %}
                        {% if alert.isRead is not defined or not alert.isRead %}{% set unread_count = unread_count + 1 %}{% endif %}
                    {% endfor %}
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-light {{ unread_count == 0 ? 'd-none' : '' }}"
                          data-notification-target="badge"
                          style="padding: 0.25em 0.4em; font-size: 0.5rem;">
                        {{ unread_count }}
                    </span>
                </button>
                <div class="dropdown-menu dropdown-menu-end shadow border-0 py-0 dark:bg-slate-800 dark:border-slate-700" 
                     aria-labelledby="alertsDropdown" 
                     style="width: 320px; position: absolute; right: 0; left: auto !important; transform: none !important; margin-top: 10px; z-index: 1050;">


                    <div class="p-3 border-b border-gray-200 dark:border-slate-700 notification-header sticky-top top-0 bg-white dark:bg-slate-800 z-10">

                        <div class="flex items-center justify-between mb-2">
                            <span class="text-xs font-bold uppercase tracking-wider dark:text-white">Notificaciones</span>
                            <button type="button" class="text-gray-400 hover:text-gray-600 transition-colors">
                                <i data-lucide="chevron-up" class="w-4 h-4"></i>
                            </button>
                        </div>
                        <div class="flex items-center gap-4">
                            <button type="button"
                                    class="text-blue-600 hover:text-blue-700 text-xxs font-bold transition-colors"
                                    data-action="click->notification#markAllAsRead"
                                    data-url="{{ path('app_notification_read_all') }}">
                                Marcar todas como leídas
                            </button>
                            <button type="button"
                                    class="text-red-600 hover:text-red-700 text-xxs font-bold transition-colors"
                                    data-action="click->notification#deleteAll"
                                    data-url="{{ path('app_notification_delete_all') }}">
                                Borrar
                            </button>
                        </div>
                    </div>
                    <div class="divide-y divide-gray-100 dark:divide-slate-700 overflow-y-auto" style="max-height: 380px;" data-notification-target="dropdown">

                        {% for alert in system_alerts %}
                            <div class="p-4 relative transition-colors group border-l-2 {{ alert.isRead|default(false) ? 'opacity-30 border-transparent' : 'border-blue-500 bg-blue-500/5 dark:bg-blue-500/10' }}"
                                 data-notification-target="item">
                                <div class="flex gap-3">
                                    <div class="w-10 h-10 flex-shrink-0 flex items-center justify-center rounded bg-blue-100/20 text-blue-400 shadow-inner">
                                        <i data-lucide="{{ alert.type == 'low_stock' ? 'package' : (alert.type == 'expired' ? 'calendar-off' : 'info') }}" class="w-5 h-5"></i>
                                    </div>
                                    <div class="flex-1 pr-4">
                                        <div class="flex justify-between items-start mb-1">
                                            <p class="text-xs font-bold leading-tight dark:text-white">{{ alert.title }}</p>
                                            <button type="button"
                                                    class="text-gray-400 hover:text-gray-600 opacity-0 group-hover:opacity-100 transition-opacity"
                                                    data-action="click->notification#delete"
                                                    data-id="{{ alert.id|default(0) }}"
                                                    data-url="{{ alert.id is defined ? path('app_notification_delete', {id: alert.id}) : '#' }}">
                                                <i data-lucide="x" class="w-3 h-3"></i>
                                            </button>
                                        </div>
                                        <p class="text-muted text-[10px] mb-1">
                                            {% if alert.createdAt is defined %}
                                                {% set diff = date().diff(date(alert.createdAt)) %}
                                                {% if diff.days > 0 %}
                                                    hace {{ diff.days }} días
                                                {% elseif diff.h > 0 %}
                                                    hace {{ diff.h }}h
                                                {% elseif diff.i > 0 %}
                                                    hace {{ diff.i }}m
                                                {% else %}
                                                    ahora mismo
                                                {% endif %}
                                            {% else %}
                                                ahora mismo
                                            {% endif %}
                                        </p>
                                        <p class="text-xxs leading-relaxed opacity-80 dark:text-slate-300">{{ alert.message }}</p>
                                    </div>
                                </div>
                                {% if alert.id is defined %}
                                    <a href="{{ alert.link|default('#') }}"
                                       class="absolute inset-0 z-0"
                                       data-action="click->notification#markAsRead"
                                       data-id="{{ alert.id }}"
                                       data-url="{{ path('app_notification_read', {id: alert.id}) }}"></a>
                                {% endif %}
                            </div>
                        {% else %}
                            <div class="p-8 text-center text-slate-500">
                                <i data-lucide="check-circle" class="w-8 h-8 mb-2 opacity-25 mx-auto"></i>
                                <p class="mb-0 text-xs">No hay notificaciones pendientes</p>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Navegación Principal -->
    <div class="flex-1 no-scrollbar overflow-y-auto pt-6">
        <nav class="space-y-8" id="main-nav">
            <!-- Dashboard Link -->
            <div class="px-6">
                {% set active = app.request.attributes.get('_route') == 'app_dashboard' %}
                <a href="{{ path('app_dashboard') }}"
                   class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-bold text-sm sidebar-item {{ active ? 'bg-blue-600 text-white shadow-lg shadow-blue-600/20' : 'text-slate-400 hover:text-white' }}"
                   data-sidebar-target="navLink"
                   data-title="Menu"
                   title="Menu">
                    <i data-lucide="grid" class="w-5 h-5 flex-shrink-0"></i>
                    <span class="sidebar-text">Menu</span>
                </a>
            </div>

            {% if is_granted('ROLE_ADMIN') %}
            <!-- OPERATIVA -->
            <div class="px-6">
                <p class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500 mb-4 ml-4 sidebar-section-title">Operativa</p>
                <ul class="space-y-1">
                    <li>
                        {% set active = app.request.attributes.get('_route') == 'app_services_list' %}
                        <a href="{{ path('app_services_list') }}"
                           class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item {{ active ? 'bg-blue-600/10 text-blue-400' : 'text-slate-400 hover:text-white hover:bg-white/5' }}"
                           data-sidebar-target="navLink"
                           data-title="Servicios"
                           title="Servicios">
                            <i data-lucide="briefcase" class="w-5 h-5 flex-shrink-0"></i>
                            <span class="sidebar-text {{ active ? 'font-bold' : '' }}">Servicios</span>
                        </a>
                    </li>
                </ul>
            </div>

            <!-- RECURSOS -->
            <div class="px-6">
                <p class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500 mb-4 ml-4 sidebar-section-title">Recursos</p>
                <ul class="space-y-1">
                    <li>
                        {% set active = app.request.attributes.get('_route') == 'app_volunteer_list' %}
                        <a href="{{ path('app_volunteer_list') }}"
                           class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item {{ active ? 'bg-blue-600/10 text-blue-400' : 'text-slate-400 hover:text-white hover:bg-white/5' }}"
                           data-sidebar-target="navLink"
                           data-title="Voluntarios"
                           title="Voluntarios">
                            <i data-lucide="users" class="w-5 h-5 flex-shrink-0"></i>
                            <span class="sidebar-text {{ active ? 'font-bold' : '' }}">Voluntarios</span>
                        </a>
                    </li>
                    <li>
                        {% set active = app.request.attributes.get('_route') == 'app_vehicle_index' %}
                        <a href="{{ path('app_vehicle_index') }}"
                           class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item {{ active ? 'bg-blue-600/10 text-blue-400' : 'text-slate-400 hover:text-white hover:bg-white/5' }}"
                           data-sidebar-target="navLink"
                           data-title="Parque Móvil"
                           title="Parque Móvil">
                            <i data-lucide="truck" class="w-5 h-5 flex-shrink-0"></i>
                            <span class="sidebar-text {{ active ? 'font-bold' : '' }}">Parque Móvil</span>
                        </a>
                    </li>
                </ul>
            </div>

            <!-- LOGÍSTICA -->
            <div class="px-6">
                <p class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500 mb-4 ml-4 sidebar-section-title">Logística</p>
                <ul class="space-y-1">
                    <li>
                        {% set active = app.request.attributes.get('_route') == 'app_warehouse_dashboard' %}
                        <a href="{{ path('app_warehouse_dashboard') }}"
                           class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item {{ active ? 'bg-blue-600/10 text-blue-400' : 'text-slate-400 hover:text-white hover:bg-white/5' }}"
                           data-sidebar-target="navLink"
                           data-title="Almacén"
                           title="Almacén">
                            <i data-lucide="boxes" class="w-5 h-5 flex-shrink-0"></i>
                            <span class="sidebar-text {{ active ? 'font-bold' : '' }}">Almacén</span>
                        </a>
                    </li>
                    <li>
                        {% set active = app.request.attributes.get('_route') starts with 'app_material' %}
                        <a href="{{ path('app_material_index') }}"
                           class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item {{ active ? 'bg-blue-600/10 text-blue-400' : 'text-slate-400 hover:text-white hover:bg-white/5' }}"
                           data-sidebar-target="navLink"
                           data-title="Inventario"
                           title="Inventario">
                            <i data-lucide="package" class="w-5 h-5 flex-shrink-0"></i>
                            <span class="sidebar-text {{ active ? 'font-bold' : '' }}">Inventario</span>
                        </a>
                    </li>
                    <li>
                        {% set active = app.request.attributes.get('_route') starts with 'app_kit' %}
                        <a href="{{ path('app_kit_index') }}"
                           class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item {{ active ? 'bg-blue-600/10 text-blue-400' : 'text-slate-400 hover:text-white hover:bg-white/5' }}"
                           data-sidebar-target="navLink"
                           data-title="Botiquines"
                           title="Botiquines">
                            <i data-lucide="briefcase" class="w-5 h-5 flex-shrink-0"></i>
                            <span class="sidebar-text {{ active ? 'font-bold' : '' }}">Botiquines</span>
                        </a>
                    </li>
                </ul>
            </div>

            <!-- SISTEMA -->
            <div class="px-6">
                <p class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500 mb-4 ml-4 sidebar-section-title">Sistema</p>
                <ul class="space-y-1">
                    <li>
                        <a href="#"
                           class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item text-slate-400 hover:text-white hover:bg-white/5"
                           data-sidebar-target="navLink"
                           data-title="Configuración">
                            <i data-lucide="settings" class="w-5 h-5 flex-shrink-0"></i>
                            <span class="sidebar-text">Configuración</span>
                        </a>
                    </li>
                    <li>
                        <a href="#"
                           class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item text-slate-400 hover:text-white hover:bg-white/5"
                           data-sidebar-target="navLink"
                           data-title="Usuarios">
                            <i data-lucide="user-cog" class="w-5 h-5 flex-shrink-0"></i>
                            <span class="sidebar-text">Usuarios</span>
                        </a>
                    </li>
                </ul>
            </div>
            {% else %}
                <div class="px-6">
                    <ul class="space-y-1">
                        <li>
                            <a href="{{ path('app_services_list') }}"
                               class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item text-slate-400 hover:text-white hover:bg-white/5"
                               data-sidebar-target="navLink"
                               data-title="Servicios">
                                <i data-lucide="briefcase" class="w-5 h-5 flex-shrink-0"></i>
                                <span class="sidebar-text">Servicios</span>
                            </a>
                        </li>
                        <li>
                            <a href="{{ path('app_my_services') }}"
                               class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item text-slate-400 hover:text-white hover:bg-white/5"
                               data-sidebar-target="navLink"
                               data-title="Mis servicios">
                                <i data-lucide="star" class="w-5 h-5 flex-shrink-0"></i>
                                <span class="sidebar-text">Mis servicios</span>
                            </a>
                        </li>
                    </ul>
                </div>
            {% endif %}
        </nav>
    </div>

    <!-- User Profile Fixed at Bottom -->
    <div class="mt-auto p-6 border-t border-slate-800 bg-slate-900/50 backdrop-blur-md">
        {% if app.user %}
            <div class="flex items-center gap-3 mb-4 sidebar-user-info overflow-hidden">
                <div class="w-10 h-10 rounded-full overflow-hidden border-2 border-slate-700 flex-shrink-0">
                    <img src="{{ asset('uploads/profile_pictures/' ~ (app.user.volunteer.profilePicture|default('default.png'))) }}"
                         alt="Foto de perfil"
                         class="w-full h-full object-cover">
                </div>
                <div class="flex-1 min-w-0">
                    <p class="font-bold text-white text-xs truncate">{{ app.user.volunteer.name|default('Usuario') }}</p>
                    <p class="text-[10px] text-slate-500 truncate">{{ app.user.email }}</p>
                </div>
            </div>
            <a href="{{ path('app_logout') }}" class="w-full flex items-center justify-center gap-2 px-4 py-2 rounded-lg bg-red-500/10 text-red-500 hover:bg-red-500 hover:text-white text-xs font-bold transition-all duration-200">
                <i data-lucide="log-out" class="w-4 h-4 flex-shrink-0"></i>
                <span class="sidebar-text">Salir</span>
            </a>
        {% endif %}
    </div>

</div>