<!-- Sidebar -->
<div class="sidebar dashboard-bg text-slate-600 dark:text-slate-300 flex flex-col flex-shrink-0 m-0 p-0 border-none h-screen z-10"
     id="sidebar"
     style="overflow: visible !important;"
     data-sidebar-target="sidebar">

    <div class="px-6 flex flex-col sidebar-header">
        <!-- Header con Título y Botones en la misma línea -->
        <div class="flex items-center justify-between gap-2 sidebar-header-row">
            <div class="flex items-center gap-2 sidebar-header-container truncate overflow-hidden">
                <span class="font-black text-slate-900 dark:text-white tracking-tighter text-sm uppercase leading-tight sidebar-header-text truncate">PC GESTIÓN</span>
            </div>
            
            <div class="flex items-center gap-1 flex-shrink-0 sidebar-actions">
                <button data-action="click->sidebar#toggleCollapse"
                        class="w-8 h-8 flex items-center justify-center text-blue-600 hover:text-blue-700 transition-colors"
                        data-bs-toggle="tooltip" data-bs-placement="right" title="Contraer barra lateral"
                        id="sidebar-toggle-btn">
                    <i data-lucide="chevron-left" class="w-5 h-5" data-sidebar-target="toggleIcon"></i>
                </button>
                <button data-controller="theme" data-action="click->theme#toggle" class="w-8 h-8 flex items-center justify-center text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white transition-colors">
                    <i data-lucide="moon" class="w-5 h-5 dark:hidden"></i>
                    <i data-lucide="sun" class="w-5 h-5 hidden dark:block"></i>
                </button>
                
                <!-- Campana de Notificaciones -->
                <div class="relative" data-controller="notification">
                    <button class="w-8 h-8 flex items-center justify-center text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white transition-colors relative" 
                            type="button" id="alertsDropdown" data-action="click->notification#toggleDropdown" aria-expanded="false">
                        <i data-lucide="bell" class="w-5 h-5"></i>
                        {% set critical_count = 0 %}
                        {% for alert in system_alerts %}
                            {% if (not alert.isRead|default(false)) and (alert.severity == 'danger' or alert.type == 'reposicion') %}
                                {% set critical_count = critical_count + 1 %}
                            {% endif %}
                        {% endfor %}
                        <span class="absolute -top-1 -right-1 flex h-4.5 min-w-[18px] px-1 items-center justify-center rounded-full bg-red-500 text-[9px] font-black text-white ring-2 ring-white dark:ring-slate-900 shadow-sm {{ critical_count == 0 ? 'hidden' : '' }}"
                              data-notification-target="badge">
                            {{ critical_count }}
                        </span>
                    </button>
                    
                    <div class="hidden absolute right-0 mt-3 w-80 bg-white dark:bg-slate-800 rounded-2xl shadow-2xl border border-slate-200 dark:border-slate-700 overflow-hidden z-[100]" 
                         data-notification-target="dropdown">
                        <div class="p-3 border-b border-gray-200 dark:border-slate-700 notification-header sticky top-0 bg-white dark:bg-slate-800 z-10">
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-xs font-bold uppercase tracking-wider dark:text-white">Alertas Críticas</span>
                            </div>
                            <div class="flex items-center gap-4">
                                <button type="button" class="text-blue-600 hover:text-blue-700 text-xxs font-bold transition-colors"
                                        data-action="click->notification#markAllAsRead" data-url="{{ path('app_notification_read_all') }}">Marcar todas</button>
                                <button type="button" class="text-red-600 hover:text-red-700 text-xxs font-bold transition-colors"
                                        data-action="click->notification#deleteAll" data-url="{{ path('app_notification_delete_all') }}">Borrar</button>
                            </div>
                        </div>
                        <div class="divide-y divide-gray-100 dark:divide-slate-700 overflow-y-auto" style="max-height: 380px;">
                            {% for alert in system_alerts %}
                                {% if (not alert.isRead|default(false)) and (alert.severity == 'danger' or alert.type == 'reposicion') %}
                                    <div class="p-3 hover:bg-blue-500/5 dark:hover:bg-blue-500/10 transition-colors border-b border-gray-100 dark:border-slate-700 relative group">
                                        <div class="flex items-start gap-3">
                                            <i data-lucide="{{ alert.type == 'reposicion' ? 'package' : 'alert-triangle' }}" class="w-4 h-4 mt-1 {{ alert.type == 'reposicion' ? 'text-blue-500' : 'text-red-500' }}"></i>
                                            <div class="flex-1 min-w-0">
                                                <p class="text-xs font-medium text-gray-900 dark:text-white leading-tight">{{ alert.message }}</p>
                                                <span class="text-xxs text-gray-400 dark:text-slate-400">{{ alert.createdAt|date('d/m/Y H:i') }}</span>
                                            </div>
                                            <button type="button" class="p-1 text-gray-400 hover:text-blue-600 transition-colors opacity-0 group-hover:opacity-100"
                                                    data-action="click->notification#markAsRead" data-id="{{ alert.id }}" data-url="{{ path('app_notification_read', {'id': alert.id}) }}">
                                                <i data-lucide="check" class="w-3 h-3"></i>
                                            </button>
                                        </div>
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Navigation Menu -->
    <div class="flex-1 overflow-y-auto py-6 no-scrollbar">
        <nav class="px-3">
            <!-- Main Section -->
            <div class="mb-8">
                {% set active = app.request.attributes.get('_route') == 'app_dashboard' %}
                <a href="{{ path('app_dashboard') }}"
                   class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-bold text-sm sidebar-item {{ active ? 'bg-blue-600/10 text-blue-600 shadow-sm' : 'text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white hover:bg-black/5 dark:hover:bg-white/5' }}"
                   data-sidebar-target="navLink"
                   data-title="Inicio"
                   data-bs-toggle="tooltip" data-bs-placement="right" title="Inicio">
                    <i data-lucide="home" class="w-5 h-5 flex-shrink-0"></i>
                    <span class="sidebar-text">Inicio</span>
                </a>
            </div>

            <!-- Operativa Section -->
            <div class="mb-8">
                <p class="text-xxs font-black uppercase tracking-[0.2em] text-slate-500 mb-4 ml-4 sidebar-section-title">Operativa</p>
                <ul class="space-y-1">
                    <li>
                        {% set active = app.request.attributes.get('_route') == 'app_services_list' %}
                        <a href="{{ path('app_services_list') }}"
                           class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item {{ active ? 'bg-blue-600/10 text-blue-600 shadow-sm' : 'text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white hover:bg-black/5 dark:hover:bg-white/5' }}"
                           data-sidebar-target="navLink"
                           data-title="Servicios"
                           data-bs-toggle="tooltip" data-bs-placement="right" title="Servicios">
                            <i data-lucide="briefcase" class="w-5 h-5 flex-shrink-0"></i>
                            <span class="sidebar-text">Servicios</span>
                        </a>
                    </li>
                </ul>
            </div>

            <!-- Recursos Section -->
            <div class="mb-8">
                <p class="text-xxs font-black uppercase tracking-[0.2em] text-slate-500 mb-4 ml-4 sidebar-section-title">Recursos</p>
                <ul class="space-y-1">
                    <li>
                        {% set active = app.request.attributes.get('_route') == 'app_volunteer_list' %}
                        <a href="{{ path('app_volunteer_list') }}"
                           class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item {{ active ? 'bg-blue-600/10 text-blue-600 shadow-sm' : 'text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white hover:bg-black/5 dark:hover:bg-white/5' }}"
                           data-sidebar-target="navLink"
                           data-title="Voluntarios"
                           data-bs-toggle="tooltip" data-bs-placement="right" title="Voluntarios">
                            <i data-lucide="users" class="w-5 h-5 flex-shrink-0"></i>
                            <span class="sidebar-text">Voluntarios</span>
                        </a>
                    </li>
                    <li>
                        {% set active = app.request.attributes.get('_route') == 'app_vehicle_index' %}
                        <a href="{{ path('app_vehicle_index') }}"
                           class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item {{ active ? 'bg-blue-600/10 text-blue-600 shadow-sm' : 'text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white hover:bg-black/5 dark:hover:bg-white/5' }}"
                           data-sidebar-target="navLink"
                           data-title="Parque Móvil"
                           data-bs-toggle="tooltip" data-bs-placement="right" title="Parque Móvil">
                            <i data-lucide="truck" class="w-5 h-5 flex-shrink-0"></i>
                            <span class="sidebar-text">Parque Móvil</span>
                        </a>
                    </li>
                </ul>
            </div>

            <!-- Logística Section -->
            <div class="mb-8">
                <p class="text-xxs font-black uppercase tracking-[0.2em] text-slate-500 mb-4 ml-4 sidebar-section-title">Logística</p>
                <ul class="space-y-1">
                    <li>
                        {% set active = app.request.attributes.get('_route') == 'app_warehouse_dashboard' %}
                        <a href="{{ path('app_warehouse_dashboard') }}"
                           class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item {{ active ? 'bg-blue-600/10 text-blue-600 shadow-sm' : 'text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white hover:bg-black/5 dark:hover:bg-white/5' }}"
                           data-sidebar-target="navLink"
                           data-title="Almacén"
                           data-bs-toggle="tooltip" data-bs-placement="right" title="Almacén">
                            <i data-lucide="layout-dashboard" class="w-5 h-5 flex-shrink-0"></i>
                            <span class="sidebar-text">Almacén</span>
                        </a>
                    </li>
                    <li>
                        {% set active = app.request.attributes.get('_route') starts with 'app_material' %}
                        <a href="{{ path('app_material_index') }}"
                           class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item {{ active ? 'bg-blue-600/10 text-blue-600 shadow-sm' : 'text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white hover:bg-black/5 dark:hover:bg-white/5' }}"
                           data-sidebar-target="navLink"
                           data-title="Inventario"
                           data-bs-toggle="tooltip" data-bs-placement="right" title="Inventario">
                            <i data-lucide="package" class="w-5 h-5 flex-shrink-0"></i>
                            <span class="sidebar-text">Inventario</span>
                        </a>
                    </li>
                    <li>
                        {% set active = app.request.attributes.get('_route') starts with 'app_kit' %}
                        <a href="{{ path('app_kit_index') }}"
                           class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item {{ active ? 'bg-blue-600/10 text-blue-600 shadow-sm' : 'text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white hover:bg-black/5 dark:hover:bg-white/5' }}"
                           data-sidebar-target="navLink"
                           data-title="Botiquines"
                           data-bs-toggle="tooltip" data-bs-placement="right" title="Botiquines">
                            <i data-lucide="heart" class="w-5 h-5 flex-shrink-0"></i>
                            <span class="sidebar-text">Botiquines</span>
                        </a>
                    </li>
                </ul>
            </div>

            <!-- Sistema Section -->
            <div>
                <p class="text-xxs font-black uppercase tracking-[0.2em] text-slate-500 mb-4 ml-4 sidebar-section-title">Sistema</p>
                <ul class="space-y-1">
                    <li>
                        <a href="#"
                           class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white hover:bg-black/5 dark:hover:bg-white/5"
                           data-sidebar-target="navLink"
                           data-title="Configuración"
                           data-bs-toggle="tooltip" data-bs-placement="right" title="Configuración">
                            <i data-lucide="settings" class="w-5 h-5 flex-shrink-0"></i>
                            <span class="sidebar-text">Configuración</span>
                        </a>
                    </li>
                    <li>
                        <a href="#"
                           class="group w-full flex items-center gap-3 px-4 py-2 rounded-xl transition-all duration-200 font-medium text-sm sidebar-item text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white hover:bg-black/5 dark:hover:bg-white/5"
                           data-sidebar-target="navLink"
                           data-title="Usuarios"
                           data-bs-toggle="tooltip" data-bs-placement="right" title="Usuarios">
                            <i data-lucide="user-cog" class="w-5 h-5 flex-shrink-0"></i>
                            <span class="sidebar-text">Usuarios</span>
                        </a>
                    </li>
                </ul>
            </div>
        </nav>
    </div>

    <!-- User Profile Fixed at Bottom -->
    <div class="mt-auto p-6 dashboard-bg">
        {% if app.user %}
            <div class="flex items-center gap-3 mb-4 sidebar-user-info overflow-hidden">
                <div class="w-10 h-10 rounded-full overflow-hidden border-2 border-slate-300 dark:border-slate-700 flex-shrink-0">
                    <img src="{{ asset('uploads/profile_pictures/' ~ (app.user.volunteer.profilePicture|default('default.png'))) }}"
                         alt="Foto de perfil"
                         class="w-full h-full object-cover">
                </div>
                <div class="flex-1 min-w-0">
                    <p class="font-bold text-slate-900 dark:text-white text-xs truncate">{{ app.user.volunteer.name|default('Usuario') }}</p>
                    <p class="text-xxs text-slate-500 truncate">{{ app.user.email }}</p>
                </div>
            </div>
            
            <a href="{{ path('app_logout') }}"
               class="group w-full flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl bg-red-500/10 text-red-600 hover:bg-red-500 hover:text-white transition-all duration-200 font-bold text-xs">
                <i data-lucide="log-out" class="w-4 h-4"></i>
                <span class="sidebar-text">Cerrar Sesión</span>
            </a>
        {% endif %}
    </div>
</div>