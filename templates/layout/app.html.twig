{% extends 'base.html.twig' %}

{% block body %}
<div class="flex h-screen w-full overflow-hidden m-0 p-0" data-controller="sidebar">
    <!-- Header Responsive Superior Izquierda -->
    <div class="hidden max-[1199px]:flex fixed top-0 left-0 w-full h-16 bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 z-[55] items-center px-4 justify-between">
        <div class="flex items-center">
            <button data-action="click->sidebar#toggleCollapse"
                    class="w-10 h-10 flex items-center justify-center text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors">
                <i data-lucide="menu" class="w-6 h-6" data-sidebar-target="mobileIcon"></i>
            </button>
            <span class="ml-4 font-black text-slate-900 dark:text-white tracking-tighter text-sm uppercase">PC GESTIÓN</span>
        </div>

        <div class="flex items-center gap-2">
            <button data-controller="theme" data-action="click->theme#toggle" class="w-10 h-10 flex items-center justify-center text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white transition-colors">
                <i data-lucide="moon" class="w-5 h-5 dark:hidden"></i>
                <i data-lucide="sun" class="w-5 h-5 hidden dark:block"></i>
            </button>

            <!-- Campana de Notificaciones (Mobile) -->
            <div class="relative" data-controller="notification">
                <button class="w-10 h-10 flex items-center justify-center text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white transition-colors relative"
                        type="button" id="alertsDropdownMobile" data-action="click->notification#toggleDropdown" aria-expanded="false">
                    <i data-lucide="bell" class="w-5 h-5"></i>
                    {% set critical_count = 0 %}
                    {% for alert in system_alerts %}
                        {% if (not alert.isRead|default(false)) and (alert.severity == 'danger' or alert.type == 'reposicion') %}
                            {% set critical_count = critical_count + 1 %}
                        {% endif %}
                    {% endfor %}
                    <span class="absolute top-2 right-2 flex h-4 min-w-[16px] px-1 items-center justify-center rounded-full bg-red-500 text-[9px] font-black text-white ring-2 ring-white dark:ring-slate-900 shadow-sm {{ critical_count == 0 ? 'hidden' : '' }}"
                          data-notification-target="badge">
                        {{ critical_count }}
                    </span>
                </button>

                <div class="hidden absolute right-0 mt-3 w-72 bg-white dark:bg-slate-800 rounded-2xl shadow-2xl border border-slate-200 dark:border-slate-700 overflow-hidden z-[100]"
                     data-notification-target="dropdown">
                    <div class="p-3 border-b border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 sticky top-0 z-10">
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-xs font-bold uppercase tracking-wider dark:text-white">Alertas</span>
                        </div>
                    </div>
                    <div class="divide-y divide-gray-100 dark:divide-slate-700 overflow-y-auto" style="max-height: 300px;">
                        {% set has_alerts = false %}
                        {% for alert in system_alerts %}
                            {% if (not alert.isRead|default(false)) and (alert.severity == 'danger' or alert.type == 'reposicion') %}
                                {% set has_alerts = true %}
                                <div class="p-3 hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors">
                                    <div class="flex items-start gap-3">
                                        <i data-lucide="{{ alert.type == 'reposicion' ? 'package' : 'alert-triangle' }}" class="w-4 h-4 mt-0.5 {{ alert.type == 'reposicion' ? 'text-blue-500' : 'text-red-500' }}"></i>
                                        <div class="flex-1 min-w-0">
                                            <p class="text-xs font-medium text-gray-900 dark:text-white leading-tight">{{ alert.message }}</p>
                                        </div>
                                    </div>
                                </div>
                            {% endif %}
                        {% endfor %}

                        {% if not has_alerts %}
                            <div class="p-4 text-center text-xs text-slate-500">Sin alertas críticas</div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sidebar -->
    {% include 'layout/sidebar.html.twig' %}
    
    <!-- Main content -->
    <div class="main-content dashboard-bg flex-1 h-full overflow-y-auto px-4 sm:px-6 lg:px-8" data-sidebar-target="content" {% block body_attr %}{% endblock %}>
        {% set pageTitle = block('page_title') %}
        {% if pageTitle|trim is not empty %}
        <header class="flex items-center justify-between p-6">
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">{{ pageTitle|raw }}</h1>
        </header>
        {% endif %}
        <!-- Main content area -->
        <main class="flex-1 pb-6">
            {% for message in app.flashes('success') %}
                <div class="mb-4 p-4 bg-green-50 border border-green-200 rounded-lg">
                    <div class="flex items-center">
                        <i data-lucide="check-circle" class="w-5 h-5 text-green-500 mr-2"></i>
                        <span class="text-green-800">{{ message }}</span>
                    </div>
                </div>
            {% endfor %}
            
            {% for message in app.flashes('error') %}
                <div class="mt-4 p-4 bg-red-50 border border-red-200 rounded-lg">
                    <div class="flex items-center">
                        <i data-lucide="alert-circle" class="w-5 h-5 text-red-500 mr-2"></i>
                        <span class="text-red-800">{{ message }}</span>
                    </div>
                </div>
            {% endfor %}
            
            {% block content %}{% endblock %}
        </main>
    </div>
</div>
{% endblock %}
